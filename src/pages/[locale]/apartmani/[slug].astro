---
import Page from "~/layouts/Page.astro";
import Breadcrumbs from "~/components/seo/Breadcrumbs.astro";
import SchemaOrg from "~/components/seo/SchemaOrg.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getEmDashEntry, getEmDashCollection } from "emdash";
import { buildVacationRentalSchema } from "~/lib/schema";

const { locale, slug } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
if (!slug) return Astro.redirect(`/${locale}/apartmani`, 302);
const typedLocale = locale as Locale;

// Load apartment by slug - try direct lookup, then search collection
let entry: Record<string, unknown> | null = null;
try {
  // Try direct slug lookup
  const result = await getEmDashEntry("apartments", slug);
  if (result?.entry) {
    entry = (result.entry as { data?: Record<string, unknown> }).data ?? null;
  }
} catch {
  // Direct lookup failed - try collection search
  try {
    const { entries } = await getEmDashCollection("apartments");
    const match = entries?.find((e: unknown) => (e as { slug?: string }).slug === slug);
    if (match) {
      entry = (match as { data?: Record<string, unknown> }).data ?? null;
    }
  } catch { /* */ }
}
// Fallback apartments when CMS not yet seeded
if (!entry) {
  const fallbacks: Record<string, Record<string, unknown>> = {
    lavanda: {
      name: typedLocale === "hr" ? "Apartman Lavanda" : typedLocale === "sl" ? "Apartma Lavanda" : "Apartment Lavanda",
      tagline: typedLocale === "hr" ? "Mediteranski mir s pogledom na more" : typedLocale === "de" ? "Mediterrane Ruhe mit Meerblick" : typedLocale === "sl" ? "Mediteranski mir s pogledom na morje" : "Mediterranean peace with sea views",
      description: typedLocale === "hr" ? "Prostrani apartman za obitelji i parove s pogledom na more, terasom i svim sadržajima za savršen odmor." : typedLocale === "de" ? "Geräumige Ferienwohnung für Familien und Paare mit Meerblick, Terrasse und allem Komfort für einen perfekten Urlaub." : typedLocale === "sl" ? "Prostoren apartma za družine in pare s pogledom na morje, teraso in vsemi ugodnostmi za popoln oddih." : "Spacious apartment for families and couples with sea views, a terrace, and everything for a perfect holiday.",
      sleeps: 4, bedrooms: 2, size_sqm: 55, beach_distance_m: 150, price_from: 70,
      best_for: typedLocale === "hr" ? "Parovi i obitelji" : typedLocale === "de" ? "Paare und Familien" : typedLocale === "sl" ? "Pari in družine" : "Couples and families",
      hero_image: "https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg?auto=compress&w=1920",
      amenities_json: ["WiFi", "A/C", "TV", typedLocale === "hr" ? "Terasa s pogledom" : typedLocale === "de" ? "Terrasse mit Meerblick" : typedLocale === "sl" ? "Terasa z razgledom" : "Sea view terrace", "Parking", typedLocale === "hr" ? "Roštilj" : typedLocale === "de" ? "Grill" : typedLocale === "sl" ? "Žar" : "BBQ"],
    },
    tramuntana: {
      name: typedLocale === "hr" ? "Apartman Tramuntana" : typedLocale === "sl" ? "Apartma Tramuntana" : "Apartment Tramuntana",
      tagline: typedLocale === "hr" ? "Intimni kutak uz more" : typedLocale === "de" ? "Gemütlicher Rückzugsort am Meer" : typedLocale === "sl" ? "Intimen kotiček ob morju" : "Intimate retreat by the sea",
      description: typedLocale === "hr" ? "Ugodan apartman za dvoje, savršen za romantični bijeg. Blizu plaže, tih i miran." : typedLocale === "de" ? "Gemütliches Apartment für zwei, perfekt für einen romantischen Kurzurlaub. Strandnah, ruhig und friedlich." : typedLocale === "sl" ? "Prijeten apartma za dva, popoln za romantični pobeg. Blizu plaže, tih in miren." : "Cozy apartment for two, perfect for a romantic escape. Close to the beach, quiet and peaceful.",
      sleeps: 2, bedrooms: 1, size_sqm: 35, beach_distance_m: 100, price_from: 55,
      best_for: typedLocale === "hr" ? "Parovi" : typedLocale === "de" ? "Paare" : typedLocale === "sl" ? "Pari" : "Couples",
      hero_image: "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&w=1920",
      amenities_json: ["WiFi", "A/C", "TV", typedLocale === "hr" ? "Terasa" : typedLocale === "de" ? "Terrasse" : typedLocale === "sl" ? "Terasa" : "Terrace", "Parking"],
    },
  };
  entry = fallbacks[slug] ?? null;
}
if (!entry) return Astro.redirect(`/${locale}/apartmani`, 302);

const d = entry;
const name = (d.name as string) ?? slug;
const tagline = (d.tagline as string) ?? "";
const description = (d.description as string) ?? "";
const heroImage = (d.hero_image as string) ?? "";
const sleeps = d.sleeps as number | undefined;
const bedrooms = d.bedrooms as number | undefined;
const sizeSqm = d.size_sqm as number | undefined;
const bestFor = (d.best_for as string) ?? "";
const beachDistance = d.beach_distance_m as number | undefined;
const priceFrom = d.price_from as number | undefined;

let amenities: string[] = [];
try {
  const raw = d.amenities_json;
  const parsed = Array.isArray(raw) ? raw : typeof raw === "string" ? JSON.parse(raw) : [];
  amenities = parsed.filter((a: unknown) => typeof a === "string");
} catch { /* ignore */ }

const breadcrumbItems = [
  { name: t(typedLocale, "nav.home"), href: `/${typedLocale}/` },
  { name: t(typedLocale, "nav.apartments"), href: `/${typedLocale}/apartmani` },
  { name, href: `/${typedLocale}/apartmani/${slug}` },
];

const vacationRentalSchema = buildVacationRentalSchema({
  name,
  description: description || tagline,
  image: heroImage,
  sleeps: sleeps ?? 4,
  bedrooms: bedrooms ?? 1,
  bathrooms: 1,
  size: sizeSqm ?? 0,
  priceFrom: priceFrom ?? 0,
  amenities,
});
---

<Page title={name} description={tagline} locale={typedLocale} lowestPrice={priceFrom}>
  <SchemaOrg type="VacationRental" data={vacationRentalSchema} />

  {/* Hero */}
  {heroImage && (
    <section class="apt-hero">
      <img src={heroImage} alt={name} width="1920" height="1080" />
      <div class="apt-hero__overlay">
        <div class="container">
          <h1>{name}</h1>
          {tagline && <p class="apt-hero__tagline">{tagline}</p>}
        </div>
      </div>
      <svg class="apt-hero__wave" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
      </svg>
    </section>
  )}

  {/* Breadcrumbs */}
  <Breadcrumbs items={breadcrumbItems} locale={typedLocale} />

  {/* Details */}
  <section class="section" data-reveal>
    <div class="container">
      <div class="apt-detail">
        <div class="apt-detail__main">
          {description && <p class="text-lead">{description}</p>}

          {/* Meta grid */}
          <div class="apt-meta">
            {sleeps && <div class="apt-meta__item"><span class="apt-meta__label">{t(typedLocale, "apartments.sleeps").replace("{count}", String(sleeps))}</span></div>}
            {bedrooms && <div class="apt-meta__item"><span class="apt-meta__label">{t(typedLocale, "apartments.bedrooms", { count: String(bedrooms) })}</span></div>}
            {sizeSqm && <div class="apt-meta__item"><span class="apt-meta__label">{sizeSqm} m²</span></div>}
            {beachDistance && <div class="apt-meta__item"><span class="apt-meta__label">{t(typedLocale, "apartments.beachDistance").replace("{meters}", String(beachDistance))}</span></div>}
          </div>

          {bestFor && (
            <p class="apt-best-for">
              <strong>{t(typedLocale, "apartments.bestFor")}:</strong> {bestFor}
            </p>
          )}
        </div>

        <div class="apt-detail__sidebar">
          {/* Price card */}
          {priceFrom && (
            <div class="apt-price-card">
              <p class="apt-price-card__label">{t(typedLocale, "apartments.priceFromLabel")}</p>
              <p class="apt-price-card__amount">{priceFrom} &euro;<span>/{t(typedLocale, "apartments.night")}</span></p>
              <a href={`/${typedLocale}/kontakt`} class="btn btn--primary" style="width:100%; margin-top: var(--space-lg);">
                {t(typedLocale, "nav.inquire")}
              </a>
            </div>
          )}

          {/* Amenities */}
          {amenities.length > 0 && (
            <div class="apt-amenities">
              <h3>{t(typedLocale, "apartments.amenitiesTitle")}</h3>
              <ul>
                {amenities.map((a) => <li>{a}</li>)}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* Back to apartments */}
  <section class="section section--alt" data-reveal>
    <div class="container text-center">
      <a href={`/${typedLocale}/apartmani`} class="btn">
        {t(typedLocale, "nav.apartments")}
      </a>
    </div>
  </section>
</Page>

<style is:global>
  .apt-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }

  .apt-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .apt-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: clamp(40px, 6vw, 80px);
    z-index: 3;
    display: block;
  }

  .apt-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(transparent 40%, rgba(10, 31, 51, 0.75));
    padding-bottom: var(--space-3xl);
  }

  .apt-hero__overlay h1 {
    color: var(--color-white);
    font-size: clamp(2rem, 5vw, 4rem);
  }

  .apt-hero__tagline {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-lg);
    margin-top: var(--space-sm);
    font-style: italic;
    max-width: none;
  }

  .apt-detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .apt-detail {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-3xl);
    }
  }

  .apt-meta {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-stone);
    border-radius: 12px;
  }

  .apt-meta__label {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-navy);
  }

  .apt-best-for {
    margin-top: var(--space-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .apt-price-card {
    padding: var(--space-xl);
    background: var(--color-white);
    border-radius: 16px;
    box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 20px 60px rgba(10,31,51,0.10);
    text-align: center;
  }

  .apt-price-card__label {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
    max-width: none;
  }

  .apt-price-card__amount {
    font-family: var(--font-serif);
    font-size: var(--font-size-4xl);
    color: var(--color-navy);
    margin-top: var(--space-sm);
    max-width: none;
  }

  .apt-price-card__amount span {
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .apt-amenities {
    margin-top: var(--space-xl);
    padding: var(--space-xl);
    background: var(--color-stone);
    border-radius: 12px;
  }

  .apt-amenities h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-md);
  }

  .apt-amenities ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .apt-amenities li {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    padding-left: 1.2em;
    position: relative;
  }

  .apt-amenities li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-olive);
    font-weight: 700;
  }
</style>
