---
import Page from "~/layouts/Page.astro";
import Breadcrumbs from "~/components/seo/Breadcrumbs.astro";
import SchemaOrg from "~/components/seo/SchemaOrg.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getEmDashEntry, getEmDashCollection } from "emdash";
import { buildVacationRentalSchema } from "~/lib/schema";

const { locale, slug } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
if (!slug) return Astro.redirect(`/${locale}/apartmani`, 302);
const typedLocale = locale as Locale;

// Load apartment by slug - try direct lookup, then search collection
let entry: Record<string, unknown> | null = null;
try {
  // Try direct slug lookup
  const result = await getEmDashEntry("apartments", slug);
  if (result?.entry) {
    entry = (result.entry as { data?: Record<string, unknown> }).data ?? null;
  }
} catch {
  // Direct lookup failed - try collection search
  try {
    const { entries } = await getEmDashCollection("apartments");
    const match = entries?.find((e: unknown) => (e as { slug?: string }).slug === slug);
    if (match) {
      entry = (match as { data?: Record<string, unknown> }).data ?? null;
    }
  } catch { /* */ }
}
// Fallback apartments when CMS not yet seeded
// CMS slugs have locale suffix (e.g., "lavanda-hr") — strip it for fallback matching
const baseSlug = slug.replace(/-(?:hr|de|sl|en)$/, "");
if (!entry) {
  const fallbacks: Record<string, Record<string, unknown>> = {
    lavanda: {
      name: typedLocale === "hr" ? "Apartman Lavanda" : typedLocale === "sl" ? "Apartma Lavanda" : "Apartment Lavanda",
      tagline: typedLocale === "hr" ? "Mediteranski mir s pogledom na more" : typedLocale === "de" ? "Mediterrane Ruhe mit Meerblick" : typedLocale === "sl" ? "Mediteranski mir s pogledom na morje" : "Mediterranean peace with sea views",
      description: typedLocale === "hr"
        ? "Prostrani apartman na prvom katu s panoramskim pogledom na Pašmanski kanal i otoke. Dva spavaće sobe, potpuno opremljena kuhinja, klimatizacija i prostrana terasa - idealno mjesto za jutarnju kavu s pogledom na more. Plaža je udaljena samo 150 metara. Apartman je savršen za obitelji s djecom ili parove koji traže mir i prostor. Roštilj na terasi, besplatan parking, i blizina mosta prema Ugljanu čine ovaj apartman idealnom bazom za istraživanje oba otoka."
        : typedLocale === "de"
        ? "Geräumige Ferienwohnung im ersten Stock mit Panoramablick auf den Pašman-Kanal und die Inseln. Zwei Schlafzimmer, voll ausgestattete Küche, Klimaanlage und eine großzügige Terrasse - der perfekte Ort für einen Morgenkaffee mit Meerblick. Der Strand ist nur 150 Meter entfernt. Ideal für Familien mit Kindern oder Paare, die Ruhe und Platz suchen. Grill auf der Terrasse, kostenloser Parkplatz und die Nähe zur Brücke nach Ugljan machen diese Wohnung zur idealen Basis."
        : typedLocale === "sl"
        ? "Prostoren apartma v prvem nadstropju s panoramskim pogledom na Pašmanski kanal in otoke. Dve spalnici, popolnoma opremljena kuhinja, klimatska naprava in prostorna terasa - idealno mesto za jutranjo kavo z razgledom na morje. Plaža je oddaljena le 150 metrov. Popoln za družine z otroki ali pare, ki iščejo mir in prostor."
        : "Spacious first-floor apartment with panoramic views of the Pašman Channel and islands. Two bedrooms, fully equipped kitchen, air conditioning, and a generous terrace - the perfect spot for morning coffee with sea views. The beach is just 150 meters away. Ideal for families with children or couples seeking peace and space. BBQ on the terrace, free parking, and proximity to the Ugljan bridge make this the perfect base for exploring both islands.",
      sleeps: 4, bedrooms: 2, size_sqm: 55, beach_distance_m: 150, price_from: 70,
      best_for: typedLocale === "hr" ? "Parovi i obitelji" : typedLocale === "de" ? "Paare und Familien" : typedLocale === "sl" ? "Pari in družine" : "Couples and families",
      hero_image: "https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg?auto=compress&w=1920",
      gallery: [
        "https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/8430503/pexels-photo-8430503.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/27651489/pexels-photo-27651489.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/16194706/pexels-photo-16194706.jpeg?auto=compress&w=800",
      ],
      amenities_json: ["WiFi", "A/C", "TV", typedLocale === "hr" ? "Terasa s pogledom na more" : typedLocale === "de" ? "Terrasse mit Meerblick" : typedLocale === "sl" ? "Terasa z razgledom na morje" : "Sea view terrace", typedLocale === "hr" ? "Besplatni parking" : typedLocale === "de" ? "Kostenloser Parkplatz" : typedLocale === "sl" ? "Brezplačno parkiranje" : "Free parking", typedLocale === "hr" ? "Roštilj" : typedLocale === "de" ? "Grill" : typedLocale === "sl" ? "Žar" : "BBQ", typedLocale === "hr" ? "Potpuno opremljena kuhinja" : typedLocale === "de" ? "Voll ausgestattete Küche" : typedLocale === "sl" ? "Popolnoma opremljena kuhinja" : "Fully equipped kitchen", typedLocale === "hr" ? "Perilica rublja" : typedLocale === "de" ? "Waschmaschine" : typedLocale === "sl" ? "Pralni stroj" : "Washing machine"],
    },
    tramuntana: {
      name: typedLocale === "hr" ? "Apartman Tramuntana" : typedLocale === "sl" ? "Apartma Tramuntana" : "Apartment Tramuntana",
      tagline: typedLocale === "hr" ? "Intimni kutak uz more" : typedLocale === "de" ? "Gemütlicher Rückzugsort am Meer" : typedLocale === "sl" ? "Intimen kotiček ob morju" : "Intimate retreat by the sea",
      description: typedLocale === "hr"
        ? "Ugodan apartman u prizemlju, savršen za romantični bijeg. Jedna spavaća soba s bračnim krevetom, moderna kupaonica s tušem, i mala terasa s pogledom na vrt. Samo 100 metara od plaže - ujutro se probudite, popijte kavu i za par minuta ste u moru. Apartman je tih i miran, zaštićen od bure, s besplatnim parkingom ispred kuće. Idealan za parove koji žele jednostavnost i blizinu mora."
        : typedLocale === "de"
        ? "Gemütliches Erdgeschoss-Apartment, perfekt für einen romantischen Kurzurlaub. Ein Schlafzimmer mit Doppelbett, modernes Bad mit Dusche, und eine kleine Terrasse mit Gartenblick. Nur 100 Meter zum Strand - morgens aufwachen, Kaffee trinken und in wenigen Minuten im Meer. Ruhig und windgeschützt, mit kostenlosem Parkplatz vor dem Haus. Ideal für Paare, die Einfachheit und Meeresnähe suchen."
        : typedLocale === "sl"
        ? "Prijeten apartma v pritličju, popoln za romantični pobeg. Ena spalnica z zakonsko posteljo, moderna kopalnica s tušem in majhna terasa z razgledom na vrt. Le 100 metrov od plaže - zjutraj se zbudite, popijte kavo in v nekaj minutah ste v morju. Tih in miren, zaščiten pred burjo, z brezplačnim parkiranjem pred hišo."
        : "Cozy ground-floor apartment, perfect for a romantic escape. One bedroom with a double bed, modern bathroom with shower, and a small terrace overlooking the garden. Just 100 meters from the beach - wake up, have your coffee, and be in the sea within minutes. Quiet and sheltered from the bora wind, with free parking in front of the house. Ideal for couples who want simplicity and closeness to the sea.",
      sleeps: 2, bedrooms: 1, size_sqm: 35, beach_distance_m: 100, price_from: 55,
      best_for: typedLocale === "hr" ? "Parovi" : typedLocale === "de" ? "Paare" : typedLocale === "sl" ? "Pari" : "Couples",
      hero_image: "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&w=1920",
      gallery: [
        "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/30091818/pexels-photo-30091818.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/33168420/pexels-photo-33168420.jpeg?auto=compress&w=800",
        "https://images.pexels.com/photos/31934689/pexels-photo-31934689.jpeg?auto=compress&w=800",
      ],
      amenities_json: ["WiFi", "A/C", "TV", typedLocale === "hr" ? "Terasa" : typedLocale === "de" ? "Terrasse" : typedLocale === "sl" ? "Terasa" : "Terrace", typedLocale === "hr" ? "Besplatni parking" : typedLocale === "de" ? "Kostenloser Parkplatz" : typedLocale === "sl" ? "Brezplačno parkiranje" : "Free parking", typedLocale === "hr" ? "Tuš" : typedLocale === "de" ? "Dusche" : typedLocale === "sl" ? "Tuš" : "Shower"],
    },
  };
  entry = fallbacks[baseSlug] ?? fallbacks[slug] ?? null;
}
if (!entry) return Astro.redirect(`/${locale}/apartmani`, 302);

const d = entry;
const name = (d.name as string) ?? slug;
const tagline = (d.tagline as string) ?? "";
const description = (d.description as string) ?? "";
const heroImage = (d.hero_image as string) ?? "";
const sleeps = d.sleeps as number | undefined;
const bedrooms = d.bedrooms as number | undefined;
const sizeSqm = d.size_sqm as number | undefined;
const bestFor = (d.best_for as string) ?? "";
const beachDistance = d.beach_distance_m as number | undefined;
const priceFrom = d.price_from as number | undefined;

let gallery: string[] = [];
try {
  const rawGallery = d.gallery;
  gallery = Array.isArray(rawGallery) ? rawGallery as string[] : typeof rawGallery === "string" ? JSON.parse(rawGallery) : [];
} catch { /* ignore */ }

let amenities: string[] = [];
try {
  const raw = d.amenities_json;
  const parsed = Array.isArray(raw) ? raw : typeof raw === "string" ? JSON.parse(raw) : [];
  amenities = parsed.filter((a: unknown) => typeof a === "string");
} catch { /* ignore */ }

const breadcrumbItems = [
  { name: t(typedLocale, "nav.home"), href: `/${typedLocale}/` },
  { name: t(typedLocale, "nav.apartments"), href: `/${typedLocale}/apartmani` },
  { name, href: `/${typedLocale}/apartmani/${slug}` },
];

const vacationRentalSchema = buildVacationRentalSchema({
  name,
  description: description || tagline,
  image: heroImage,
  sleeps: sleeps ?? 4,
  bedrooms: bedrooms ?? 1,
  bathrooms: 1,
  size: sizeSqm ?? 0,
  priceFrom: priceFrom ?? 0,
  amenities,
});
---

<Page title={name} description={tagline} locale={typedLocale} lowestPrice={priceFrom}>
  <SchemaOrg type="VacationRental" data={vacationRentalSchema} />

  {/* Hero */}
  {heroImage && (
    <section class="apt-hero">
      <img src={heroImage} alt={name} width="1920" height="1080" />
      <div class="apt-hero__overlay">
        <div class="container">
          <h1>{name}</h1>
          {tagline && <p class="apt-hero__tagline">{tagline}</p>}
        </div>
      </div>
      <svg class="apt-hero__wave" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
      </svg>
    </section>
  )}

  {/* Breadcrumbs */}
  <Breadcrumbs items={breadcrumbItems} locale={typedLocale} />

  {/* Photo gallery - horizontal scroll */}
  {gallery.length > 0 && (
    <section class="apt-gallery" data-reveal>
      <div class="apt-gallery__scroll">
        {gallery.map((img, i) => (
          <div class="apt-gallery__item">
            <img src={img} alt={`${name} - ${i + 1}`} width="800" height="600" loading={i === 0 ? "eager" : "lazy"} />
          </div>
        ))}
      </div>
    </section>
  )}

  {/* Details */}
  <section class="section" data-reveal>
    <div class="container">
      <div class="apt-detail">
        <div class="apt-detail__main">
          {description && <p class="text-lead">{description}</p>}

          {/* Meta grid */}
          <div class="apt-meta">
            {sleeps && <div class="apt-meta__item"><span class="apt-meta__label">{t(typedLocale, "apartments.sleeps").replace("{count}", String(sleeps))}</span></div>}
            {bedrooms && <div class="apt-meta__item"><span class="apt-meta__label">{t(typedLocale, "apartments.bedrooms", { count: String(bedrooms) })}</span></div>}
            {sizeSqm && <div class="apt-meta__item"><span class="apt-meta__label">{sizeSqm} m²</span></div>}
            {beachDistance && <div class="apt-meta__item"><span class="apt-meta__label">{t(typedLocale, "apartments.beachDistance").replace("{meters}", String(beachDistance))}</span></div>}
          </div>

          {bestFor && (
            <p class="apt-best-for">
              <strong>{t(typedLocale, "apartments.bestFor")}:</strong> {bestFor}
            </p>
          )}
        </div>

        <div class="apt-detail__sidebar">
          {/* Price card */}
          {priceFrom && (
            <div class="apt-price-card">
              <p class="apt-price-card__label">{t(typedLocale, "apartments.priceFromLabel")}</p>
              <p class="apt-price-card__amount">{priceFrom} &euro;<span>/{t(typedLocale, "apartments.night")}</span></p>
              <a href={`/${typedLocale}/kontakt`} class="btn btn--primary" style="width:100%; margin-top: var(--space-lg);">
                {t(typedLocale, "nav.inquire")}
              </a>
            </div>
          )}

          {/* Amenities */}
          {amenities.length > 0 && (
            <div class="apt-amenities">
              <h3>{t(typedLocale, "apartments.amenitiesTitle")}</h3>
              <ul>
                {amenities.map((a) => <li>{a}</li>)}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* Back to apartments */}
  <section class="section section--alt" data-reveal>
    <div class="container text-center">
      <a href={`/${typedLocale}/apartmani`} class="btn">
        {t(typedLocale, "nav.apartments")}
      </a>
    </div>
  </section>
</Page>

<style is:global>
  .apt-gallery {
    padding: var(--space-lg) 0;
    overflow: hidden;
  }

  .apt-gallery__scroll {
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0 var(--space-lg);
    scrollbar-width: none;
  }

  .apt-gallery__scroll::-webkit-scrollbar {
    display: none;
  }

  .apt-gallery__item {
    flex: 0 0 80%;
    scroll-snap-align: center;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 12px 40px rgba(10,31,51,0.08);
  }

  @media (min-width: 768px) {
    .apt-gallery__item {
      flex: 0 0 45%;
    }
  }

  .apt-gallery__item img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .apt-gallery__item img {
      height: 400px;
    }
  }

  .apt-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }

  .apt-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .apt-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: clamp(40px, 6vw, 80px);
    z-index: 3;
    display: block;
  }

  .apt-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(transparent 40%, rgba(10, 31, 51, 0.75));
    padding-bottom: var(--space-3xl);
  }

  .apt-hero__overlay h1 {
    color: var(--color-white);
    font-size: clamp(2rem, 5vw, 4rem);
  }

  .apt-hero__tagline {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-lg);
    margin-top: var(--space-sm);
    font-style: italic;
    max-width: none;
  }

  .apt-detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .apt-detail {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-3xl);
    }
  }

  .apt-meta {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-stone);
    border-radius: 12px;
  }

  .apt-meta__label {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-navy);
  }

  .apt-best-for {
    margin-top: var(--space-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .apt-price-card {
    padding: var(--space-xl);
    background: var(--color-white);
    border-radius: 16px;
    box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 20px 60px rgba(10,31,51,0.10);
    text-align: center;
  }

  .apt-price-card__label {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
    max-width: none;
  }

  .apt-price-card__amount {
    font-family: var(--font-serif);
    font-size: var(--font-size-4xl);
    color: var(--color-navy);
    margin-top: var(--space-sm);
    max-width: none;
  }

  .apt-price-card__amount span {
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .apt-amenities {
    margin-top: var(--space-xl);
    padding: var(--space-xl);
    background: var(--color-stone);
    border-radius: 12px;
  }

  .apt-amenities h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-md);
  }

  .apt-amenities ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .apt-amenities li {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    padding-left: 1.2em;
    position: relative;
  }

  .apt-amenities li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-olive);
    font-weight: 700;
  }
</style>
