---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import ScrollCollage from "~/components/home/ScrollCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const apartments = await getLocalizedCollection("apartments", typedLocale);

// Content from CMS only
const displayApartments = apartments;

// Collage photos from homepage editorial entry (same exterior photos)
const allEditorial = await getLocalizedCollection("editorial", typedLocale);
const collageEntry = allEditorial.find((e) => e.data.page_key === "homepage" && e.data.section_key === "collage");
const collagePhotos = parsePhotoArray(collageEntry?.data.body);
---

<Page title={t(typedLocale, "apartments.title")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "apartments.title")} image="/api/img/2f348da2-de88-4bb0-8f54-d517545b6cff" />

  <section class="section">
    <div class="container">
      <div class="apartments-grid" data-reveal-stagger>
        {displayApartments.map((apt) => (
          <a href={`/${typedLocale}/apartmani/${apt.slug}`} class="apartment-card" data-reveal style="text-decoration:none; color:inherit; display:block;">
            <div class="apartment-card__image">
              <img
                src={apt.data.hero_image as string}
                alt={`${apt.data.name} - ${apt.data.tagline}`}
                width="600"
                height="400"
                loading="lazy"
              />
              {apt.data.best_for && (
                <span class="apartment-card__badge">{apt.data.best_for}</span>
              )}
            </div>
            <div class="apartment-card__content">
              <h2 class="apartment-card__name">{apt.data.name}</h2>
              <p class="apartment-card__tagline">{apt.data.tagline}</p>
              <div class="apartment-card__meta">
                <span>{t(typedLocale, "apartments.sleeps").replace("{count}", String(apt.data.sleeps))}</span>
                <span>{apt.data.size_sqm} m²</span>
                <span>{t(typedLocale, "apartments.beachDistance").replace("{meters}", String(apt.data.beach_distance_m))}</span>
              </div>
              <div class="apartment-card__footer">
                {apt.data.price_from && (
                  <span class="apartment-card__price">
                    {t(typedLocale, "apartments.fromPrice").replace("{price}", String(apt.data.price_from))}
                  </span>
                )}
                <span class="btn btn--primary">
                  {t(typedLocale, "apartments.viewButton")}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Exterior photo collage with wave borders */}
  {collagePhotos.length > 0 && (
    <section class="collage-strip">
      <svg class="collage-strip__wave collage-strip__wave--top" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="var(--color-navy)" />
      </svg>
      <div class="collage-strip__inner">
        <ScrollCollage images={collagePhotos} />
      </div>
      <svg class="collage-strip__wave collage-strip__wave--bottom" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M0,0 L0,30 C240,0 480,60 720,30 C960,0 1200,60 1440,30 L1440,0 Z" fill="var(--color-navy)" />
      </svg>
    </section>
  )}

  {/* Inquiry CTA */}
  <section class="section section--alt" id="inquiry" data-reveal>
    <div class="container text-center">
      <h2>{t(typedLocale, "homepage.cta.title")}</h2>
      <p style="margin-top: var(--space-lg); margin-inline: auto; color: var(--color-text-light);">
        {t(typedLocale, "trust.responseTime")}
      </p>
      <a href={`/${typedLocale}/kontakt`} class="btn btn--primary" style="margin-top: var(--space-xl);">
        {t(typedLocale, "booking.title")}
      </a>
    </div>
  </section>
</Page>

<style>
  .apartment-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .apartments-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .apartments-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .apartment-card {
    background: var(--color-white);
    overflow: hidden;
    border-radius: 12px;
    transition: box-shadow var(--duration-normal) var(--ease-out), transform 0.4s var(--ease-out);
  }

  .apartment-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .apartment-card__image {
    position: relative;
    overflow: hidden;
  }

  .apartment-card__image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .apartment-card:hover .apartment-card__image img {
    transform: scale(1.03);
  }

  .apartment-card__badge {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: var(--color-navy);
    color: var(--color-white);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
  }

  .apartment-card__content {
    padding: var(--space-xl);
  }

  .apartment-card__name {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-xs);
  }

  .apartment-card__tagline {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    font-style: italic;
  }

  .apartment-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .apartment-card__meta span {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .apartment-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .apartment-card__price {
    font-family: var(--font-serif);
    font-size: var(--font-size-xl);
    color: var(--color-navy);
  }

  .apartment-card__footer .btn {
    padding: 0.6rem 1.5rem;
  }
  /* Reduce spacing on apartments section — 50% of default */
  :global(.section:first-of-type) {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  /* Collage strip with wave borders */
  .collage-strip {
    position: relative;
    margin-top: calc(-1 * var(--space-lg));
  }

  .collage-strip__inner {
    background: var(--color-navy);
    padding: var(--space-2xl) 0;
  }

  .collage-strip__wave {
    display: block;
    width: 100%;
    height: clamp(30px, 5vw, 60px);
  }

  .collage-strip__wave--top {
    margin-bottom: -1px;
  }

  .collage-strip__wave--bottom {
    margin-top: -1px;
  }
</style>
