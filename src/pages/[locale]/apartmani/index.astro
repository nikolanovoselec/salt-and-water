---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;
---

<Page title={t(typedLocale, "apartments.title")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "apartments.title")} />

  <section class="section">
    <div class="container">
      <div class="apartments-coming" data-reveal>
        <div class="apartments-coming__images">
          <img src="https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg?auto=compress&w=600" alt="" width="600" height="800" loading="lazy" />
          <img src="https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&w=600" alt="" width="600" height="800" loading="lazy" />
        </div>
        <div class="apartments-coming__text">
          <p class="text-label">
            {typedLocale === "hr" ? "Uskoro" :
             typedLocale === "de" ? "Demnächst" :
             typedLocale === "sl" ? "Kmalu" :
             "Coming soon"}
          </p>
          <h2>
            {typedLocale === "hr" ? "Pripremamo nešto posebno za vas" :
             typedLocale === "de" ? "Wir bereiten etwas Besonderes für Sie vor" :
             typedLocale === "sl" ? "Pripravljamo nekaj posebnega za vas" :
             "We're preparing something special for you"}
          </h2>
          <p class="text-lead" style="margin-top: var(--space-lg);">
            {typedLocale === "hr" ? "Naši apartmani u Ždrelacu na otoku Pašmanu čekaju vas. S pogledom na more, kamenom terasom i svim što trebate za savršen odmor na Jadranu." :
             typedLocale === "de" ? "Unsere Ferienwohnungen in Ždrelac auf der Insel Pašman erwarten Sie. Mit Meerblick, Steinterrasse und allem, was Sie für einen perfekten Urlaub an der Adria brauchen." :
             typedLocale === "sl" ? "Naši apartmaji v Ždrelacu na otoku Pašman vas čakajo. S pogledom na morje, kamnito teraso in vsem, kar potrebujete za popoln dopust na Jadranu." :
             "Our apartments in Ždrelac on Pašman island await you. With sea views, stone terraces, and everything you need for a perfect Adriatic holiday."}
          </p>
          <a href={`/${typedLocale}/#inquiry`} class="btn btn--primary" style="margin-top: var(--space-2xl);">
            {t(typedLocale, "booking.title")}
          </a>
        </div>
      </div>
    </div>
  </section>
</Page>

<style>
  .apartments-coming {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .apartments-coming {
      grid-template-columns: 1fr 1.2fr;
      gap: var(--space-3xl);
    }
  }

  .apartments-coming__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .apartments-coming__images img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
  }

  .apartments-coming__text h2 {
    margin-top: var(--space-md);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  }
</style>
