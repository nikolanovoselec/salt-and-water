---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const apartments = await getLocalizedCollection("apartments", typedLocale);

// Fallback apartments when CMS not yet seeded
const fallbackApartments = [
  {
    slug: "lavanda",
    data: {
      name: typedLocale === "de" ? "Apartment Lavanda" : typedLocale === "sl" ? "Apartma Lavanda" : typedLocale === "en" ? "Apartment Lavanda" : "Apartman Lavanda",
      tagline: typedLocale === "de" ? "Mediterrane Ruhe mit Meerblick" : typedLocale === "sl" ? "Mediteranski mir s pogledom na morje" : typedLocale === "en" ? "Mediterranean peace with sea views" : "Mediteranski mir s pogledom na more",
      sleeps: 4,
      bedrooms: 2,
      size_sqm: 55,
      best_for: typedLocale === "de" ? "Paare und Familien" : typedLocale === "sl" ? "Pari in družine" : typedLocale === "en" ? "Couples and families" : "Parovi i obitelji",
      beach_distance_m: 150,
      price_from: 70,
      hero_image: "https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg?auto=compress&w=600",
    },
    locale: typedLocale,
  },
  {
    slug: "tramuntana",
    data: {
      name: typedLocale === "de" ? "Apartment Tramuntana" : typedLocale === "sl" ? "Apartma Tramuntana" : typedLocale === "en" ? "Apartment Tramuntana" : "Apartman Tramuntana",
      tagline: typedLocale === "de" ? "Gemütlicher Rückzugsort am Meer" : typedLocale === "sl" ? "Intimen kotiček ob morju" : typedLocale === "en" ? "Intimate retreat by the sea" : "Intimni kutak uz more",
      sleeps: 2,
      bedrooms: 1,
      size_sqm: 35,
      best_for: typedLocale === "de" ? "Paare" : typedLocale === "sl" ? "Pari" : typedLocale === "en" ? "Couples" : "Parovi",
      beach_distance_m: 100,
      price_from: 55,
      hero_image: "https://images.pexels.com/photos/1457842/pexels-photo-1457842.jpeg?auto=compress&w=600",
    },
    locale: typedLocale,
  },
];

const displayApartments = apartments.length > 0 ? apartments : fallbackApartments;
---

<Page title={t(typedLocale, "apartments.title")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "apartments.title")} image="https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg?auto=compress&w=1920" />

  <section class="section">
    <div class="container">
      <div class="apartments-grid" data-reveal-stagger>
        {displayApartments.map((apt) => (
          <a href={`/${typedLocale}/apartmani/${apt.slug}`} class="apartment-card" data-reveal style="text-decoration:none; color:inherit; display:block;">
            <div class="apartment-card__image">
              <img
                src={apt.data.hero_image as string}
                alt={`${apt.data.name} - ${apt.data.tagline}`}
                width="600"
                height="400"
                loading="lazy"
              />
              {apt.data.best_for && (
                <span class="apartment-card__badge">{apt.data.best_for}</span>
              )}
            </div>
            <div class="apartment-card__content">
              <h2 class="apartment-card__name">{apt.data.name}</h2>
              <p class="apartment-card__tagline">{apt.data.tagline}</p>
              <div class="apartment-card__meta">
                <span>{t(typedLocale, "apartments.sleeps").replace("{count}", String(apt.data.sleeps))}</span>
                <span>{apt.data.size_sqm} m²</span>
                <span>{t(typedLocale, "apartments.beachDistance").replace("{meters}", String(apt.data.beach_distance_m))}</span>
              </div>
              <div class="apartment-card__footer">
                {apt.data.price_from && (
                  <span class="apartment-card__price">
                    {t(typedLocale, "apartments.fromPrice").replace("{price}", String(apt.data.price_from))}
                  </span>
                )}
                <span class="btn btn--primary">
                  {t(typedLocale, "apartments.viewButton")}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Inquiry CTA */}
  <section class="section section--alt" id="inquiry" data-reveal>
    <div class="container text-center">
      <h2>{t(typedLocale, "homepage.cta.title")}</h2>
      <p style="margin-top: var(--space-lg); margin-inline: auto; color: var(--color-text-light);">
        {t(typedLocale, "trust.responseTime")}
      </p>
      <a href={`/${typedLocale}/kontakt`} class="btn btn--primary" style="margin-top: var(--space-xl);">
        {t(typedLocale, "booking.title")}
      </a>
    </div>
  </section>
</Page>

<style>
  .apartment-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .apartments-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .apartments-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .apartment-card {
    background: var(--color-white);
    overflow: hidden;
    border-radius: 12px;
    transition: box-shadow var(--duration-normal) var(--ease-out), transform 0.4s var(--ease-out);
  }

  .apartment-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .apartment-card__image {
    position: relative;
    overflow: hidden;
  }

  .apartment-card__image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .apartment-card:hover .apartment-card__image img {
    transform: scale(1.03);
  }

  .apartment-card__badge {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: var(--color-navy);
    color: var(--color-white);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
  }

  .apartment-card__content {
    padding: var(--space-xl);
  }

  .apartment-card__name {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-xs);
  }

  .apartment-card__tagline {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    font-style: italic;
  }

  .apartment-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .apartment-card__meta span {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .apartment-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .apartment-card__price {
    font-family: var(--font-serif);
    font-size: var(--font-size-xl);
    color: var(--color-navy);
  }

  .apartment-card__footer .btn {
    padding: 0.6rem 1.5rem;
  }
</style>
