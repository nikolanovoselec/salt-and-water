---
import Page from "~/layouts/Page.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Try CMS first
const cmsEntries = await getLocalizedCollection("editorial", typedLocale);
const cmsZdrelac = cmsEntries
  .filter((e) => e.data.page_key === "zdrelac")
  .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0));

// Fallback content
const content: Record<Locale, { title: string; intro: string; sections: Array<{ title: string; text: string; image: string; alt: string }> }> = {
  hr: {
    title: "Ždrelac",
    intro: "Malo selo od oko 300 stanovnika na sjevernom vrhu Pašmana. Ime dolazi od riječi ždrilo - uski prolaz između dva otoka. Most od 210 metara (obnovljen 2009.) jedini je cestovni spoj Pašmana i Ugljana, a crkva sv. Luke u središtu sela spominje se od 13. stoljeća.",
    sections: [
      { title: "Most između dva otoka", text: "Ždrelački most (210 m, obnovljen 2009.) jedini je cestovni spoj dvaju otoka. Iz sela ste za 5 minuta na Ugljanu, a za 20 minuta na trajektu za Zadar iz Preka (karta samo 2.52-3.45 eura, do 29 polazaka dnevno u sezoni). Nekada su Pašman i Ugljan bili jedan otok - more je raslo i razdvojilo ih upravo ovdje, na mjestu koje danas zovemo Ždrelac.", image: "https://images.pexels.com/photos/18759978/pexels-photo-18759978.jpeg?auto=compress&w=800", alt: "Most Ždrelac koji spaja Pašman i Ugljan" },
      { title: "Veliki Bokolj - vrh otoka (274 m)", text: "Najviši vrh Pašmana nudi pogled na Pašmanski kanal, Velebit, i po dobrom vremenu čak Dinaru, Prominu i Svilaju. Na vrhu vas čeka kameni vidikovac s panoramskim teleskopom. Staza kreće iz Dobropoljane, makadamskim putem lagano na vrh. Na susjednom vrhu Mali Bokolj stoji crkva Gospe Loretske, do koje vodi kameni put s postajama Križnog puta.", image: "https://images.pexels.com/photos/18759978/pexels-photo-18759978.jpeg?auto=compress&w=800", alt: "Pogled s vrha Veliki Bokolj" },
      { title: "Benediktinski samostan Ćokovac", text: "Iznad Tkona, na brdu s pogledom na kanal, stoji samostan sv. Kuzme i Damjana iz 12. stoljeća - jedini još naseljeni benediktinski samostan u Hrvatskoj. Šest redovnika živi ovdje u tišini staroj gotovo tisuću godina. U blizini su i ostaci utvrde Pustograda iz 6. stoljeća - važno arheološko nalazište gdje se stanovništvo sklanjalo u nemirnim vremenima.", image: "https://images.pexels.com/photos/2880507/pexels-photo-2880507.jpeg?auto=compress&w=800", alt: "Benediktinski samostan Ćokovac" },
      { title: "Stoljetni maslinici", text: "Krajolik Pašmana obilježavaju maslinici, vinogradi i smokve. Na južnoj strani otoka kamene kućice usred stoljetnih maslinika nekad su se koristile samo u sezoni berbe. Domaće maslinovo ulje ima onaj prepoznatljivi, blago pikantni okus koji ne možete naći u supermarketu - kupujte direktno od OPG-ova.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=800", alt: "Stoljetni maslinik na Pašmanu" },
      { title: "Tvrđava sv. Mihovila na Ugljanu", text: "Samo 20 minuta vožnje od Ždrelca, iznad Preka na 265 metara, stoji tvrđava iz 6. stoljeća obnovljena u 13. kao mletačka utvrda. Pogled se proteže preko 200 otoka zadarskog arhipelaga, Kornata, Zadra i Velebita. Do tvrđave vodi asfaltirana staza od 2.5 km (oko sat pješice). Na putu prolazite kroz maslinike i garig, a na vrhu vas čeka jedan od najljepših zalazaka na Jadranu.", image: "https://images.pexels.com/photos/2880507/pexels-photo-2880507.jpeg?auto=compress&w=800", alt: "Tvrđava sv. Mihovila iznad Preka" },
      { title: "Otočić Galovac i špilje Ugljana", text: "Ispred Preka leži otočić Galovac s franjevačkim samostanom - mirno utočište za posjet brodom. Ugljan krije i nekoliko špilja: Željina špilja u podnožju brda sv. Mihovila, Boškova špilja iznad uvale Svitla, te Vela i Mala špilja kod brda Kobiljak. Otok ima preko 100 km označenih pješačkih i biciklističkih staza.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Pogled na otočić Galovac" },
    ],
  },
  de: {
    title: "Ždrelac",
    intro: "Ein ruhiges Fischerdorf an der Nordspitze der Insel Pašman, durch eine Brücke mit Ugljan verbunden. Ein Ort, an dem die Zeit langsamer vergeht und das Meer zum Alltag gehört.",
    sections: [
      { title: "Brücke zwischen zwei Inseln", text: "Ždrelac liegt am schmalsten Teil von Pašman, direkt an der Brücke nach Ugljan. Das bedeutet Zugang zu beiden Inseln - die Ruhe von Pašman auf der einen, die Lebhaftigkeit von Ugljan und die schnelle Fähre nach Zadar auf der anderen Seite.", image: "https://images.pexels.com/photos/18759978/pexels-photo-18759978.jpeg?auto=compress&w=800", alt: "Ždrelac aus der Luft" },
      { title: "Versteckte Strände", text: "In unmittelbarer Nähe des Dorfes befinden sich Steinbuchten mit kristallklarem Wasser. Einige sind nur zu Fuß oder per Boot erreichbar - ein wahres Paradies für Ruhesuchende.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Kristallklares Meer" },
      { title: "Dalmatinisches Leben", text: "Die Konoba an der Promenade, der Fischer, der seinen Morgenfang verkauft, der Duft von Olivenöl aus dem Nachbarhaus. Ždrelac ist Dalmatien, wie es einmal war.", image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=800", alt: "Dalmatinische Küche" },
      { title: "Olivenhaine", text: "Die Umgebung von Ždrelac ist voller jahrhundertealter Olivenhaine. Hausgemachtes Olivenöl ist eines der wichtigsten Produkte der Insel.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=800", alt: "Olivenhaine auf Pašman" },
    ],
  },
  sl: {
    title: "Ždrelac",
    intro: "Tiha ribiška vas na severnem vrhu otoka Pašman, povezana z mostom z Ugljanom. Kraj, kjer se čas upočasni in morje postane del vsakdana.",
    sections: [
      { title: "Most med dvema otokoma", text: "Ždrelac leži na najožjem delu Pašmana, tik ob mostu proti Ugljanu. To pomeni dostop do obeh otokov - na eni strani mir Pašmana, na drugi živahnost Ugljana in hiter trajekt do Zadra.", image: "https://images.pexels.com/photos/18759978/pexels-photo-18759978.jpeg?auto=compress&w=800", alt: "Ždrelac iz zraka" },
      { title: "Skrite plaže", text: "V neposredni bližini vasi so kamnite zalivčke s kristalno čistim morjem. Nekatere so dostopne le peš ali z ladjo - pravi raj za iskalce miru.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Kristalno čisto morje" },
      { title: "Dalmatinsko življenje", text: "Konoba na rivi, ribič, ki prodaja jutranji ulov, vonj oljčnega olja iz sosedove hiše. Ždrelac je Dalmacija, kakršna je nekoč bila.", image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=800", alt: "Dalmatinska hrana" },
      { title: "Oljčni nasadi", text: "Okolica Ždrelaca je polna stoletnih oljčnih nasadov. Domače oljčno olje je eden najpomembnejših proizvodov otoka.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=800", alt: "Oljčni nasadi na Pašmanu" },
    ],
  },
  en: {
    title: "Ždrelac",
    intro: "A quiet fishing village at the northern tip of Pašman island, connected by bridge to Ugljan. A place where time slows down and the sea becomes part of everyday life.",
    sections: [
      { title: "Bridge between two islands", text: "Ždrelac sits at the narrowest part of Pašman, right at the bridge to Ugljan. This means access to both islands - the peace of Pašman on one side, the liveliness of Ugljan and the fast ferry to Zadar on the other.", image: "https://images.pexels.com/photos/18759978/pexels-photo-18759978.jpeg?auto=compress&w=800", alt: "Ždrelac from above" },
      { title: "Hidden beaches", text: "Near the village you'll find stone coves with crystal-clear water. Some are accessible only on foot or by boat - a true paradise for those seeking peace.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Crystal-clear sea" },
      { title: "Dalmatian life", text: "The konoba on the promenade, the fisherman selling his morning catch, the scent of olive oil from the neighbor's house. Ždrelac is Dalmatia as it once was.", image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=800", alt: "Dalmatian cuisine" },
      { title: "Olive groves", text: "The surroundings of Ždrelac are full of centuries-old olive groves. Homemade olive oil is one of the island's most important products.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=800", alt: "Olive groves on Pašman" },
    ],
  },
};

const fallback = content[typedLocale];

// Use CMS if available, otherwise fallback
const useCms = cmsZdrelac.length > 0;
const pageTitle = "Ždrelac";
const pageIntro = useCms ? "" : fallback.intro;
const sections = useCms
  ? cmsZdrelac.map((e) => ({
      title: (e.data.title as string) ?? "",
      text: (e.data.body as string) ?? "",
      image: (e.data.image as string) ?? "https://images.pexels.com/photos/18759978/pexels-photo-18759978.jpeg?auto=compress&w=800",
      alt: (e.data.title as string) ?? "",
    }))
  : fallback.sections;
---

<Page title={pageTitle} locale={typedLocale}>
  {/* Village hero with aerial image */}
  <section class="village-hero">
    <img src="https://images.pexels.com/photos/18759978/pexels-photo-18759978.jpeg?auto=compress&w=1920" alt={`${pageTitle} - Pašman`} width="1920" height="1080" fetchpriority="high" />
    <div class="village-hero__overlay">
      <div class="container">
        <h1>{pageTitle}</h1>
        {pageIntro && <p class="village-hero__intro">{pageIntro}</p>}
      </div>
    </div>
    <svg class="village-hero__wave" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
    </svg>
  </section>

  {sections.map((section, i) => (
    <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
      <div class="container">
        <div class:list={["village-row", { "village-row--reverse": i % 2 === 1 }]}>
          <div class="village-row__image">
            <img src={section.image} alt={section.alt} width="800" height="600" loading="lazy" />
          </div>
          <div class="village-row__content">
            <h2>{section.title}</h2>
            <p class="text-lead">{section.text}</p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="section" data-reveal>
    <div class="container text-center">
      <a href={`/${typedLocale}/apartmani`} class="btn btn--primary">
        {t(typedLocale, "apartments.viewApartments")}
      </a>
    </div>
  </section>
</Page>

<style>
  .village-hero {
    position: relative;
    height: 70vh;
    min-height: 400px;
    overflow: hidden;
  }
  .village-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: clamp(40px, 6vw, 80px);
    z-index: 3;
    display: block;
  }

  .village-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .village-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(transparent 30%, rgba(10, 31, 51, 0.8));
    padding-bottom: var(--space-3xl);
  }

  .village-hero__overlay h1 {
    color: var(--color-white);
    font-size: clamp(3rem, 7vw, 6rem);
  }

  .village-hero__intro {
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--font-size-lg);
    max-width: 600px;
    margin-top: var(--space-md);
    line-height: 1.7;
  }

  .village-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .village-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
    .village-row--reverse .village-row__image {
      order: 2;
    }
    .village-row--reverse .village-row__content {
      order: 1;
    }
  }

  .village-row__image {
    overflow: hidden;
    border-radius: 16px;
  }

  .village-row__image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .village-row:hover .village-row__image img {
    transform: scale(1.03);
  }

  .village-row__content h2 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    margin-bottom: var(--space-md);
  }
</style>
