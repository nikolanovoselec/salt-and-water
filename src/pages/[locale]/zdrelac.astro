---
import Page from "~/layouts/Page.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Try CMS first
const cmsEntries = await getLocalizedCollection("editorial", typedLocale);
const cmsZdrelac = cmsEntries
  .filter((e) => e.data.page_key === "zdrelac")
  .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0));

// No fallback - content comes from CMS only

// CMS content
const pageTitle = "Ždrelac";
const pageIntro = "";
const sections = cmsZdrelac.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
  alt: (e.data.title as string) ?? "",
}));
---

<Page title={pageTitle} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/photos/zdrelac-from-sea.jpg">
  {/* Village hero with aerial image */}
  <section class="village-hero">
    <img src="/photos/zdrelac-from-sea.jpg" alt={`${pageTitle} - Pašman`} width="1920" height="1080" fetchpriority="high" />
    <div class="village-hero__overlay">
      <div class="container">
        <h1>{pageTitle}</h1>
        {pageIntro && <p class="village-hero__intro">{pageIntro}</p>}
      </div>
    </div>
    <svg class="village-hero__wave" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
    </svg>
  </section>

  {sections.map((section, i) => (
    <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
      <div class="container">
        <div class:list={["village-row", { "village-row--reverse": i % 2 === 1 }]}>
          {section.image && (<div class="village-row__image">
            <img src={section.image} alt={section.alt} width="800" height="600" loading="lazy" />
          </div>)}
          <div class="village-row__content">
            <h2>{section.title}</h2>
            <p class="text-lead">{section.text}</p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="section" data-reveal>
    <div class="container text-center">
      <a href={`/${typedLocale}/apartmani`} class="btn btn--primary">
        {t(typedLocale, "apartments.viewApartments")}
      </a>
    </div>
  </section>
</Page>

<style>
  .village-hero {
    position: relative;
    height: 70vh;
    min-height: 400px;
    overflow: hidden;
  }
  .village-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: clamp(40px, 6vw, 80px);
    z-index: 3;
    display: block;
  }

  .village-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .village-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(transparent 30%, rgba(10, 31, 51, 0.8));
    padding-bottom: var(--space-3xl);
  }

  .village-hero__overlay h1 {
    color: var(--color-white);
    font-size: clamp(3rem, 7vw, 6rem);
  }

  .village-hero__intro {
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--font-size-lg);
    max-width: 600px;
    margin-top: var(--space-md);
    line-height: 1.7;
  }

  .village-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .village-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
    .village-row--reverse .village-row__image {
      order: 2;
    }
    .village-row--reverse .village-row__content {
      order: 1;
    }
  }

  .village-row__image {
    overflow: hidden;
    border-radius: 16px;
  }

  .village-row__image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .village-row:hover .village-row__image img {
    transform: scale(1.03);
  }

  .village-row__content h2 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    margin-bottom: var(--space-md);
  }
</style>
