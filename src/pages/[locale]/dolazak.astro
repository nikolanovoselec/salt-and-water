---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const cmsEntries = (await getLocalizedCollection("dolazak", typedLocale))
  .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0));

const sections = cmsEntries.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
  gallery: parsePhotoArray(e.data.gallery),
}));

const address = "Fratarsko 5, 23263 Ždrelac, Croatia";
const googleMapsUrl = "https://maps.app.goo.gl/bbDoqzZcWnUUeW7X8";
const appleMapsUrl = "https://maps.apple.com/?ll=44.010669,15.285480&q=Apartmani+Novoselec";
---

<Page title={t(typedLocale, "gettingHere.title")} locale={typedLocale} ogImage={`https://apartmani.novoselec.ch${sections[0]?.image || "/api/img/1203a417-fbf4-4065-bef9-233b75a4af44"}`}>
  <HeroSimple title={t(typedLocale, "gettingHere.title")} image={sections[0]?.image || "/api/img/1203a417-fbf4-4065-bef9-233b75a4af44"} />

  {sections.map((section, i) => {
    const photos = section.gallery.length > 0
      ? section.gallery
      : section.image ? [{ src: section.image, alt: section.title }] : [];
    return (
      <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
        <div class="container">
          <h2 class="editorial-title">{section.title}</h2>
        </div>
        <div class="container">
          <p class="editorial-text" set:html={section.text.replace(/<(?!\/?(a|br|em|strong)\b)[^>]+>/gi, '')} />
        </div>
        {photos.length > 0 && (
          <div class="editorial-strip">
            <MiniCollage images={photos} speed={Math.max(35, photos.length * 8)} reverse={i % 2 === 1} />
          </div>
        )}
      </section>
    );
  })}

  <section class="section section--dark section--wave-in section--footer-clear" data-reveal>
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="position: absolute; top: 0; left: 0; width: 100%; height: clamp(50px, 8vw, 100px); display: block; z-index: 2; transform: scaleY(-1);">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="var(--color-bg)" />
    </svg>
    <div class="container text-center">
      <h2 style="color: var(--color-white); margin-bottom: var(--space-sm);">{t(typedLocale, "gettingHere.ourAddress")}</h2>
      <p class="address-text">{address}</p>
      <div class="map-buttons">
        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">Google Maps</a>
        <a href={appleMapsUrl} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">Apple Maps</a>
      </div>
    </div>
  </section>
</Page>

<style>
  .address-text {
    font-family: var(--font-serif);
    font-size: var(--font-size-2xl);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-xl);
    max-width: none;
  }
  .map-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
