---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS
const pages = await getLocalizedCollection("editorial", typedLocale);
const page = pages.find((p) => p.data.page_key === "getting-here");

type TransportSection = { key: string; route?: string; duration?: string; operator?: string; tip?: string; title?: string; text?: string; distance?: string };
let sections: TransportSection[] = [];

if (page?.data.sections_json) {
  try {
    sections = JSON.parse(page.data.sections_json as string);
  } catch { /* fallback below */ }
}

// Fallback
const ferry = sections.find((s) => s.key === "ferry") ?? {
  route: "Biograd na Moru → Tkon",
  duration: { hr: "25 minuta", de: "25 Minuten", sl: "25 minut", en: "25 minutes" }[typedLocale],
  operator: "Jadrolinija",
  tip: { hr: "U srpnju i kolovozu dođite 45 minuta ranije ako vozite auto.", de: "Im Juli und August kommen Sie 45 Minuten früher, wenn Sie ein Auto mitnehmen.", sl: "Julija in avgusta pridite 45 minut prej, če pripeljete avto.", en: "In July and August, arrive 45 minutes early if bringing a car." }[typedLocale],
};

const altRoute = sections.find((s) => s.key === "alt-route") ?? {
  title: { hr: "Alternativna ruta preko Ugljana", de: "Alternative Route über Ugljan", sl: "Alternativna pot čez Ugljan", en: "Alternative route via Ugljan" }[typedLocale],
  text: { hr: "Budući da se apartmani nalaze u Ždrelacu, na samom mostu prema Ugljanu, možete koristiti i trajekt Zadar → Preko (Ugljan), a zatim prijeći most do Pašmana.", de: "Da sich die Ferienwohnungen in Ždrelac befinden, direkt an der Brücke nach Ugljan, können Sie auch die Fähre Zadar → Preko (Ugljan) nehmen und dann über die Brücke nach Pašman fahren.", sl: "Ker se apartmaji nahajajo v Ždrelacu, tik ob mostu proti Ugljanu, lahko uporabite tudi trajekt Zadar → Preko (Ugljan) in nato prečkate most do Pašmana.", en: "Since the apartments are in Ždrelac, right at the bridge to Ugljan, you can also take the ferry Zadar → Preko (Ugljan) and then cross the bridge to Pašman." }[typedLocale],
};

const airport = sections.find((s) => s.key === "airport") ?? {
  title: { hr: "Aerodrom Zadar (ZAD)", de: "Flughafen Zadar (ZAD)", sl: "Letališče Zadar (ZAD)", en: "Zadar Airport (ZAD)" }[typedLocale],
  distance: { hr: "~30 km do trajektne luke u Biogradu", de: "~30 km zum Fährhafen Biograd", sl: "~30 km do trajektnega pristanišča v Biogradu", en: "~30 km to Biograd ferry port" }[typedLocale],
  text: { hr: "Najbliži aerodrom. Vožnja do trajektne luke traje oko 30 minuta.", de: "Der nächstgelegene Flughafen. Die Fahrt zum Fährhafen dauert etwa 30 Minuten.", sl: "Najbližje letališče. Vožnja do trajektnega pristanišča traja približno 30 minut.", en: "The closest airport. The drive to the ferry port takes about 30 minutes." }[typedLocale],
};
---

<Page title={t(typedLocale, "gettingHere.title")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "gettingHere.title")} />

  {/* Ferry section */}
  <section class="section" data-reveal>
    <div class="container">
      <h2>{t(typedLocale, "gettingHere.ferry")}</h2>
      <div class="section-divider" style="margin: var(--space-lg) 0;"></div>
      <div class="info-card">
        <p class="info-card__route">{ferry.route}</p>
        <p class="info-card__detail">{ferry.duration} · {ferry.operator}</p>
        <p class="info-card__tip">{ferry.tip}</p>
        <a href="https://www.jadrolinija.hr" target="_blank" rel="noopener noreferrer" class="btn" style="margin-top: var(--space-lg);">
          Jadrolinija.hr
        </a>
      </div>
    </div>
  </section>

  {/* Alternative route */}
  <section class="section section--alt" data-reveal>
    <div class="container">
      <h2>{altRoute.title}</h2>
      <div class="section-divider" style="margin: var(--space-lg) 0;"></div>
      <p class="text-lead">{altRoute.text}</p>
    </div>
  </section>

  {/* Airport */}
  <section class="section" data-reveal>
    <div class="container">
      <h2>{airport.title}</h2>
      <div class="section-divider" style="margin: var(--space-lg) 0;"></div>
      <p class="info-card__detail">{airport.distance}</p>
      <p style="margin-top: var(--space-md);">{airport.text}</p>
    </div>
  </section>

  {/* Map links */}
  <section class="section section--alt" data-reveal>
    <div class="container text-center">
      <h3>{t(typedLocale, "gettingHere.viewOnMap")}</h3>
      <div style="display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; margin-top: var(--space-lg);">
        <a href="https://maps.google.com/?q=Ždrelac,+Pašman,+Croatia" target="_blank" rel="noopener noreferrer" class="btn">
          Google Maps
        </a>
        <a href="https://maps.apple.com/?q=Ždrelac,+Pašman,+Croatia" target="_blank" rel="noopener noreferrer" class="btn">
          Apple Maps
        </a>
      </div>
    </div>
  </section>

  {/* Transfer offer */}
  <section class="section" data-reveal>
    <div class="container text-center">
      <p class="transfer-text">{t(typedLocale, "gettingHere.transfer")}</p>
    </div>
  </section>
</Page>

<style>
  .info-card {
    margin-top: var(--space-lg);
  }

  .info-card__route {
    font-family: var(--font-serif);
    font-size: var(--font-size-2xl);
    color: var(--color-navy);
  }

  .info-card__detail {
    font-size: var(--font-size-lg);
    color: var(--color-text-light);
    margin-top: var(--space-sm);
  }

  .info-card__tip {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: var(--color-stone);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
  }

  .transfer-text {
    font-family: var(--font-serif);
    font-size: var(--font-size-2xl);
    color: var(--color-navy);
  }
</style>
