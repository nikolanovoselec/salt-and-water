---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS - individual editorial entries
const cmsEntries = (await getLocalizedCollection("editorial", typedLocale))
  .filter((e) => e.data.page_key === "dolazak")
  .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0));

const sections = cmsEntries.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
}));

const address = "Fratarsko 3, 23271 Ždrelac, Croatia";
const mapsLat = "44.0261";
const mapsLng = "15.2236";
---

<Page title={t(typedLocale, "gettingHere.title")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "gettingHere.title")} image="/photos/marina-harbor.jpg" />

  {/* Content sections from CMS */}
  {sections.map((section, i) => (
    <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
      <div class="container">
        <div class:list={["content-row", { "content-row--reverse": i % 2 === 1 }]}>
          {section.image && (
            <div class="content-row__image">
              <img src={section.image} alt={section.title} width="800" height="600" loading="lazy" />
            </div>
          )}
          <div class="content-row__text">
            <h2>{section.title}</h2>
            <p class="text-lead" set:html={section.text.replace(/<(?!\/?(a|br|em|strong)\b)[^>]+>/gi, '')} />
          </div>
        </div>
      </div>
    </section>
  ))}

  {/* Address + Maps */}
  <section class="section section--dark" data-reveal>
    <div class="container text-center">
      <h2 style="color: var(--color-white); margin-bottom: var(--space-sm);">{t(typedLocale, "gettingHere.ourAddress")}</h2>
      <p class="address-text">{address}</p>
      <div class="map-buttons">
        <a href={`https://www.google.com/maps/search/?api=1&query=${mapsLat},${mapsLng}`} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
          Google Maps
        </a>
        <a href={`https://maps.apple.com/?ll=${mapsLat},${mapsLng}&q=Apartmani+Novoselec`} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
          Apple Maps
        </a>
      </div>
    </div>
  </section>
</Page>

<style>
  .address-text {
    font-family: var(--font-serif);
    font-size: var(--font-size-2xl);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-xl);
  }

  .map-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn--ghost {
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: var(--color-white);
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--radius-md);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: all var(--duration-fast);
  }

  .btn--ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
  }
</style>
