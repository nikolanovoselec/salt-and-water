---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS
const pages = await getLocalizedCollection("editorial", typedLocale);
const page = pages.find((p) => p.data.page_key === "why-pasman");

// Parse sections from CMS or use fallback
let sections: Array<{ title: string; text: string }> = [];
if (page?.data.sections_json) {
  try {
    const raw = page.data.sections_json as string;
    sections = JSON.parse(raw);
  } catch { /* fallback below */ }
}

// No fallback - content from CMS only

const images = [
  "https://images.pexels.com/photos/3566139/pexels-photo-3566139.jpeg?auto=compress&w=800",
  "https://images.pexels.com/photos/2880507/pexels-photo-2880507.jpeg?auto=compress&w=800",
  "https://images.pexels.com/photos/3601425/pexels-photo-3601425.jpeg?auto=compress&w=800",
  "https://images.pexels.com/photos/2440061/pexels-photo-2440061.jpeg?auto=compress&w=800",
];
const imageAlts = [
  "Crystal-clear Adriatic waters near Pašman",
  "Traditional stone village on the Croatian coast",
  "Aerial view of Pašman island coastline",
  "Sunset over the Adriatic from Pašman",
];
---

<Page title={t(typedLocale, "nav.whyPasman")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "nav.whyPasman")} image="/photos/beach-zdrelac.jpg" />

  {sections.map((section, i) => (
    <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
      <div class="container">
        <div class:list={["content-row", { "content-row--reverse": i % 2 === 1 }]}>
          <div class="content-row__text">
            <h2>{section.title}</h2>
            <div class="section-divider" style="margin: var(--space-lg) 0;"></div>
            <p class="text-lead">{section.text}</p>
          </div>
          <div class="content-row__image">
            <img src={images[i % images.length]} alt={imageAlts[i % imageAlts.length]} width="800" height="533" loading="lazy" />
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="section" data-reveal>
    <div class="container text-center">
      <a href={`/${typedLocale}/apartmani`} class="btn btn--primary">
        {t(typedLocale, "nav.apartments")}
      </a>
    </div>
  </section>
</Page>

<style>
  .content-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .content-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
    .content-row--reverse .content-row__text {
      order: 2;
    }
    .content-row--reverse .content-row__image {
      order: 1;
    }
  }

  .content-row__image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }

  .content-row__text h2 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
  }
</style>
