---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const title: Record<Locale, string> = {
  hr: "Plaže", de: "Strände", sl: "Plaže", en: "Beaches",
};
const intro: Record<Locale, string> = {
  hr: "Ždrelac je stvoren za spontano kupanje: kratka šetnja, ručnik preko ramena i more koje mami u svako doba dana. A s autom ili brodom, otvaraju se deseci skrivenih uvala.",
  de: "Ždrelac ist wie gemacht für spontanes Baden: ein kurzer Spaziergang, das Handtuch über der Schulter und ein Meer, das zu jeder Tageszeit lockt.",
  sl: "Ždrelac je ustvarjen za spontano kopanje: kratek sprehod, brisača čez ramo in morje, ki vabi ob vsakem delu dneva.",
  en: "Ždrelac was made for spontaneous swimming: a short walk, towel over your shoulder, and a sea that beckons at any time of day.",
};

const cmsEntries = (await getLocalizedCollection("plaze", typedLocale))
  .sort((a, b) => (Number(a.data.sort_order) || 0) - (Number(b.data.sort_order) || 0));

const sections = cmsEntries.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
  gallery: parsePhotoArray(e.data.gallery),
}));
---

<Page title={title[typedLocale]} locale={typedLocale} ogImage={`https://apartmani.novoselec.ch${sections[0]?.image || "/api/img/953b4b07-6c3a-4df1-8358-63a2997e6d24"}`}>
  <HeroSimple title={title[typedLocale]} intro={intro[typedLocale]} image={sections[0]?.image || "/api/img/953b4b07-6c3a-4df1-8358-63a2997e6d24"} />

  {sections.map((section, i) => {
    const photos = section.gallery.length > 0
      ? section.gallery
      : section.image ? [{ src: section.image, alt: section.title }] : [];
    return (
      <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
        <div class="container">
          <h2 class="editorial-title">{section.title}</h2>
        </div>
        {photos.length > 0 && (
          <div class="editorial-strip">
            <MiniCollage images={photos} speed={35} />
          </div>
        )}
        <div class="container">
          <p class="editorial-text">{section.text}</p>
        </div>
      </section>
    );
  })}
</Page>
