---
import Page from "~/layouts/Page.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const cmsEntries = (await getLocalizedCollection("editorial", typedLocale))
  .filter((e) => e.data.page_key === "plaze")
  .sort((a, b) => (Number(a.data.sort_order) || 0) - (Number(b.data.sort_order) || 0));

const title: Record<Locale, string> = {
  hr: "Plaže", de: "Strände", sl: "Plaže", en: "Beaches",
};
const intro: Record<Locale, string> = {
  hr: "Ždrelac je stvoren za spontano kupanje: kratka šetnja, ručnik preko ramena i more koje mami u svako doba dana. A s autom ili brodom, otvaraju se deseci skrivenih uvala.",
  de: "Ždrelac ist wie gemacht für spontanes Baden: ein kurzer Spaziergang, das Handtuch über der Schulter und ein Meer, das zu jeder Tageszeit lockt.",
  sl: "Ždrelac je ustvarjen za spontano kopanje: kratek sprehod, brisača čez ramo in morje, ki vabi ob vsakem delu dneva.",
  en: "Ždrelac was made for spontaneous swimming: a short walk, towel over your shoulder, and a sea that beckons at any time of day.",
};

type Section = { title: string; text: string; image: string; alt: string };
const sections: Record<Locale, Section[]> = {
  hr: [
    { title: "Uvale u Ždrelacu (0-2 km)", text: "Uvala Mali Ždrelac mirnija je i pogodna za obitelji i jutarnje plivanje. Područje uz most atraktivno je za promatranje brodova i plivanje u bistrijem moru. Za najfotogeničnije kadrove dođite rano ujutro - more je stakleno, a svjetlo mekano.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Kristalno čisto more u Ždrelacu" },
    { title: "Plaže na sjevernom Pašmanu (5-15 km)", text: "Plaža Matlovac u Dobropoljani (5-7 km) jedna je od poznatijih na sjevernom Pašmanu. Plaža Soline u Tkonu (10-12 km) ima pješčanu/pliću zonu odličnu za djecu. Uvale između Dobropoljana i Neviđana (6-12 km) savršene su za mir i snorkeling.", image: "https://images.pexels.com/photos/1450353/pexels-photo-1450353.jpeg?auto=compress&w=800", alt: "Plaža na Pašmanu" },
    { title: "Plaže na Ugljanu (10-20 km)", text: "Plaža Jaz u Preku (12-14 km) omiljena je gradska plaža uz sadržaje i šetnicu. Kupališta u Kalima (10-12 km) kombiniraju kamen i šljunak uz ribarsko mjesto. Područje Muline (8-10 km) nudi mirnije uvale u blizini mjesta Ugljan.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Plaža na Ugljanu" },
    { title: "Skrivene uvale (brodom ili kajakom)", text: "Ako želite luksuzni osjećaj da ste sami na Mediteranu, idite s mora. Male uvale uz obalu Pašmana prema Neviđanima (10-30 min brodom) često su bez infrastrukture, s kristalno čistim morem. Uvale prema otočićima u Pašmanskom kanalu mirne su i zaštićene.", image: "https://images.pexels.com/photos/2440061/pexels-photo-2440061.jpeg?auto=compress&w=800", alt: "Skrivena uvala" },
    { title: "Savjeti za savršen dan na plaži", text: "Parking uz popularne plaže puni se do kasnog jutra - krenite ranije. Prirodan hlad borova dragocjen je ljeti. Maestral pojačava poslijepodne - ujutro je more najmirnije za SUP i fotografije. Ako je jedna strana otoka vjetrovita, prijeđite na zaklonjeniju stranu.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Borovi uz plažu" },
  ],
  de: [
    { title: "Buchten in Ždrelac (0-2 km)", text: "Die Bucht Mali Ždrelac ist ruhiger und familienfreundlich. Das Gebiet an der Brücke bietet klares Wasser und Bootsbeobachtung. Für die schönsten Fotos: früh morgens kommen.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Kristallklares Meer in Ždrelac" },
    { title: "Strände auf Nord-Pašman (5-15 km)", text: "Strand Matlovac in Dobropoljana (5-7 km). Strand Soline in Tkon (10-12 km) mit flachem Bereich für Kinder. Buchten zwischen Dobropoljana und Neviđane zum Schnorcheln.", image: "https://images.pexels.com/photos/1450353/pexels-photo-1450353.jpeg?auto=compress&w=800", alt: "Strand auf Pašman" },
    { title: "Strände auf Ugljan (10-20 km)", text: "Strand Jaz in Preko (12-14 km) mit Promenade. Steinstrände in Kali (10-12 km). Ruhigere Buchten bei Muline (8-10 km).", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Strand auf Ugljan" },
    { title: "Versteckte Buchten (Boot/Kajak)", text: "Kleine Buchten entlang der Pašman-Küste (10-30 Min. Boot) ohne Infrastruktur, mit kristallklarem Wasser.", image: "https://images.pexels.com/photos/2440061/pexels-photo-2440061.jpeg?auto=compress&w=800", alt: "Versteckte Bucht" },
    { title: "Tipps für den perfekten Strandtag", text: "Parkplätze füllen sich bis zum späten Vormittag. Natürlicher Pinienschatten ist wertvoll. Maestral verstärkt nachmittags - morgens ist das Meer am ruhigsten.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Pinien am Strand" },
  ],
  sl: [
    { title: "Zalivčki v Ždrelacu (0-2 km)", text: "Zaliv Mali Ždrelac je mirnejši in primeren za družine. Območje ob mostu ponuja čisto vodo. Za najlepše fotografije: zgodaj zjutraj.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Kristalno čisto morje v Ždrelacu" },
    { title: "Plaže na severnem Pašmanu (5-15 km)", text: "Plaža Matlovac v Dobropoljani (5-7 km). Plaža Soline v Tkonu (10-12 km) s plitvo cono za otroke. Zalivčki med Dobropoljano in Neviđanami za potapljanje.", image: "https://images.pexels.com/photos/1450353/pexels-photo-1450353.jpeg?auto=compress&w=800", alt: "Plaža na Pašmanu" },
    { title: "Plaže na Ugljanu (10-20 km)", text: "Plaža Jaz v Preku (12-14 km) s promenado. Kopališča v Kalih (10-12 km). Mirnejši zalivčki pri Mulinah (8-10 km).", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Plaža na Ugljanu" },
    { title: "Skrite zalivčke (čoln/kajak)", text: "Majhne zalivčke vzdolž obale Pašmana (10-30 min s čolnom) brez infrastrukture, s kristalno čistim morjem.", image: "https://images.pexels.com/photos/2440061/pexels-photo-2440061.jpeg?auto=compress&w=800", alt: "Skrita zalivčka" },
    { title: "Nasveti za popoln dan na plaži", text: "Parkirišča se polnijo do poznega dopoldneva. Naravna senca borov je dragocena. Maestral se okrepi popoldne - zjutraj je morje najmirnejše.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Bori ob plaži" },
  ],
  en: [
    { title: "Coves in Ždrelac (0-2 km)", text: "Mali Ždrelac bay is quieter and family-friendly. The bridge area offers clear water and boat watching. For the most photogenic shots, come early morning - the sea is glassy, the light soft.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Crystal-clear sea in Ždrelac" },
    { title: "Northern Pašman beaches (5-15 km)", text: "Matlovac beach in Dobropoljana (5-7 km) is one of the best known. Soline beach in Tkon (10-12 km) has a shallow sandy zone great for children. Coves between Dobropoljana and Neviđane are perfect for snorkeling.", image: "https://images.pexels.com/photos/1450353/pexels-photo-1450353.jpeg?auto=compress&w=800", alt: "Beach on Pašman" },
    { title: "Ugljan beaches (10-20 km)", text: "Jaz beach in Preko (12-14 km) is a popular town beach with a promenade. Kali swimming spots (10-12 km) combine stone and pebble. Muline area (8-10 km) offers quieter coves.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Beach on Ugljan" },
    { title: "Hidden coves (by boat or kayak)", text: "Small coves along Pašman's coast toward Neviđane (10-30 min by boat) with no infrastructure and crystal-clear water. Coves near islets in the Pašman Channel are calm and sheltered.", image: "https://images.pexels.com/photos/2440061/pexels-photo-2440061.jpeg?auto=compress&w=800", alt: "Hidden cove" },
    { title: "Tips for the perfect beach day", text: "Parking at popular beaches fills by late morning - arrive early. Natural pine shade is precious in summer. Maestral wind picks up in the afternoon - mornings are calmest for SUP and photos.", image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=800", alt: "Pine trees by the beach" },
  ],
};
const page = sections[typedLocale];
---

<Page title={title[typedLocale]} locale={typedLocale}>
  <section class="page-hero">
    <img src="https://images.pexels.com/photos/31934689/pexels-photo-31934689.jpeg?auto=compress&w=1920" alt={title[typedLocale]} width="1920" height="1080" fetchpriority="high" />
    <div class="page-hero__overlay">
      <div class="container">
        <h1>{title[typedLocale]}</h1>
        <p class="page-hero__intro">{intro[typedLocale]}</p>
      </div>
    </div>
    <svg class="page-hero__wave" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
    </svg>
  </section>

  {(cmsEntries.length > 0
    ? cmsEntries.map((e) => ({
        title: (e.data.title as string) ?? "",
        text: (e.data.body as string) ?? "",
        image: (e.data.image as string) ?? "",
        alt: (e.data.title as string) ?? "",
      }))
    : page
  ).map((section, i) => (
    <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
      <div class="container">
        <div class:list={["content-row", { "content-row--reverse": i % 2 === 1 }]}>
          <div class="content-row__image">
            <img src={section.image} alt={section.alt} width="800" height="600" loading="lazy" />
          </div>
          <div class="content-row__text">
            <h2>{section.title}</h2>
            <p class="text-lead">{section.text}</p>
          </div>
        </div>
      </div>
    </section>
  ))}
</Page>

<style is:global>
  .page-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }
  .page-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: clamp(40px, 6vw, 80px);
    z-index: 3;
    display: block;
  }
  .page-hero img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .page-hero__overlay {
    position: absolute; inset: 0;
    display: flex; align-items: flex-end;
    background: linear-gradient(transparent 30%, rgba(10,31,51,0.8));
    padding-bottom: var(--space-3xl);
  }
  .page-hero__overlay h1 {
    color: var(--color-white);
    font-size: clamp(2.5rem, 6vw, 5rem);
  }
  .page-hero__intro {
    color: rgba(255,255,255,0.8);
    font-size: var(--font-size-lg);
    max-width: 600px;
    margin-top: var(--space-md);
    line-height: 1.7;
  }
  .content-row {
    display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: center;
  }
  @media (min-width: 768px) {
    .content-row { grid-template-columns: 1fr 1fr; gap: var(--space-3xl); }
    .content-row--reverse .content-row__text { order: 1; }
    .content-row--reverse .content-row__image { order: 2; }
  }
  .content-row__image { overflow: hidden; border-radius: 20px 4px 20px 4px; box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 12px 40px rgba(10,31,51,0.08); }
  .content-row__image img {
    width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;
    transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .content-row:hover .content-row__image img { transform: scale(1.03); }
  .content-row__text h2 { font-size: clamp(1.5rem, 3vw, 2.5rem); margin-bottom: var(--space-md); }
</style>
