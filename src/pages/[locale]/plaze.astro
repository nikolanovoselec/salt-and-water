---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const title: Record<Locale, string> = {
  hr: "Plaže", de: "Strände", sl: "Plaže", en: "Beaches",
};
const intro: Record<Locale, string> = {
  hr: "Kod nas se na more ne ide bez velikog plana. Pašman i Ugljan nemaju onih razvikanih plaža iz turističkih magazina, i to je naša najveća sreća. Ovdje se ručnik prebaci preko ramena čim sunce ugrije — bilo da ste u Ždrelcu ili ste krenuli istraživati cestom uz more, uvijek ćete naići na neki prazan mol, ravnu stijenu ili šljunak skriven pod borovima.",
  de: "Bei uns geht man nicht mit einem grossen Plan ans Meer. Pašman und Ugljan haben nicht diese typischen Hochglanz-Strände aus den Reisemagazinen – und genau das ist unser grösstes Glück. Sobald die Sonne wärmt, wirft man sich einfach das Handtuch über die Schulter. Egal ob ihr in Ždrelac bleibt oder die Küstenstrasse entlangzieht: Irgendwo wartet immer ein leerer Steg, eine glatte Felsplatte oder ein kleiner Kieselstrand, versteckt unter den Pinien.",
  sl: "Pri nas se na morje ne hodi z velikim planom. Pašman in Ugljan nimata tistih znanih plaž z naslovnic turističnih revij – in to je naša največja sreča. Brisačo si vržete čez ramo takoj, ko sonce zares ogreje – pa naj ostanete v Ždrelcu ali pa se odpravite raziskovat po obalni cesti: vedno boste naleteli na prazen pomol, gladko skalo ali droben prod, skrit pod borovci.",
  en: "Here, heading to the sea doesn't require a grand plan. Pašman and Ugljan don't have those glossy beaches you see in travel magazines — and that is our greatest blessing. The moment the sun warms up, you just sling a towel over your shoulder. Whether you stay in Ždrelac or drive along the coast to explore, you will always come across an empty little pier, a smooth rock ledge, or a patch of pebbles tucked beneath the pines.",
};

const cmsEntries = (await getLocalizedCollection("plaze", typedLocale))
  .sort((a, b) => (Number(a.data.sort_order) || 0) - (Number(b.data.sort_order) || 0));

const sections = cmsEntries.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
  gallery: parsePhotoArray(e.data.gallery),
}));
---

<Page title={title[typedLocale]} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/4c9238fa-0890-44a6-8f35-1ff787a8a27b">
  <HeroSimple title={title[typedLocale]} intro={intro[typedLocale]} image="/api/img/4c9238fa-0890-44a6-8f35-1ff787a8a27b" />

  {sections.map((section, i) => {
    const photos = section.gallery.length > 0
      ? section.gallery
      : section.image ? [{ src: section.image, alt: section.title }] : [];
    return (
      <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
        <div class="container">
          <h2 class="editorial-title">{section.title}</h2>
        </div>
        <div class="container">
          <p class="editorial-text">{section.text}</p>
        </div>
        {photos.length > 0 && (
          <div class="editorial-strip">
            <MiniCollage images={photos} speed={Math.max(35, photos.length * 8)} />
          </div>
        )}
      </section>
    );
  })}
</Page>
