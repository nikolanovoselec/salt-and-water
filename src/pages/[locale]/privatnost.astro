---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const pages = await getLocalizedCollection("editorial", typedLocale);
const page = pages.find((p) => p.data.page_key === "privacy");

const fallback: Record<Locale, { title: string; body: string }> = {
  hr: { title: "Politika privatnosti", body: "Ova politika privatnosti opisuje kako prikupljamo, koristimo i štitimo vaše osobne podatke.\n\nVoditelj obrade podataka: Apartmani Novoselec, Ždrelac, Pašman, Hrvatska.\n\nPodaci koje prikupljamo: Ime, email, telefon i poruku putem obrasca za upit.\n\nPravna osnova: Članak 6(1)(b) GDPR - predugovorne mjere na zahtjev ispitanika.\n\nPohrana: Podaci se pohranjuju u Cloudflare D1 bazi podataka (EU regija).\n\nVaša prava: Imate pravo na pristup, ispravak i brisanje svojih podataka.\n\nNe prodajemo vaše podatke trećim stranama." },
  de: { title: "Datenschutzerklärung", body: "Diese Datenschutzerklärung beschreibt, wie wir Ihre personenbezogenen Daten erheben, verwenden und schützen.\n\nVerantwortlicher: Apartmani Novoselec, Ždrelac, Pašman, Kroatien.\n\nErhobene Daten: Name, E-Mail, Telefon und Nachricht über das Anfrageformular.\n\nRechtsgrundlage: Art. 6 Abs. 1 lit. b DSGVO - vorvertragliche Maßnahmen.\n\nSpeicherung: Daten werden in der Cloudflare D1-Datenbank (EU-Region) gespeichert.\n\nIhre Rechte: Sie haben das Recht auf Auskunft, Berichtigung und Löschung Ihrer Daten.\n\nWir verkaufen Ihre Daten nicht an Dritte." },
  sl: { title: "Politika zasebnosti", body: "Ta politika zasebnosti opisuje, kako zbiramo, uporabljamo in ščitimo vaše osebne podatke.\n\nUpravljavec podatkov: Apartmani Novoselec, Ždrelac, Pašman, Hrvaška.\n\nPodatki, ki jih zbiramo: Ime, e-pošta, telefon in sporočilo prek obrazca za povpraševanje.\n\nPravna podlaga: Člen 6(1)(b) GDPR - predpogodbeni ukrepi.\n\nShranjevanje: Podatki se shranjujejo v bazi podatkov Cloudflare D1 (regija EU).\n\nVaše pravice: Imate pravico do dostopa, popravka in izbrisa svojih podatkov.\n\nVaših podatkov ne prodajamo tretjim osebam." },
  en: { title: "Privacy Policy", body: "This privacy policy describes how we collect, use, and protect your personal data.\n\nData controller: Apartmani Novoselec, Ždrelac, Pašman, Croatia.\n\nData we collect: Name, email, phone, and message via the inquiry form.\n\nLegal basis: Article 6(1)(b) GDPR - pre-contractual measures.\n\nStorage: Data is stored in a Cloudflare D1 database (EU region).\n\nYour rights: You have the right to access, rectify, and erase your data.\n\nWe do not sell your data to third parties." },
};

const title = (page?.data.title as string) ?? fallback[typedLocale].title;
const body = (page?.data.body as string) ?? fallback[typedLocale].body;
---

<Page title={title} locale={typedLocale}>
  <HeroSimple title={title} image="https://images.pexels.com/photos/15564185/pexels-photo-15564185.jpeg?auto=compress&w=1920" />

  <section class="section">
    <div class="container legal-content">
      {body.split("\n\n").map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </section>
</Page>

<style>
  .legal-content {
    max-width: 700px;
    margin-inline: auto;
  }

  .legal-content p {
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }
</style>
