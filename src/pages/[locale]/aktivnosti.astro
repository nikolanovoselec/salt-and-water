---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const title: Record<Locale, string> = {
  hr: "Priroda i aktivnosti", de: "Natur & Aktivitäten", sl: "Narava in aktivnosti", en: "Nature & Activities",
};
const intro: Record<Locale, string> = {
  hr: "Pašman i Ugljan nisu otoci dramatičnih visina ni ekstremnih sportova. Ovdje se priroda ne osvaja — prihvaća. Staze vas vode kroz maslinike i borovu šumu, more vas poziva na kajak ili SUP, a najbolji plan je onaj koji se napravi usput.",
  de: "Pašman und Ugljan sind keine Inseln der grossen Höhen oder der Extremsportarten. Hier erobert man die Natur nicht – man nimmt sie an. Wege führen euch durch Olivenhaine und Pinienwald, das Meer ruft nach Kajak oder SUP, und der beste Plan ist der, der unterwegs entsteht.",
  sl: "Pašman in Ugljan nista otoka visokih vrhov in ekstremnih športov. Pri nas se narave ne osvaja – sprejme se jo. Poti te vodijo skozi oljčnike in borov gozd, morje te kliče na kajak ali SUP, najboljši plan pa je tisti, ki nastane sproti.",
  en: "Pašman and Ugljan aren't islands of dramatic peaks or extreme sports. Here, nature isn't something you conquer — it's something you accept. Paths lead you through olive groves and pine woods, the sea invites you out on a kayak or SUP, and the best plan is the one you make along the way.",
};

const cmsEntries = (await getLocalizedCollection("aktivnosti", typedLocale))
  .sort((a, b) => (Number(a.data.sort_order) || 0) - (Number(b.data.sort_order) || 0));

const sections = cmsEntries.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
  gallery: parsePhotoArray(e.data.gallery),
}));
---

<Page title={title[typedLocale]} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/0afa5c7a-6108-454d-b309-80eccc3b8f6b">
  <HeroSimple title={title[typedLocale]} intro={intro[typedLocale]} image="/api/img/0afa5c7a-6108-454d-b309-80eccc3b8f6b" />

  {sections.map((section, i) => {
    const photos = section.gallery.length > 0
      ? section.gallery
      : section.image ? [{ src: section.image, alt: section.title }] : [];
    return (
      <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
        <div class="container">
          <h2 class="editorial-title">{section.title}</h2>
        </div>
        <div class="container">
          <p class="editorial-text">{section.text}</p>
        </div>
        {photos.length > 0 && (
          <div class="editorial-strip">
            <MiniCollage images={photos} speed={Math.max(35, photos.length * 8)} />
          </div>
        )}
      </section>
    );
  })}
</Page>
