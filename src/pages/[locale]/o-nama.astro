---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const pages = await getLocalizedCollection("editorial", typedLocale);
const page = pages.find((p) => p.data.page_key === "about");

// No fallback - content from CMS only
const story = (page?.data.body as string) ?? "";
---

<Page title={t(typedLocale, "hosts.title")} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/4181b561-2828-4119-b04e-9fc596d65569">
  <HeroSimple title={t(typedLocale, "hosts.title")} image="/api/img/4181b561-2828-4119-b04e-9fc596d65569" />

  <section class="section" data-reveal>
    <div class="container">
      <div class="about-layout">
        <div class="about-image" style="display: flex; justify-content: center;">
          <div style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; box-shadow: 0 8px 30px rgba(10,31,51,0.15); border: 4px solid var(--color-white);">
            <img src="/api/img/def88273-db56-4aa2-a30e-cae9ce95f86e" alt="Obitelj Novoselec" width="600" height="600" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
        </div>
        <div class="about-content">
          <p class="about-story">{story}</p>
        </div>
      </div>
    </div>
  </section>

</Page>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
    max-width: 960px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .about-layout {
      grid-template-columns: 1fr 1.3fr;
      gap: var(--space-3xl);
    }
  }

  .about-image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }

  .about-story {
    font-size: var(--font-size-lg);
    line-height: 1.8;
    color: var(--color-text);
  }

  .about-response {
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-stone);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    color: var(--color-olive);
    font-weight: 500;
    display: inline-block;
  }
</style>
