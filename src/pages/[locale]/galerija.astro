// Shuffle photos deterministically by locale (different order per language)
const seed = typedLocale.charCodeAt(0);
const shuffled = [...allPhotos].sort((a, b) => {
  const ha = (parseInt(a.slice(0, 8), 16) ^ seed) >>> 0;
  const hb = (parseInt(b.slice(0, 8), 16) ^ seed) >>> 0;
  return ha - hb;
});

// Build gallery items — images are decorative in auto-scrolling context
// Poetic captions used as alt text are visual atmosphere, not descriptive
const galleryItems = shuffled.map((uuid, i) => ({
  src: `/api/img/${uuid}`,
  alt: captions[i % captions.length],
}));

// Split into strips of 10
const strips: Array<{ images: typeof galleryItems; reverse: boolean }> = [];
for (let i = 0; i < galleryItems.length; i += 10) {
  strips.push({
    images: galleryItems.slice(i, i + 10),
    reverse: strips.length % 2 === 1,
  });
}
---

<Page title={galleryTitle[typedLocale]} locale={typedLocale}>
  <HeroSimple title={galleryTitle[typedLocale]} intro={intro[typedLocale]} image="/api/img/bd440b3f-7f65-4971-bfba-639458c5b9ec" />

  <div class="gallery-collages">
    {strips.map((strip) => (
      <div class="gallery-strip">
        <MiniCollage images={strip.images} speed={80} reverse={strip.reverse} showCaptions />
      </div>
    ))}
  </div>
</Page>

<style>
  .gallery-collages {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .gallery-strip {
    margin-bottom: var(--space-sm);
  }

  .gallery-strip:last-child {
    margin-bottom: 0;
  }
</style>
