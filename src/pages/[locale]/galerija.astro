---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const galleryTitle: Record<Locale, string> = {
  hr: "Galerija", de: "Galerie", sl: "Galerija", en: "Gallery",
};

type GalleryItem = { src: string; alt: string; caption: string };

const t4 = (hr: string, de: string, sl: string, en: string) =>
  ({ hr, de, sl, en }[typedLocale] ?? en);

const images: GalleryItem[] = [
  { src: "/api/img/aa0fd53c-5d96-4a78-a5b5-0f68b543515a", alt: t4("Ždrelac s mora", "Ždrelac vom Meer", "Ždrelac z morja", "Ždrelac from the sea"), caption: t4("Selo i most s mora", "Dorf und Brücke vom Meer", "Vas in most z morja", "Village and bridge from the sea") },
  { src: "/api/img/4a3ad312-31d5-4867-8655-1eebc6be3710", alt: t4("Tirkizni zaljev", "Türkise Bucht", "Turkizen zaliv", "Turquoise bay"), caption: t4("Jedrilice u tirkiznom zaljevu", "Segelboote in türkiser Bucht", "Jadrnice v turkiznem zalivu", "Sailboats in turquoise bay") },
  { src: "/api/img/64d936cd-d83b-4ebd-8afb-efd5a623a5c3", alt: t4("Zalazak sunca", "Sonnenuntergang", "Sončni zahod", "Sunset"), caption: t4("Dramatičan zalazak nad Jadranom", "Dramatischer Sonnenuntergang", "Dramatičen sončni zahod", "Dramatic sunset over the Adriatic") },
  { src: "/api/img/186752ec-1497-4926-b5c7-1c9b5d4ac207", alt: t4("Pješčana plaža", "Sandstrand", "Peščena plaža", "Sandy beach"), caption: t4("Kristalno čisto more i pijesak", "Kristallklares Meer und Sand", "Kristalno čisto morje in pesek", "Crystal clear sea and sand") },
  { src: "/api/img/73178b98-d2e6-4e49-b738-a9f9ecff2bc3", alt: t4("Obiteljska plaža", "Familienstrand", "Družinska plaža", "Family beach"), caption: t4("Plitka voda savršena za djecu", "Flaches Wasser perfekt für Kinder", "Plitva voda popolna za otroke", "Shallow water perfect for children") },
  { src: "/api/img/98611c2d-5fbe-4ab6-87c0-43cc6c17bd73", alt: t4("Panorama s vrha", "Panorama vom Gipfel", "Panorama z vrha", "Hilltop panorama"), caption: t4("Pogled na otoke s vidikovca", "Inselblick vom Aussichtspunkt", "Pogled na otoke z razgledišča", "Island view from the viewpoint") },
  { src: "/api/img/ccc96ad1-ec57-484e-b32e-18f4104dbbae", alt: t4("Tvrđava sv. Mihovila", "Festung St. Michael", "Trdnjava sv. Mihaela", "St. Michael's Fortress"), caption: t4("Ruševine i pogled na Zadar", "Ruinen und Blick auf Zadar", "Ruševine in pogled na Zadar", "Ruins and Zadar view") },
  { src: "/api/img/2f348da2-de88-4bb0-8f54-d517545b6cff", alt: t4("Luka Ždrelac", "Hafen Ždrelac", "Pristanišče Ždrelac", "Ždrelac harbour"), caption: t4("Tirkizno more u luci", "Türkises Meer im Hafen", "Turkizno morje v pristanišču", "Turquoise harbour water") },
  { src: "/api/img/0df6dd12-bd04-42c7-aaec-811b75bd7ae4", alt: t4("Skrivena uvala", "Versteckte Bucht", "Skrita zalivčka", "Secluded cove"), caption: t4("Mir Mediterana", "Stille des Mittelmeers", "Mir Sredozemlja", "Mediterranean solitude") },
  { src: "/api/img/c9c4485b-df86-4179-8d49-6cbbfbe0948c", alt: t4("Zvonik", "Glockenturm", "Zvonik", "Bell tower"), caption: t4("Crkva sv. Luke u Ždrelcu", "Kirche St. Lukas in Ždrelac", "Cerkev sv. Luka v Ždrelcu", "Church of St. Luke in Ždrelac") },
  { src: "/api/img/4181b561-2828-4119-b04e-9fc596d65569", alt: t4("Borovi na zalasku", "Pinien bei Sonnenuntergang", "Bori ob sončnem zahodu", "Pines at sunset"), caption: t4("Zlatno svjetlo kroz borove", "Goldenes Licht durch die Pinien", "Zlata svetloba med bori", "Golden light through the pines") },
  { src: "/api/img/dd602881-521e-437a-a666-c9433bbc29a5", alt: t4("Djeca na plaži", "Kinder am Strand", "Otroci na plaži", "Kids at the beach"), caption: t4("Ljetne radosti", "Sommerfreuden", "Poletne radosti", "Summer joys") },
];
---

<Page title={galleryTitle[typedLocale]} locale={typedLocale}>
  <HeroSimple title={galleryTitle[typedLocale]} image="/api/img/216f0b04-b41f-491d-8921-bb5621c347fc" />

  <section class="section">
    <div class="container">
      <div class="gallery-grid" data-reveal-stagger>
        {images.map((img) => (
          <figure class="gallery-item" data-reveal>
            <div class="gallery-item__image">
              <img src={img.src} alt={img.alt} width="800" height="600" loading="lazy" />
            </div>
            {img.caption && <figcaption class="gallery-item__caption">{img.caption}</figcaption>}
          </figure>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-white);
    box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 4px 16px rgba(10,31,51,0.06);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 20px 60px rgba(10,31,51,0.12);
  }

  .gallery-item__image {
    overflow: hidden;
  }

  .gallery-item__image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover .gallery-item__image img {
    transform: scale(1.05);
  }

  .gallery-item__caption {
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-align: center;
  }

</style>
