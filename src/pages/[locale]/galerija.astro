---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const galleryTitle: Record<Locale, string> = {
  hr: "Galerija", de: "Galerie", sl: "Galerija", en: "Gallery",
};

type GalleryItem = { src: string; alt: string; caption: string };

const t4 = (hr: string, de: string, sl: string, en: string) =>
  ({ hr, de, sl, en }[typedLocale] ?? en);

const images: GalleryItem[] = [
  // Island scenery
  { src: "/api/img/8dfecf5d-4e47-4b26-bcf3-c7238d9cb2d9", alt: t4("Luka Ždrelac", "Hafen Ždrelac", "Pristanišče Ždrelac", "Ždrelac harbour"), caption: t4("Tirkizno more i brodovi u luci", "Türkises Meer und Boote im Hafen", "Turkizno morje in čolni v pristanišču", "Turquoise water and boats in the harbour") },
  { src: "/api/img/8fa232be-df70-418c-9933-0960203d6bba", alt: t4("Tirkizni zaljev", "Türkise Bucht", "Turkizen zaliv", "Turquoise bay"), caption: t4("Jedrilice u tirkiznom zaljevu", "Segelboote in türkiser Bucht", "Jadrnice v turkiznem zalivu", "Sailboats in turquoise bay") },
  { src: "/api/img/5242d047-a955-4cd7-afe7-79191db2202b", alt: t4("Zalazak sunca", "Sonnenuntergang", "Sončni zahod", "Sunset"), caption: t4("Dramatičan zalazak nad Jadranom", "Dramatischer Sonnenuntergang", "Dramatičen sončni zahod", "Dramatic sunset over the Adriatic") },
  { src: "/api/img/ceec62e2-e1a1-42db-914b-64807c4751f7", alt: t4("Kristalno more", "Kristallklares Meer", "Kristalno morje", "Crystal clear sea"), caption: t4("Prozirno more i otoci", "Durchsichtiges Meer und Inseln", "Prozorno morje in otoki", "Transparent sea and islands") },
  // Beaches
  { src: "/api/img/953b4b07-6c3a-4df1-8358-63a2997e6d24", alt: t4("Pješčana plaža", "Sandstrand", "Peščena plaža", "Sandy beach"), caption: t4("Kristalno čisto more i pijesak", "Kristallklares Meer und Sand", "Kristalno čisto morje in pesek", "Crystal clear sea and sand") },
  { src: "/api/img/029648ae-b7af-4bd4-831a-4ceba2b9c4d7", alt: t4("Obiteljska plaža", "Familienstrand", "Družinska plaža", "Family beach"), caption: t4("Plitka voda savršena za djecu", "Flaches Wasser perfekt für Kinder", "Plitva voda popolna za otroke", "Shallow water perfect for children") },
  { src: "/api/img/0df6dd12-bd04-42c7-aaec-811b75bd7ae4", alt: t4("Skrivena uvala", "Versteckte Bucht", "Skrita zalivčka", "Secluded cove"), caption: t4("Staza do skrivene uvale", "Pfad zur versteckten Bucht", "Pot do skrite zalivčke", "Path to a secluded cove") },
  { src: "/api/img/aafdb60d-c80b-41f6-a3ad-353c50622e22", alt: t4("Vrata na plažu", "Tor zum Strand", "Vrata na plažo", "Door to the beach"), caption: t4("Korak do mora", "Ein Schritt zum Meer", "Korak do morja", "One step to the sea") },
  // Monuments & landmarks
  { src: "/api/img/c9c4485b-df86-4179-8d49-6cbbfbe0948c", alt: t4("Zvonik", "Glockenturm", "Zvonik", "Bell tower"), caption: t4("Crkva sv. Luke u Ždrelcu", "Kirche St. Lukas in Ždrelac", "Cerkev sv. Luka v Ždrelcu", "Church of St. Luke in Ždrelac") },
  { src: "/api/img/c047fffd-b9b7-4a05-84f9-7df061389901", alt: t4("Kapelica u boricima", "Kapelle in den Pinien", "Kapelica med bori", "Chapel among pines"), caption: t4("Stara kapela u borovoj šumi", "Alte Kapelle im Pinienwald", "Stara kapela v borovem gozdu", "Old chapel in the pine forest") },
  { src: "/api/img/b57f32b0-5684-47fb-8358-4ab3637f251f", alt: t4("Kameni lukovi", "Steinbögen", "Kamniti loki", "Stone arches"), caption: t4("Vidikovac s pogledom na more", "Aussichtspunkt mit Meerblick", "Razgledna točka z razgledom na morje", "Viewpoint overlooking the sea") },
  { src: "/api/img/90ffbceb-9d1a-4b1d-9938-18f134f6774e", alt: t4("Tvrđava i zaljev", "Festung und Bucht", "Trdnjava in zaliv", "Fortress and bay"), caption: t4("Ruševine i pogled na Zadar", "Ruinen und Blick auf Zadar", "Ruševine in pogled na Zadar", "Ruins and Zadar view") },
  // Panoramas & hiking
  { src: "/api/img/6bc0414c-fcd2-46d9-a737-ad755e39661b", alt: t4("Panorama s vrha", "Panorama vom Gipfel", "Panorama z vrha", "Hilltop panorama"), caption: t4("Pogled na otočje s vidikovca", "Inselblick vom Aussichtspunkt", "Pogled na otočje z razgledišča", "Archipelago view from the viewpoint") },
  { src: "/api/img/7186c488-dfb3-4220-91a3-c66698c98e40", alt: t4("Planinarska staza", "Wanderweg", "Pohodniška pot", "Hiking trail"), caption: t4("Staze po kamenim vrhovima", "Wege über steinige Gipfel", "Poti čez kamnite vrhove", "Trails over rocky peaks") },
  { src: "/api/img/98611c2d-5fbe-4ab6-87c0-43cc6c17bd73", alt: t4("Panorama otoka", "Inselpanorama", "Panorama otoka", "Island panorama"), caption: t4("Pogled na otoke i Zadar", "Blick auf die Inseln und Zadar", "Pogled na otoke in Zadar", "View of islands and Zadar") },
  // Golden hour & atmosphere
  { src: "/api/img/d8d7081e-1a5f-4c7a-ae8d-294b78e6f209", alt: t4("Obala na zalasku", "Küste bei Sonnenuntergang", "Obala ob sončnem zahodu", "Coast at sunset"), caption: t4("Zlatno svjetlo na obali", "Goldenes Licht an der Küste", "Zlata svetloba na obali", "Golden light on the coast") },
  { src: "/api/img/dd602881-521e-437a-a666-c9433bbc29a5", alt: t4("Djeca na plaži", "Kinder am Strand", "Otroci na plaži", "Kids at the beach"), caption: t4("Ljetne radosti", "Sommerfreuden", "Poletne radosti", "Summer joys") },
  { src: "/api/img/37815428-68df-4fe1-9dbc-afbd57f9e735", alt: t4("Marina", "Jachthafen", "Marina", "Marina"), caption: t4("Jedrilice u marini", "Segelboote im Hafen", "Jadrnice v marini", "Sailboats in the marina") },
];
---

<Page title={galleryTitle[typedLocale]} locale={typedLocale}>
  <HeroSimple title={galleryTitle[typedLocale]} image="/api/img/bd440b3f-7f65-4971-bfba-639458c5b9ec" />

  <section class="section">
    <div class="container">
      <div class="gallery-grid" data-reveal-stagger>
        {images.map((img) => (
          <figure class="gallery-item" data-reveal>
            <div class="gallery-item__image">
              <img src={img.src} alt={img.alt} width="800" height="600" loading="lazy" />
            </div>
            {img.caption && <figcaption class="gallery-item__caption">{img.caption}</figcaption>}
          </figure>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-white);
    box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 4px 16px rgba(10,31,51,0.06);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 0 1px rgba(10,31,51,0.06), 0 20px 60px rgba(10,31,51,0.12);
  }

  .gallery-item__image {
    overflow: hidden;
  }

  .gallery-item__image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover .gallery-item__image img {
    transform: scale(1.05);
  }

  .gallery-item__caption {
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-align: center;
  }

</style>
