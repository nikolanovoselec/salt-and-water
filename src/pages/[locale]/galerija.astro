---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const galleryTitle: Record<Locale, string> = {
  hr: "Galerija", de: "Galerie", sl: "Galerija", en: "Gallery",
};

const intro: Record<Locale, string> = {
  hr: "Sve boje otoka na jednom mjestu — more, kameni zidovi, konobe, borovi i onaj mir koji se ne da opisati, samo osjetiti.",
  de: "Alle Farben der Inseln an einem Ort — das Meer, die Steinmauern, die Konobas, die Pinien und jene Ruhe, die sich nicht beschreiben, nur fühlen lässt.",
  sl: "Vse barve otokov na enem mestu — morje, kamniti zidovi, konobe, borovci in tisti mir, ki ga ni mogoče opisati, samo občutiti.",
  en: "All the colours of the islands in one place — the sea, the stone walls, the konobas, the pines, and that peace which cannot be described, only felt.",
};

// Poetic captions — randomly assigned to photos
const captions = [
  "More ovdje šapće sporije nego igdje",
