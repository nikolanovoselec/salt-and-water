---
import Page from "~/layouts/Page.astro";
import Hero from "~/components/home/Hero.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

const { locale } = Astro.params;

if (!locale || !isValidLocale(locale)) {
  return Astro.redirect("/hr/", 302);
}

const typedLocale = locale as Locale;

const titles: Record<Locale, string> = {
  hr: "Apartmani Ždrelac — Otok Pašman",
  de: "Ferienwohnungen Ždrelac — Insel Pašman",
  sl: "Apartmaji Ždrelac — Otok Pašman",
  en: "Apartments Ždrelac — Pašman Island",
};
---

<Page
  title={titles[typedLocale]}
  locale={typedLocale}
  hasHero={true}
>
  <Hero locale={typedLocale} />

  {/* Why Pašman section */}
  <section class="section" data-reveal>
    <div class="container text-center">
      <h2>{t(typedLocale, "nav.whyPasman")}</h2>
      <div class="section-divider"></div>
      <p style="margin-inline: auto; margin-top: var(--space-lg);">
        {typedLocale === "hr" && "Kristalno čisto more, mir otoka i autentična Dalmacija — samo 25 minuta trajektom od kopna."}
        {typedLocale === "de" && "Kristallklares Meer, die Ruhe einer Insel und authentisches Dalmatien — nur 25 Minuten mit der Fähre vom Festland."}
        {typedLocale === "sl" && "Kristalno čisto morje, mir otoka in pristna Dalmacija — le 25 minut s trajektom od kopna."}
        {typedLocale === "en" && "Crystal-clear sea, island tranquility, and authentic Dalmatia — just 25 minutes by ferry from the mainland."}
      </p>
    </div>
  </section>

  {/* Apartments preview */}
  <section class="section" style="background: var(--color-bg-alt);" data-reveal>
    <div class="container text-center">
      <h2>{t(typedLocale, "apartments.title")}</h2>
      <div class="section-divider"></div>
      <p style="margin-inline: auto; margin-top: var(--space-lg);">
        {t(typedLocale, "apartments.comingSoon")}
      </p>
      <a href={`/${typedLocale}/apartmani`} class="btn" style="margin-top: var(--space-xl);">
        {t(typedLocale, "nav.apartments")}
      </a>
    </div>
  </section>

  {/* Contact / inquiry CTA */}
  <section class="section" id="inquiry" data-reveal>
    <div class="container text-center">
      <h2>{t(typedLocale, "booking.title")}</h2>
      <div class="section-divider"></div>
      <p style="margin-inline: auto; margin-top: var(--space-lg);">
        {t(typedLocale, "trust.responseTime")}
      </p>
    </div>
  </section>
</Page>
