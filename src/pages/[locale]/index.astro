---
import Page from "~/layouts/Page.astro";
import Hero from "~/components/home/Hero.astro";
import ScrollCollage from "~/components/home/ScrollCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection, type LocalizedEntry } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const titles: Record<Locale, string> = {
  hr: "Apartmani Novoselec - Otok Pašman",
  de: "Ferienwohnungen Ždrelac - Insel Pašman",
  sl: "Apartmaji Ždrelac - Otok Pašman",
  en: "Apartments Ždrelac - Pašman Island",
};

// Load CMS content
const allEditorial = await getLocalizedCollection("editorial", typedLocale);
const homepageSections = allEditorial.filter((e) => e.data.page_key === "homepage");
const testimonials = await getLocalizedCollection("testimonials", typedLocale);

function getSection(key: string): LocalizedEntry | undefined {
  return homepageSections.find((e) => e.data.section_key === key);
}

const whySection = getSection("why-pasman");
const zdrelacSection = getSection("zdrelac");
const aptsSection = getSection("apartments");
const ctaSection = getSection("cta");
const collageSection = getSection("collage");

// Parse collage photos from CMS (JSON array in body field)
let collagePhotos: Array<{ src: string; alt: string }> = [];
if (collageSection?.data.body) {
  try {
    const raw = JSON.parse(collageSection.data.body as string);
    if (Array.isArray(raw)) {
      collagePhotos = raw.filter(
        (item: unknown) =>
          typeof item === "object" && item !== null &&
          typeof (item as Record<string, unknown>).src === "string" &&
          typeof (item as Record<string, unknown>).alt === "string"
      );
    }
  } catch { /* empty collage if JSON invalid */ }
}

// Fallback content when CMS not yet seeded
const whyTitle = (whySection?.data.title as string) ?? {
  hr: "Otok koji je vrijeme zaboravilo",
  de: "Die Insel, die die Zeit vergessen hat",
  sl: "Otok, ki ga je čas pozabil",
  en: "The island time forgot",
}[typedLocale];

const whySubtitle = (whySection?.data.subtitle as string) ?? t(typedLocale, "nav.whyPasman");

const whyBody = (whySection?.data.body as string) ?? {
  hr: "Daleko od gužvi, Pašman nudi ono što je Dalmacija nekada bila - kamene kuće, maslinovi nasadi, konobe s domaćom hranom i more koje oduzima dah. Samo 25 minuta trajektom od kopna, a opet dovoljno daleko da se osjetite kao na pravom odmoru.",
  de: "Fernab vom Trubel bietet Pašman das, was Dalmatien einst war - Steinhäuser, Olivenhaine, Konobas mit hausgemachtem Essen und ein atemberaubendes Meer. Nur 25 Minuten mit der Fähre vom Festland, aber weit genug für einen echten Urlaub.",
  sl: "Daleč od gneče Pašman ponuja tisto, kar je bila nekoč Dalmacija - kamnite hiše, oljčni nasadi, konobe z domačo hrano in morje, ki jemlje dih. Le 25 minut s trajektom od kopna, a vseeno dovolj daleč za pravi dopust.",
  en: "Far from the crowds, Pašman offers what Dalmatia once was - stone houses, olive groves, konobas with homemade food, and a sea that takes your breath away. Just 25 minutes by ferry from the mainland, yet far enough to feel like a real escape.",
}[typedLocale];

const whyItems = [
  { hr: "Kristalno čisto more", de: "Kristallklares Meer", sl: "Kristalno čisto morje", en: "Crystal-clear sea" },
  { hr: "Mir otoka", de: "Inselruhe", sl: "Mir otoka", en: "Island tranquility" },
  { hr: "25 min trajektom", de: "25 Min. Fähre", sl: "25 min s trajektom", en: "25 min by ferry" },
  { hr: "Autentična Dalmacija", de: "Authentisches Dalmatien", sl: "Pristna Dalmacija", en: "Authentic Dalmatia" },
];

const zdrelacTitle = (zdrelacSection?.data.title as string) ?? {
  hr: "Tiho selo na sjevernom vrhu otoka",
  de: "Ein ruhiges Dorf an der Nordspitze der Insel",
  sl: "Tiha vas na severnem vrhu otoka",
  en: "A quiet village at the northern tip of the island",
}[typedLocale];

const aptsTitle = (aptsSection?.data.title as string) ?? {
  hr: "Vaš dom na Jadranu",
  de: "Ihr Zuhause an der Adria",
  sl: "Vaš dom na Jadranu",
  en: "Your home on the Adriatic",
}[typedLocale];

const aptsBody = (aptsSection?.data.body as string) ?? {
  hr: "Udobni apartmani s pogledom na more, kamenom terasom za jutarnju kavu i svim što trebate za savršen odmor.",
  de: "Komfortable Ferienwohnungen mit Meerblick, Steinterrasse für den Morgenkaffee und allem, was Sie für einen perfekten Urlaub brauchen.",
  sl: "Udobni apartmaji s pogledom na morje, kamnito teraso za jutranjo kavo in vsem, kar potrebujete za popoln dopust.",
  en: "Comfortable apartments with sea views, a stone terrace for morning coffee, and everything you need for a perfect holiday.",
}[typedLocale];

const ctaTitle = (ctaSection?.data.title as string) ?? t(typedLocale, "homepage.cta.title");

// Olive oil label
const oliveOilLabel: Record<Locale, string> = {
  hr: "Maslinovo ulje", de: "Olivenöl", sl: "Oljčno olje", en: "Olive oil",
};
---

<Page title={titles[typedLocale]} locale={typedLocale} hasHero={true}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "Apartmani Novoselec",
    "description": titles[typedLocale],
    "url": `https://apartmani.novoselec.ch/${typedLocale}/`,
    "image": "https://apartmani.novoselec.ch/api/img/aa0fd53c-5d96-4a78-a5b5-0f68b543515a",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Fratarsko 5",
      "addressLocality": "Ždrelac",
      "postalCode": "23263",
      "addressCountry": "HR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 44.010669,
      "longitude": 15.285480
    },
    "numberOfRooms": 2,
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Wi-Fi", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Parking", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Air conditioning", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "BBQ", "value": true }
    ]
  })} />
  <Hero locale={typedLocale} />

  {/* Why Pašman */}
  <section class="section" data-reveal style="padding-bottom: var(--space-xl); margin-top: -2px;">
    <div class="container">
      <div class="split-section">
        <div class="split-section__left">
          <p class="text-label">{whySubtitle}</p>
          <h2>{whyTitle}</h2>
        </div>
        <div class="split-section__right">
          <p class="text-lead">{whyBody}</p>
          <div class="tag-row">
            {whyItems.map((item) => (
              <span class="tag">{item[typedLocale]}</span>
            ))}
          </div>
          <a href={`/${typedLocale}/zasto-pasman`} class="btn">
            {t(typedLocale, "nav.whyPasman")}
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Full-width image - Ždrelac - clickable, links to village page */}
  <div class="container" style="padding-bottom: var(--space-xl);">
    <a href={`/${typedLocale}/zdrelac`} class="feature-image" data-reveal style="text-decoration:none; color:inherit; display:block;">
      <div class="feature-image__wrap" style="border-radius: 16px; overflow: hidden;">
        <img src="/api/img/aa0fd53c-5d96-4a78-a5b5-0f68b543515a" alt="Aerial view of Ždrelac village on Pašman island" width="1920" height="1080" loading="lazy" />
        <div class="card-overlay">
          <span class="card-overlay__label">Ždrelac</span>
          <span class="card-overlay__title">{zdrelacTitle}</span>
        </div>
      </div>
    </a>
  </div>

  {/* Apartments */}
  <section class="section section--dark" data-reveal style="position: relative; margin-top: -1px; padding-top: clamp(80px, 12vw, 140px);">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="position: absolute; top: 0; left: 0; width: 100%; height: clamp(50px, 8vw, 100px); display: block; z-index: 2; transform: scaleY(-1);">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
    </svg>
    <div class="container">
      <div class="split-section split-section--reverse">
        <div class="split-section__left">
          <p class="text-label" style="color: rgba(255,255,255,0.7);">{t(typedLocale, "apartments.title")}</p>
          <h2>{aptsTitle}</h2>
          <p class="text-lead" style="color: rgba(255,255,255,0.75); margin-top: var(--space-lg);">
            {aptsBody}
          </p>
          <a href={`/${typedLocale}/apartmani`} class="btn btn--ghost" style="margin-top: var(--space-2xl);">
            {t(typedLocale, "nav.apartments")}
          </a>
        </div>
        <div class="split-section__right">
          <div class="duo-image">
            <div class="img-organic">
              <img src="/api/img/36c9265d-000a-42f1-9a4d-4b5c3c1b57c6" alt="Croatian coastal town from the sea" width="600" height="800" loading="lazy" />
            </div>
            <div class="img-organic">
              <img src="/api/img/4181b561-2828-4119-b04e-9fc596d65569" alt="Cozy apartment terrace with Mediterranean plants" width="600" height="800" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Exterior photo collage — CMS managed */}
    {collagePhotos.length > 0 && (
      <ScrollCollage images={collagePhotos} />
    )}

    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="position: absolute; bottom: -1px; left: 0; width: 100%; height: clamp(50px, 8vw, 100px); display: block; z-index: 2;">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
    </svg>
  </section>

  {/* Testimonials */}
  {testimonials.length > 0 && (
    <section class="section" data-reveal>
      <div class="container">
        <p class="text-label text-center" style="margin-bottom: var(--space-md);">
          {t(typedLocale, "homepage.ourGuests")}
        </p>
        <div class="testimonials-grid">
          {testimonials.slice(0, 3).map((test) => (
            <blockquote class="testimonial-card">
              <p class="testimonial-card__quote">{test.data.quote}</p>
              <footer class="testimonial-card__footer">
                <cite class="testimonial-card__name">{test.data.guest_name}</cite>
                {test.data.country && <span class="testimonial-card__country">{test.data.country}</span>}
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Experience section - what to do on the island */}
  <section class="section gradient-warm" data-reveal style="padding-bottom: 0;">
    <div class="container">
      <p class="text-label text-center">{t(typedLocale, "homepage.experiences")}</p>
      <h2 class="text-center" style="margin-top: var(--space-md); margin-bottom: var(--space-2xl);">
        {t(typedLocale, "homepage.discoverIsland")}
      </h2>
      <div class="triptych">
        <a href={`/${typedLocale}/hrana`} class="triptych__item">
          <img src="/api/img/216f0b04-b41f-491d-8921-bb5621c347fc" alt="Fresh Mediterranean seafood platter" width="600" height="750" loading="lazy" />
          <div class="card-overlay">
            <span class="card-overlay__label">{t(typedLocale, "guide.foodDrink")}</span>
            <span class="card-overlay__title">{t(typedLocale, "homepage.triptych.foodSubtitle")}</span>
          </div>
        </a>
        <a href={`/${typedLocale}/aktivnosti`} class="triptych__item">
          <img src="/api/img/55191404-d1fa-499c-a07e-dd169a96980a" alt="Coastal hiking trail on Adriatic island" width="600" height="750" loading="lazy" />
          <div class="card-overlay">
            <span class="card-overlay__label">{t(typedLocale, "homepage.triptych.activities")}</span>
            <span class="card-overlay__title">{t(typedLocale, "homepage.triptych.activitiesSubtitle")}</span>
          </div>
        </a>
        <a href={`/${typedLocale}/plaze`} class="triptych__item">
          <img src="/api/img/d7b6b48a-808a-4f38-b221-b6207e7fa36c" alt="Croatian pebble beach with turquoise water" width="600" height="750" loading="lazy" />
          <div class="card-overlay">
            <span class="card-overlay__label">{t(typedLocale, "guide.beaches")}</span>
            <span class="card-overlay__title">{t(typedLocale, "homepage.triptych.beachesSubtitle")}</span>
          </div>
        </a>
        <a href={`/${typedLocale}/vodic`} class="triptych__item">
          <img src="/api/img/c9c4485b-df86-4179-8d49-6cbbfbe0948c" alt="Historic bell tower on Pašman island" width="600" height="750" loading="lazy" />
          <div class="card-overlay">
            <span class="card-overlay__label">{t(typedLocale, "nav.localGuide")}</span>
            <span class="card-overlay__title">{t(typedLocale, "homepage.triptych.guideSubtitle")}</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  {/* CTA - sunset gradient */}
  <section class="section sunset-gradient" id="inquiry" data-reveal style="position: relative; padding-top: clamp(80px, 12vw, 140px);">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="position: absolute; top: 0; left: 0; width: 100%; height: clamp(50px, 8vw, 100px); display: block; z-index: 2; transform: scaleY(-1);">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
    </svg>
    <div class="container text-center">
      <p class="text-label" style="color: rgba(255,255,255,0.7);">{t(typedLocale, "nav.contact")}</p>
      <h2 style="margin-top: var(--space-md); color: white;">{ctaTitle}</h2>
      <p style="margin-inline: auto; margin-top: var(--space-lg); color: rgba(255,255,255,0.75);">
        {t(typedLocale, "trust.responseTime")}
      </p>
      <div style="margin-top: var(--space-2xl);">
        <a href={`/${typedLocale}/kontakt`} class="btn btn--ghost">
          {t(typedLocale, "booking.title")}
        </a>
      </div>
    </div>
  </section>
</Page>

<style is:global>
  /* ============================================================
     PHOTO STRIP - padded with rounded corners
     ============================================================ */
  .photo-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    padding-block: var(--space-2xl);
  }

  .photo-strip__item {
    overflow: hidden;
    border-radius: 16px;
    box-shadow: var(--shadow-hairline), var(--shadow-md);
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .photo-strip__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3 / 2;
    display: block;
    transition: transform 0.8s var(--ease-out);
  }

  .photo-strip__item:hover img {
    transform: scale(1.05);
    filter: saturate(1.05) contrast(1.03);
  }

  @media (max-width: 640px) {
    .photo-strip {
      grid-template-columns: 1fr;
    }
    .photo-strip__item img {
      aspect-ratio: 16 / 9;
    }
  }

  /* ============================================================
     WAVE SEPARATORS
     ============================================================ */
  .wave-sep {
    display: block;
    width: 100%;
    height: 60px;
    margin: 0;
  }

  .wave-sep--flip {
    transform: scaleY(-1);
  }

  /* ============================================================
     SPLIT SECTION - text + content side by side
     ============================================================ */
  .split-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .split-section {
      grid-template-columns: 1fr 1.2fr;
      gap: var(--space-3xl);
      align-items: start;
    }
    .split-section--reverse {
      grid-template-columns: 1.2fr 1fr;
    }
    .split-section--reverse .split-section__left {
      order: 1;
    }
    .split-section--reverse .split-section__right {
      order: 2;
    }
  }

  .split-section__left h2 {
    margin-top: var(--space-md);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  }

  /* Tag row */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .tag {
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid var(--color-sand);
    border-radius: 20px;
    color: var(--color-navy);
  }

  /* ============================================================
     FEATURE IMAGE - curved corners, text overlay, contained
     ============================================================ */
  .feature-image {
    padding-block: var(--space-xl);
  }

  .feature-image__wrap {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    box-shadow: var(--shadow-hairline), var(--shadow-xl);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .feature-image__wrap img {
    width: 100%;
    display: block;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    transition: transform 1.2s var(--ease-lux), filter 1.2s var(--ease-lux);
  }

  .feature-image__wrap:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 640px) {
    .feature-image__wrap img {
      aspect-ratio: 16 / 9;
    }
    .feature-image__wrap {
      border-radius: 16px;
    }
  }

  

  /* ============================================================
     DUO IMAGE - two photos with rounded corners
     ============================================================ */
  .duo-image {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .duo-image .img-organic img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    transition: transform 0.8s var(--ease-out);
  }

  .duo-image .img-organic:hover img {
    transform: scale(1.03);
  }

  /* ============================================================
     TESTIMONIALS - with subtle gradient background
     ============================================================ */
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  @media (min-width: 768px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .testimonial-card {
    position: relative;
    padding: var(--space-xl);
    background: var(--color-white);
    border-radius: 16px;
    box-shadow: var(--shadow-hairline), var(--shadow-md);
    transition: transform 0.5s var(--ease-lux), box-shadow 0.5s var(--ease-lux);
  }

  .testimonial-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hairline), var(--shadow-float);
  }

  .testimonial-card__quote {
    font-family: var(--font-serif);
    font-size: var(--font-size-lg);
    line-height: 1.6;
    color: var(--color-navy);
    font-style: italic;
    quotes: "\201C" "\201D" "\2018" "\2019";
  }

  .testimonial-card__quote::before { content: open-quote; }
  .testimonial-card__quote::after { content: close-quote; }

  .testimonial-card__footer {
    margin-top: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .testimonial-card__name {
    font-style: normal;
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--color-navy);
  }

  .testimonial-card__country {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
  }

  /* ============================================================
     TRIPTYCH - rounded corners, gap, labels slide in
     ============================================================ */
  .triptych {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .triptych {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .triptych__item {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    box-shadow: var(--shadow-hairline), var(--shadow-md);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .triptych__item img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 1.2s var(--ease-lux), filter 1.2s var(--ease-lux);
  }

  .triptych__item:hover img {
    transform: scale(1.06);
    filter: saturate(1.05) contrast(1.02);
  }

  

  @media (max-width: 640px) {
    .triptych {
      grid-template-columns: 1fr;
    }
    .triptych__item img {
      aspect-ratio: 16 / 9;
    }
  }
</style>
