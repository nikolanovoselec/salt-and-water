---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import MiniCollage from "~/components/ui/MiniCollage.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection, parsePhotoArray } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const title: Record<Locale, string> = {
  hr: "Hrana i piće", de: "Essen & Trinken", sl: "Hrana in pijača", en: "Food & Drink",
};

const intro: Record<Locale, string> = {
  hr: "Na Pašmanu i Ugljanu kuhinja je jednostavna i samouvjerena: kvalitetna riba s gradela, domaće maslinovo ulje, lagano dalmatinsko vino i ritam života koji se mjeri u obrocima uz more.",
  de: "Auf Pašman und Ugljan ist die Küche einfach und selbstbewusst: frischer Fisch vom Grill, hausgemachtes Olivenöl, leichter dalmatinischer Wein und ein Lebensrhythmus, der sich an Mahlzeiten am Meer misst.",
  sl: "Na Pašmanu in Ugljanu je kuhinja preprosta in samozavestna: kakovostna riba z žara, domače oljčno olje, rahlo dalmatinsko vino in ritem življenja, ki se meri v obrokih ob morju.",
  en: "On Pašman and Ugljan, the cuisine is simple and self-assured: quality grilled fish, homemade olive oil, light Dalmatian wine, and a pace of life measured in meals by the sea.",
};

const cmsEntries = (await getLocalizedCollection("hrana", typedLocale))
  .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0));

const sections = cmsEntries.map((e) => ({
  title: (e.data.title as string) ?? "",
  text: (e.data.body as string) ?? "",
  image: (e.data.image as string) ?? "",
  gallery: parsePhotoArray(e.data.gallery),
}));
---

<Page title={title[typedLocale]} locale={typedLocale} ogImage={`https://apartmani.novoselec.ch${sections[0]?.image || "/api/img/073aa7b8-b7d8-4da9-932d-d39caa24df2a"}`}>
  <HeroSimple title={title[typedLocale]} intro={intro[typedLocale]} image={sections[0]?.image || "/api/img/073aa7b8-b7d8-4da9-932d-d39caa24df2a"} />

  {sections.map((section, i) => {
    const photos = section.gallery.length > 0
      ? section.gallery
      : section.image ? [{ src: section.image, alt: section.title }] : [];
    return (
      <section class:list={["section", { "section--alt": i % 2 === 1 }]} data-reveal>
        <div class="container">
          <h2 class="editorial-title">{section.title}</h2>
        </div>
        {photos.length > 0 && (
          <div class="editorial-strip">
            <MiniCollage images={photos} speed={35} />
          </div>
        )}
        <div class="container">
          <p class="editorial-text">{section.text}</p>
        </div>
      </section>
    );
  })}
</Page>
