---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS — guide collection + editorial entries with page_key=vodic
const cmsGuide = await getLocalizedCollection("guide", typedLocale);
const cmsEditorial = (await getLocalizedCollection("editorial", typedLocale))
  .filter((e) => e.data.page_key === "vodic")
  .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0));

// Merge all entries into unified card format
const entries = [
  ...cmsGuide
    .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0))
    .map((g) => ({
      title: g.data.title as string,
      text: (g.data.description as string) ?? "",
      image: (g.data.image as string) ?? "",
    })),
  ...cmsEditorial.map((e) => ({
    title: (e.data.title as string) ?? "",
    text: (e.data.body as string) ?? "",
    image: (e.data.image as string) ?? "",
  })),
];
---

<Page title={t(typedLocale, "guide.title")} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/55191404-d1fa-499c-a07e-dd169a96980a">
  <HeroSimple title={t(typedLocale, "guide.title")} image="/api/img/55191404-d1fa-499c-a07e-dd169a96980a" />

  <section class="section">
    <div class="container">
      <div class="guide-cards">
        {entries.map((entry) => (
          <div class="guide-card" data-reveal>
            {entry.image && (
              <img src={entry.image} alt={entry.title} width="800" height="600" loading="lazy" />
            )}
            <div class="card-overlay">
              <span class="card-overlay__label">{entry.title}</span>
              {entry.text && <span class="card-overlay__title">{entry.text}</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .guide-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .guide-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .guide-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .guide-card {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    aspect-ratio: 4 / 3;
    background: var(--color-navy);
  }

  .guide-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .guide-card:hover img {
    transform: scale(1.06);
  }
</style>
