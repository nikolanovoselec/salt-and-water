---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS
const cmsGuide = await getLocalizedCollection("guide", typedLocale);

type GuideItem = { title: string; description: string; image: string };
let categories: GuideItem[] = [];

if (cmsGuide.length > 0) {
  categories = cmsGuide
    .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0))
    .map((g) => ({
      title: g.data.title as string,
      description: g.data.description as string,
      image: (g.data.image as string) ?? "",
    }));
} else {
  const fb: Record<Locale, GuideItem[]> = {
    hr: [
      { title: "Plaže", description: "Skrivene uvale, kristalno čisto more i kamene plaže na svakom koraku.", image: "https://images.pexels.com/photos/29175634/pexels-photo-29175634.jpeg?auto=compress&w=600" },
      { title: "Hrana i piće", description: "Svježa riba s roštilja, hobotnica ispod peke, domaće maslinovo ulje i otočno vino.", image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=600" },
      { title: "Aktivnosti", description: "Biciklizam, kayaking, ronjenje, šetnje maslinicima i istraživanje otoka.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=600" },
      { title: "Izleti", description: "Kornati, Zadar, nacionalni park Krka - sve nadohvat ruke.", image: "https://images.pexels.com/photos/3601425/pexels-photo-3601425.jpeg?auto=compress&w=600" },
    ],
    de: [
      { title: "Strände", description: "Versteckte Buchten, kristallklares Meer und Steinstrände bei jedem Schritt.", image: "https://images.pexels.com/photos/29175634/pexels-photo-29175634.jpeg?auto=compress&w=600" },
      { title: "Essen & Trinken", description: "Frischer Fisch vom Grill, Oktopus unter der Peka, hausgemachtes Olivenöl und Inselwein.", image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=600" },
      { title: "Aktivitäten", description: "Radfahren, Kajakfahren, Schnorcheln, Spaziergänge durch Olivenhaine und Inselerkundung.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=600" },
      { title: "Ausflüge", description: "Kornati, Zadar, Nationalpark Krka - alles in Reichweite.", image: "https://images.pexels.com/photos/3601425/pexels-photo-3601425.jpeg?auto=compress&w=600" },
    ],
    sl: [
      { title: "Plaže", description: "Skrite zalivčke, kristalno čisto morje in kamnite plaže na vsakem koraku.", image: "https://images.pexels.com/photos/29175634/pexels-photo-29175634.jpeg?auto=compress&w=600" },
      { title: "Hrana in pijača", description: "Sveža riba z žara, hobotnica izpod peke, domače oljčno olje in otoško vino.", image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=600" },
      { title: "Aktivnosti", description: "Kolesarjenje, kajakaštvo, potapljanje, sprehodi med oljkami in raziskovanje otoka.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=600" },
      { title: "Izleti", description: "Kornati, Zadar, narodni park Krka - vse na dosegu roke.", image: "https://images.pexels.com/photos/3601425/pexels-photo-3601425.jpeg?auto=compress&w=600" },
    ],
    en: [
      { title: "Beaches", description: "Hidden coves, crystal-clear sea, and pebble beaches at every turn.", image: "https://images.pexels.com/photos/29175634/pexels-photo-29175634.jpeg?auto=compress&w=600" },
      { title: "Food & Drink", description: "Fresh grilled fish, octopus peka, homemade olive oil, and island wine.", image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=600" },
      { title: "Activities", description: "Cycling, kayaking, snorkeling, olive grove walks, and island exploration.", image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=600" },
      { title: "Day Trips", description: "Kornati islands, Zadar, Krka National Park - all within reach.", image: "https://images.pexels.com/photos/3601425/pexels-photo-3601425.jpeg?auto=compress&w=600" },
    ],
  };
  categories = fb[typedLocale];
}

const imageAlts = [
  "Secluded pebble beach on Pašman island",
  "Traditional Dalmatian seafood meal",
  "Olive groves and hiking trails on Pašman",
  "Kornati islands aerial view from excursion boat",
];
---

<Page title={t(typedLocale, "guide.title")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "guide.title")} image="https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=1920" />

  <section class="section">
    <div class="container">
      <div class="guide-grid" data-reveal-stagger>
        {categories.map((cat, i) => (
          <div class:list={["guide-item", { "guide-item--reverse": i % 2 === 1 }]} data-reveal>
            <div class="guide-item__image">
              <img src={cat.image} alt={imageAlts[i % imageAlts.length]} width="600" height="400" loading="lazy" />
            </div>
            <div class="guide-item__content">
              <h2 class="guide-item__title">{cat.title}</h2>
              <div class="section-divider" style="margin: var(--space-md) 0;"></div>
              <p class="guide-item__text">{cat.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .guide-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .guide-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .guide-item {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
    .guide-item--reverse .guide-item__image {
      order: 2;
    }
    .guide-item--reverse .guide-item__content {
      order: 1;
    }
  }

  .guide-item__image {
    overflow: hidden;
  }

  .guide-item__image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .guide-item:hover .guide-item__image img {
    transform: scale(1.02);
  }

  .guide-item__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  .guide-item__text {
    font-size: var(--font-size-lg);
    line-height: 1.7;
    color: var(--color-text);
  }
</style>
