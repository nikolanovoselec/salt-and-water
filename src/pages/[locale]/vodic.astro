---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const categories = [
  {
    key: "guide.beaches",
    image: "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=600",
    hr: "Skrivene uvale, kristalno čisto more i kamene plaže na svakom koraku.",
    de: "Versteckte Buchten, kristallklares Meer und Steinstrände bei jedem Schritt.",
    sl: "Skrite zalivčke, kristalno čisto morje in kamnite plaže na vsakem koraku.",
    en: "Hidden coves, crystal-clear sea, and pebble beaches at every turn.",
  },
  {
    key: "guide.foodDrink",
    image: "https://images.pexels.com/photos/1267320/pexels-photo-1267320.jpeg?auto=compress&w=600",
    hr: "Svježa riba s roštilja, hobotnica ispod peke, domaće maslinovo ulje i otočno vino.",
    de: "Frischer Fisch vom Grill, Oktopus unter der Peka, hausgemachtes Olivenöl und Inselwein.",
    sl: "Sveža riba z žara, hobotnica izpod peke, domače oljčno olje in otoško vino.",
    en: "Fresh grilled fish, octopus peka, homemade olive oil, and island wine.",
  },
  {
    key: "guide.activities",
    image: "https://images.pexels.com/photos/4992828/pexels-photo-4992828.jpeg?auto=compress&w=600",
    hr: "Biciklizam, kayaking, ronjenje, šetnje maslinicima i istraživanje otoka.",
    de: "Radfahren, Kajakfahren, Schnorcheln, Spaziergänge durch Olivenhaine und Inselerkundung.",
    sl: "Kolesarjenje, kajakaštvo, potapljanje, sprehodi med oljkami in raziskovanje otoka.",
    en: "Cycling, kayaking, snorkeling, olive grove walks, and island exploration.",
  },
  {
    key: "guide.dayTrips",
    image: "https://images.pexels.com/photos/3601425/pexels-photo-3601425.jpeg?auto=compress&w=600",
    hr: "Kornati, Zadar, nacionalni park Krka — sve nadohvat ruke.",
    de: "Kornati, Zadar, Nationalpark Krka — alles in Reichweite.",
    sl: "Kornati, Zadar, narodni park Krka — vse na dosegu roke.",
    en: "Kornati islands, Zadar, Krka National Park — all within reach.",
  },
];
---

<Page title={t(typedLocale, "guide.title")} locale={typedLocale}>
  <HeroSimple title={t(typedLocale, "guide.title")} />

  <section class="section">
    <div class="container">
      <div class="guide-grid" data-reveal>
        {categories.map((cat, i) => (
          <div class:list={["guide-item", { "guide-item--reverse": i % 2 === 1 }]}>
            <div class="guide-item__image">
              <img src={cat.image} alt="" width="600" height="400" loading="lazy" />
            </div>
            <div class="guide-item__content">
              <p class="text-label">{t(typedLocale, cat.key)}</p>
              <p class="guide-item__text">{cat[typedLocale]}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .guide-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .guide-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .guide-item {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
    .guide-item--reverse .guide-item__image {
      order: 2;
    }
    .guide-item--reverse .guide-item__content {
      order: 1;
    }
  }

  .guide-item__image {
    overflow: hidden;
  }

  .guide-item__image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }

  .guide-item__text {
    font-size: var(--font-size-lg);
    line-height: 1.7;
    margin-top: var(--space-md);
    color: var(--color-text);
  }
</style>
