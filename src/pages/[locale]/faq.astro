---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import SchemaOrg from "~/components/seo/SchemaOrg.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS
const cmsFaqs = await getLocalizedCollection("faqs", typedLocale);

// Build FAQ list from CMS or fallback
type FaqItem = { question: string; answer: string; category: string };
let faqs: FaqItem[] = [];

if (cmsFaqs.length > 0) {
  faqs = cmsFaqs
    .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0))
    .map((f) => ({
      question: f.data.question as string,
      answer: f.data.answer as string,
      category: (f.data.category as string) ?? "general",
    }));
} else {
  // Fallback
  const fb: Record<Locale, FaqItem[]> = {
    hr: [
      { question: "Kako doći na Pašman?", answer: "Trajektom iz Biograda na Moru do Tkona (25 min) ili preko mosta Ždrelac s Ugljana.", category: "getting-there" },
      { question: "Ima li klima uređaj?", answer: "Da, svi apartmani imaju klimu.", category: "apartment" },
      { question: "Ima li parkinga?", answer: "Da, besplatno parkiranje je dostupno uz smještaj.", category: "apartment" },
      { question: "Jesu li kućni ljubimci dozvoljeni?", answer: "Molimo pitajte pri rezervaciji. Primamo kućne ljubimce, ali vrijede određeni uvjeti.", category: "booking" },
      { question: "Kada je prijava/odjava?", answer: "Prijava od 14:00, odjava do 10:00. Fleksibilni termini po dogovoru.", category: "booking" },
      { question: "Ima li Wi-Fi?", answer: "Da, besplatan brzi Wi-Fi je dostupan u svim apartmanima.", category: "apartment" },
      { question: "Gdje mogu kupiti namirnice?", answer: "Najbliža trgovina je u Ždrelacu (5 min pješice). Veći supermarketi su u Tkonu i na Ugljanu.", category: "getting-there" },
    ],
    de: [
      { question: "Wie kommt ihr nach Pašman?", answer: "Mit der Fähre ab Biograd (ca. 25 Min.) oder ab Zadar (Fähre nach Ugljan, dann über die Brücke). Detaillierte Infos findet ihr auf der Seite Anreise.", category: "getting-there" },
      { question: "Gibt es eine Klimaanlage?", answer: "Ja, alle Apartments haben eine Klimaanlage.", category: "apartment" },
      { question: "Gibt es einen Parkplatz?", answer: "Ja, ihr könnt direkt beim Apartment kostenlos parken.", category: "apartment" },
      { question: "Sind Haustiere erlaubt?", answer: "Bitte fragt uns bei der Anfrage kurz nach – je nach Termin und Apartment.", category: "booking" },
      { question: "Wann ist Check-in / Check-out?", answer: "Check-in ab 14:00 Uhr, Check-out bis 10:00 Uhr.", category: "booking" },
      { question: "Gibt es WLAN?", answer: "Ja, in allen Apartments gibt es schnelles, kostenloses WLAN.", category: "apartment" },
      { question: "Wo kann ich einkaufen?", answer: "Der nächste Laden ist in Ždrelac (ca. 5 Minuten zu Fuss). Für mehr Auswahl eignen sich Biograd oder Zadar.", category: "getting-there" },
    ],
    sl: [
      { question: "Kako priti na Pašman?", answer: "S trajektom iz Biograda (ok. 25 min) ali iz Zadra (trajekt na Ugljan, nato čez most). Podrobna navodila so na strani Kako priti.", category: "getting-there" },
      { question: "Ali je klima?", answer: "Da, vsi apartmaji imajo klimatsko napravo.", category: "apartment" },
      { question: "Ali je parkirišče?", answer: "Da, brezplačno parkiranje je ob apartmaju.", category: "apartment" },
      { question: "Ali so hišni ljubljenčki dovoljeni?", answer: "Prosimo, vprašajte ob rezervaciji – odvisno od termina in apartmaja.", category: "booking" },
      { question: "Kdaj je prihod/odhod?", answer: "Prihod od 14:00, odhod do 10:00.", category: "booking" },
      { question: "Ali je Wi-Fi?", answer: "Da, v vseh apartmajih je na voljo brezplačen hiter Wi-Fi.", category: "apartment" },
      { question: "Kje lahko kupim živila?", answer: "Najbližja trgovina je v Ždrelcu (približno 5 minut peš). Za večjo izbiro sta najboljša Biograd ali Zadar.", category: "getting-there" },
    ],
    en: [
      { question: "How do we get to Pašman?", answer: "By ferry from Biograd (about 25 minutes) or from Zadar (ferry to Ugljan, then across the bridge). You'll find step-by-step directions on the Getting Here page.", category: "getting-there" },
      { question: "Do you have air conditioning?", answer: "Yes — every apartment has air conditioning.", category: "apartment" },
      { question: "Is parking available?", answer: "Yes — free parking is available right by the apartment.", category: "apartment" },
      { question: "Are pets allowed?", answer: "Please ask us when you book — we'll confirm what works for your dates and the apartment.", category: "booking" },
      { question: "What are the check-in and check-out times?", answer: "Check-in from 2:00 PM, check-out by 10:00 AM.", category: "booking" },
      { question: "Is there Wi-Fi?", answer: "Yes — free, fast Wi-Fi is available in all apartments.", category: "apartment" },
      { question: "Where can we buy groceries?", answer: "The nearest shop is in Ždrelac (about a 5-minute walk). For a bigger selection, head to Biograd or Zadar.", category: "getting-there" },
    ],
  };
  faqs = fb[typedLocale];
}

// Schema.org FAQPage
const faqSchema = {
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Page title={t(typedLocale, "faq.title")} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/a1f5a8fb-6616-4c17-a60f-e7df4eec89bc">
  <SchemaOrg type="FAQPage" data={faqSchema} />
  <HeroSimple title={t(typedLocale, "faq.title")} image="/api/img/a1f5a8fb-6616-4c17-a60f-e7df4eec89bc" />

  <section class="section">
    <div class="container">
      <div class="faq-list" data-reveal-stagger>
        {faqs.map((faq, i) => (
          <details class="faq-item" id={i === faqs.length - 1 ? "house-rules" : undefined}>
            <summary class="faq-item__question">
              {faq.question}
              <svg class="faq-item__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              </svg>
            </summary>
            <div class="faq-item__answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .faq-list {
    max-width: 800px;
    margin-inline: auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-stone);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) 0;
    cursor: pointer;
    font-size: var(--font-size-lg);
    font-weight: 500;
    color: var(--color-navy);
    list-style: none;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__icon {
    flex-shrink: 0;
    transition: transform var(--duration-fast);
    color: var(--color-text-light);
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(180deg);
  }

  .faq-item__answer {
    padding-bottom: var(--space-lg);
    color: var(--color-text);
    line-height: 1.7;
  }
</style>
