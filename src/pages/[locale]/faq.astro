---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import SchemaOrg from "~/components/seo/SchemaOrg.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS
const cmsFaqs = await getLocalizedCollection("faqs", typedLocale);

// Build FAQ list from CMS or fallback
type FaqItem = { question: string; answer: string; category: string };
let faqs: FaqItem[] = [];

if (cmsFaqs.length > 0) {
  faqs = cmsFaqs
    .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0))
    .map((f) => ({
      question: f.data.question as string,
      answer: f.data.answer as string,
      category: (f.data.category as string) ?? "general",
    }));
} else {
  // Fallback
  const fb: Record<Locale, FaqItem[]> = {
    hr: [
      { question: "Kako doći do nas?", answer: "Trajektom iz Biograda do Tkona (25 min) ili iz Zadra do Preka na Ugljanu (25 min), pa preko mosta Ždrelac ravno do nas. Sve upute na stranici Kako doći.", category: "getting-there" },
      { question: "Treba li nam auto?", answer: "Ne nužno. S trajektom i lokalnim autobusom ili dogovorenim prijevozom možete doći do nas. Na otoku se bicikl može iznajmiti od 10 €/dan s dostavom na adresu. Ali ako volite istraživati uvale i okolna mjesta, auto je praktičan.", category: "getting-there" },
      { question: "Kako funkcionira dolazak i odlazak?", answer: "Nema recepcije ni formalnosti. Prije dolaska dobijete PIN kod i upute za lockbox s ključem. Dođete kad vam odgovara (prijava od 14:00, odjava do 10:00), otključate i odmah ste doma. Nitko vas neće smetati.", category: "booking" },
      { question: "Smijemo li dovesti kućnog ljubimca?", answer: "Javite nam se kad šaljete upit — ovisno o situaciji dogovorimo se.", category: "booking" },
      { question: "Ima li klima, Wi-Fi i parking?", answer: "Da, sve troje. Klima u svim sobama, brzi Wi-Fi i besplatno parkiranje uz apartman.", category: "apartment" },
      { question: "Gdje kupiti namirnice i svježu ribu?", answer: "Trgovina u Ždrelcu je 5 minuta pješice. Svježu ribu kupujete u Kaliju na Ugljanu ili na ribarnici u Zadru. Za veći izbor tu su Biograd i Zadar — oboje 25 minuta trajektom.", category: "getting-there" },
      { question: "Kakve su plaže — pijesak ili kamen?", answer: "Oboje. Matlovac u Ždrelcu je pješčana plaža s blagim ulazom, savršena za djecu. Na obje strane otoka ima i šljunčanih i kamenitih uvala. Pitajte nas za preporuku — znamo koju uvalu za svaki ukus.", category: "getting-there" },
      { question: "Kućni red", answer: "Nemamo čistačicu ni hotelski servis — o apartmanima brinemo sami, s pažnjom i ljubavlju. Jedino što vas molimo: ostavite apartman onako kako ste ga zatekli. Ako svaki gost ostavi malo pažnje za sljedećeg, svima nam je ljepše. Hvala vam na tome.", category: "house-rules" },
    ],
    de: [
      { question: "Wie kommt ihr zu uns?", answer: "Mit der Fähre von Biograd nach Tkon (25 Min.) oder von Zadar nach Preko auf Ugljan (25 Min.), dann über die Brücke in Ždrelac direkt zu uns. Alle Details auf der Seite Anreise.", category: "getting-there" },
      { question: "Brauchen wir ein Auto?", answer: "Nicht unbedingt. Ihr könnt uns per Fähre und Lokalbus oder organisiertem Transfer erreichen. Fahrräder gibt es auf der Insel ab 10 €/Tag mit Lieferung. Aber wenn ihr Buchten und die Umgebung erkunden wollt, ist ein Auto praktisch.", category: "getting-there" },
      { question: "Wie funktioniert der Check-in?", answer: "Keine Rezeption, keine Formalitäten. Vor eurer Ankunft bekommt ihr einen PIN-Code und eine Anleitung für die Schlüsselbox. Kommt, wann es euch passt (Check-in ab 14:00, Check-out bis 10:00), schliesst auf und seid zuhause. Niemand wird euch stören.", category: "booking" },
      { question: "Dürfen wir ein Haustier mitbringen?", answer: "Meldet euch bei eurer Anfrage — je nach Situation finden wir eine Lösung.", category: "booking" },
      { question: "Gibt es Klima, WLAN und Parkplatz?", answer: "Ja, alles drei. Klimaanlage in jedem Zimmer, schnelles WLAN und kostenloser Parkplatz direkt beim Apartment.", category: "apartment" },
      { question: "Wo kauft man Lebensmittel und frischen Fisch?", answer: "Ein Laden in Ždrelac ist 5 Gehminuten entfernt. Frischen Fisch bekommt ihr in Kali auf Ugljan oder auf dem Fischmarkt in Zadar. Für grössere Einkäufe sind Biograd und Zadar je 25 Fährminuten entfernt.", category: "getting-there" },
      { question: "Wie sind die Strände — Sand oder Kies?", answer: "Beides. Matlovac in Ždrelac ist ein Sandstrand mit flachem Einstieg, ideal für Kinder. Auf beiden Seiten der Insel gibt es auch Kies- und Felsbuchten. Fragt uns nach einer Empfehlung — wir kennen die richtige Bucht für jeden Geschmack.", category: "getting-there" },
      { question: "Hausordnung", answer: "Wir haben keine Reinigungskraft und keinen Hotelservice — wir pflegen unsere Apartments selbst, mit Sorgfalt und Liebe. Unsere einzige Bitte: Hinterlasst das Apartment so, wie ihr es vorgefunden habt. Wenn jeder Gast ein wenig Rücksicht für den nächsten zeigt, ist es für alle schöner. Danke euch dafür.", category: "house-rules" },
    ],
    sl: [
      { question: "Kako pridemo do vas?", answer: "S trajektom iz Biograda do Tkona (25 min) ali iz Zadra do Preka na Ugljanu (25 min), nato čez most v Ždrelcu naravnost do nas. Vse podrobnosti na strani Kako priti.", category: "getting-there" },
      { question: "Ali potrebujemo avto?", answer: "Ne nujno. Do nas pridete s trajektom in lokalnim avtobusom ali dogovorjenim prevozom. Na otoku se kolo da najeti od 10 €/dan z dostavo. Če pa bi radi raziskovali zalive in okolico, je avto priročen.", category: "getting-there" },
      { question: "Kako poteka prihod?", answer: "Brez recepcije, brez formalnosti. Pred prihodom prejmete PIN kodo in navodila za ključavnico s ključem. Pridete, ko vam ustreza (prihod od 14:00, odhod do 10:00), odklenete in ste doma. Nihče vas ne bo motil.", category: "booking" },
      { question: "Ali lahko pripeljemo hišnega ljubljenčka?", answer: "Javite se nam ob povpraševanju — glede na situacijo se dogovorimo.", category: "booking" },
      { question: "Ali je klima, Wi-Fi in parkirišče?", answer: "Da, vse troje. Klima v vsaki sobi, hiter Wi-Fi in brezplačno parkiranje ob apartmaju.", category: "apartment" },
      { question: "Kje kupiti živila in svežo ribo?", answer: "Trgovina v Ždrelcu je 5 minut peš. Svežo ribo dobite v Kaliju na Ugljanu ali na ribji tržnici v Zadru. Za večjo izbiro sta tu Biograd in Zadar — oba 25 minut s trajektom.", category: "getting-there" },
      { question: "Kakšne so plaže — pesek ali kamen?", answer: "Oboje. Matlovac v Ždrelcu je peščena plaža z blagim vstopom, idealna za otroke. Na obeh straneh otoka so tudi prodnati in skalnati zalivi. Vprašajte nas za priporočilo — vemo, kateri zaliv ustreza vsakemu okusu.", category: "getting-there" },
      { question: "Hišni red", answer: "Nimamo čistilke niti hotelskega servisa — apartmaje vzdržujemo sami, s skrbjo in ljubeznijo. Edina prošnja: pustite apartma tako, kot ste ga našli. Če vsak gost pusti malce pozornosti za naslednjega, je vsem lepše. Hvala vam za to.", category: "house-rules" },
    ],
    en: [
      { question: "How do we get there?", answer: "By ferry from Biograd to Tkon (25 min) or from Zadar to Preko on Ugljan (25 min), then across the Ždrelac bridge straight to us. Full directions on the Getting Here page.", category: "getting-there" },
      { question: "Do we need a car?", answer: "Not necessarily. You can reach us by ferry and local bus or arranged transfer. Bikes can be rented on the island from €10/day with delivery. But if you like exploring coves and nearby villages, a car is handy.", category: "getting-there" },
      { question: "How does check-in work?", answer: "No reception, no formalities. Before you arrive, we send you a PIN code and instructions for the lockbox with the key. Come when it suits you (check-in from 2 PM, check-out by 10 AM), unlock, and you're home. Nobody will bother you.", category: "booking" },
      { question: "Can we bring a pet?", answer: "Get in touch when you send your inquiry — we'll work it out depending on the situation.", category: "booking" },
      { question: "Is there AC, Wi-Fi, and parking?", answer: "Yes, all three. Air conditioning in every room, fast Wi-Fi, and free parking right by the apartment.", category: "apartment" },
      { question: "Where do we buy groceries and fresh fish?", answer: "There's a shop in Ždrelac, a 5-minute walk away. For fresh fish, head to Kali on Ugljan or the fish market in Zadar. For a bigger selection, Biograd and Zadar are both 25 minutes by ferry.", category: "getting-there" },
      { question: "What are the beaches like — sand or pebbles?", answer: "Both. Matlovac in Ždrelac is a sandy beach with a gentle slope, perfect for children. Both sides of the island have pebble and rocky coves too. Ask us for a recommendation — we know which cove suits every taste.", category: "getting-there" },
      { question: "House rules", answer: "We don't have a cleaning service or hotel staff — we look after our apartments ourselves, with care and love. Our only request: please leave the apartment the way you found it. When every guest leaves a little consideration for the next, it's nicer for everyone. Thank you for that.", category: "house-rules" },
    ],
  };
  faqs = fb[typedLocale];
}

// Schema.org FAQPage
const faqSchema = {
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Page title={t(typedLocale, "faq.title")} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/a1f5a8fb-6616-4c17-a60f-e7df4eec89bc">
  <SchemaOrg type="FAQPage" data={faqSchema} />
  <HeroSimple title={t(typedLocale, "faq.title")} image="/api/img/a1f5a8fb-6616-4c17-a60f-e7df4eec89bc" />

  <section class="section">
    <div class="container">
      <div class="faq-list" data-reveal-stagger>
        {faqs.map((faq, i) => (
          <details class="faq-item" id={faq.category === "house-rules" ? "house-rules" : undefined}>
            <summary class="faq-item__question">
              {faq.question}
              <svg class="faq-item__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              </svg>
            </summary>
            <div class="faq-item__answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    if (window.location.hash === "#house-rules") {
      var el = document.getElementById("house-rules");
      if (el) {
        el.open = true;
        el.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    }
  </script>
</Page>

<style>
  .faq-list {
    max-width: 800px;
    margin-inline: auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-stone);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) 0;
    cursor: pointer;
    font-size: var(--font-size-lg);
    font-weight: 500;
    color: var(--color-navy);
    list-style: none;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__icon {
    flex-shrink: 0;
    transition: transform var(--duration-fast);
    color: var(--color-text-light);
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(180deg);
  }

  .faq-item__answer {
    padding-bottom: var(--space-lg);
    color: var(--color-text);
    line-height: 1.7;
  }
</style>
