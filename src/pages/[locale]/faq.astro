---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import SchemaOrg from "~/components/seo/SchemaOrg.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";
import { stripHtml } from "~/lib/sanitize";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS
const cmsFaqs = await getLocalizedCollection("faqs", typedLocale);

// Build FAQ list from CMS or fallback
type FaqItem = { question: string; answer: string; category: string };
let faqs: FaqItem[] = [];

if (cmsFaqs.length > 0) {
  faqs = cmsFaqs
    .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0))
    .map((f) => ({
      question: f.data.question as string,
      answer: f.data.answer as string,
      category: (f.data.category as string) ?? "general",
    }));
} else {
  // Fallback
  const fb: Record<Locale, FaqItem[]> = {
    hr: [
      { question: "Kako doći do nas?", answer: `Najlakše trajektom Biograd → Tkon (25 min) ili Zadar → Preko (25 min), pa preko mosta u Ždrelcu prema Pašmanu. Sve upute, parking i Google Maps link na stranici <a href="/${locale}/dolazak">Kako doći</a>.`, category: "getting-there" },
      { question: "Treba li nam auto?", answer: "Ne nužno. Do nas možete doći trajektom pa autobusom, a po potrebi vam možemo preporučiti lokalni prijevoz. Na otoku se može iznajmiti i bicikl uz dostavu na adresu. Ipak, ako želite obilaziti uvale i mjesta po otoku, auto je najpraktičniji.", category: "getting-there" },
      { question: "Kako funkcionira dolazak?", answer: "Sve je samostalno, bez recepcije. Prije dolaska šaljemo vam PIN i upute za sef za ključeve. Dolazite kad vam odgovara (ulazak od 14:00, izlazak do 10:00) — otključate i odmah ste doma. Imate svoj mir, a mi smo dostupni na telefonu ako nešto zatreba.", category: "booking" },
      { question: "Smijemo li dovesti kućnog ljubimca?", answer: "Može uz prethodnu najavu. Napišite nam u upitu koju životinju dovodite, pa ćemo vam odmah potvrditi može li u taj apartman i pod kojim uvjetima.", category: "booking" },
      { question: "Ima li klima, Wi-Fi i parking?", answer: "Da — apartmani imaju klimu, Wi-Fi i besplatan parking uz kuću.", category: "apartment" },
      { question: "Gdje kupiti namirnice i svježu ribu?", answer: "Najbliža trgovina u Ždrelcu je par minuta pješice. Svježu ribu možete kupiti u Kaliju na Ugljanu ili na ribarnici u Zadru. Za veći izbor tu su Biograd i Zadar — lako dostupni trajektom.", category: "getting-there" },
      { question: "Kakve su plaže — pijesak ili kamen?", answer: "Oboje. Matlovac u Ždrelcu je pješčana plaža s blagim ulazom, odlična za djecu. Na obje strane otoka ima i šljunčanih i kamenitih uvala. Javite što volite — preporučit ćemo vam uvalu po mjeri.", category: "getting-there" },
      { question: "Kućni red", answer: "Nismo hotel i nemamo dnevno čišćenje — apartman vam predajemo čist i spreman, a o svemu brinemo osobno. Molimo vas samo osnovno: ostavite apartman pristojno i uredno, otprilike kako ste ga zatekli. Ako svaki gost ostavi malo pažnje za sljedećeg, svima nam je ljepše. Hvala vam.", category: "house-rules" },
    ],
    de: [
      { question: "Wie kommt ihr zu uns?", answer: `Am einfachsten mit der Fähre: Biograd → Tkon (25 Min.) oder Zadar → Preko (25 Min.), dann über die Brücke in Ždrelac nach Pašman. Alle Details, Parkinfos und Google-Maps-Link auf der Seite <a href="/${locale}/dolazak">Anreise</a>.`, category: "getting-there" },
      { question: "Brauchen wir ein Auto?", answer: "Nicht unbedingt. Ihr könnt uns per Fähre und Lokalbus erreichen, und wir empfehlen euch gern einen lokalen Transport. Fahrräder gibt es auf der Insel mit Lieferung. Aber wenn ihr Buchten und Dörfer auf der Insel erkunden wollt, ist ein Auto am praktischsten.", category: "getting-there" },
      { question: "Wie funktioniert der Check-in?", answer: "Alles läuft eigenständig, ohne Rezeption. Vor eurer Ankunft schicken wir euch einen PIN und eine Anleitung für den Schlüsselsafe. Kommt, wann es euch passt (Anreise ab 14:00, Abreise bis 10:00) — aufschliessen und ihr seid zuhause. Ihr habt eure Ruhe und Privatsphäre, und wir sind telefonisch erreichbar, falls ihr etwas braucht.", category: "booking" },
      { question: "Dürfen wir ein Haustier mitbringen?", answer: "Ja, mit Voranmeldung. Schreibt uns in eurer Anfrage, welches Tier ihr mitbringt, und wir bestätigen, ob es in dem Apartment und zu dem Termin passt.", category: "booking" },
      { question: "Gibt es Klima, WLAN und Parkplatz?", answer: "Ja — die Apartments haben Klimaanlage, WLAN und kostenlosen Parkplatz am Haus.", category: "apartment" },
      { question: "Wo kauft man Lebensmittel und frischen Fisch?", answer: "Der nächste Laden in Ždrelac ist ein paar Gehminuten entfernt. Frischen Fisch bekommt ihr in Kali auf Ugljan oder auf dem Fischmarkt in Zadar. Biograd und Zadar sind per Fähre leicht erreichbar für grössere Einkäufe.", category: "getting-there" },
      { question: "Wie sind die Strände — Sand oder Kies?", answer: "Beides. Matlovac in Ždrelac ist ein Sandstrand mit flachem Einstieg, toll für Kinder. Auf beiden Seiten der Insel gibt es auch Kies- und Felsbuchten. Sagt uns, was ihr mögt — wir empfehlen euch die passende Bucht.", category: "getting-there" },
      { question: "Hausordnung", answer: "Wir sind kein Hotel und es gibt keine tägliche Reinigung — wir übergeben das Apartment sauber und fertig, und kümmern uns um alles persönlich. Wir bitten euch nur um das Grundlegende: Hinterlasst das Apartment ordentlich und ungefähr so, wie ihr es vorgefunden habt. Wenn jeder Gast ein wenig Rücksicht für den nächsten zeigt, ist es für alle schöner. Danke euch.", category: "house-rules" },
    ],
    sl: [
      { question: "Kako pridemo do vas?", answer: `Najlažje s trajektom: Biograd → Tkon (25 min) ali Zadar → Preko (25 min), nato čez most v Ždrelcu na Pašman. Vse podrobnosti, parkiranje in Google Maps povezava na strani <a href="/${locale}/dolazak">Kako priti</a>.`, category: "getting-there" },
      { question: "Ali potrebujemo avto?", answer: "Ne nujno. Do nas pridete s trajektom in lokalnim avtobusom, po potrebi vam priporočimo lokalni prevoz. Na otoku se da najeti tudi kolo z dostavo. Če pa bi radi raziskovali zalive in kraje po otoku, je avto najpriročnejši.", category: "getting-there" },
      { question: "Kako poteka prihod?", answer: "Vse je samostojno, brez recepcije. Pred prihodom vam pošljemo PIN in navodila za sef za ključe. Pridete, ko vam ustreza (prihod od 14:00, odhod do 10:00) — odklenete in ste doma. Imate svoj mir, mi pa smo dosegljivi po telefonu, če kaj potrebujete.", category: "booking" },
      { question: "Ali lahko pripeljemo hišnega ljubljenčka?", answer: "Ja, s predhodno najavo. V povpraševanju nam napišite, kakšno žival imate, in potrdili vam bomo, ali gre v ta apartma in pod kakšnimi pogoji.", category: "booking" },
      { question: "Ali je klima, Wi-Fi in parkirišče?", answer: "Da — apartmaji imajo klimo, Wi-Fi in brezplačno parkirišče ob hiši.", category: "apartment" },
      { question: "Kje kupiti živila in svežo ribo?", answer: "Najbližja trgovina v Ždrelcu je par minut peš. Svežo ribo dobite v Kaliju na Ugljanu ali na ribji tržnici v Zadru. Biograd in Zadar sta s trajektom lahko dosegljiva za večje nakupe.", category: "getting-there" },
      { question: "Kakšne so plaže — pesek ali kamen?", answer: "Oboje. Matlovac v Ždrelcu je peščena plaža z blagim vstopom, odlična za otroke. Na obeh straneh otoka so tudi prodnati in skalnati zalivi. Povejte, kaj vam je bolj všeč — priporočili vam bomo pravi zaliv.", category: "getting-there" },
      { question: "Hišni red", answer: "Nismo hotel in nimamo dnevnega čiščenja — apartma vam predamo čist in pripravljen, za vse pa skrbimo osebno. Prosimo vas le za osnovno: pustite apartma urejen in približno tak, kot ste ga našli. Če vsak gost pusti malce pozornosti za naslednjega, je vsem lepše. Hvala vam.", category: "house-rules" },
    ],
    en: [
      { question: "How do we get there?", answer: `Easiest by ferry: Biograd → Tkon (25 min) or Zadar → Preko (25 min), then across the bridge in Ždrelac to Pašman. Full directions, parking info and Google Maps link on the <a href="/${locale}/dolazak">Getting Here</a> page.`, category: "getting-there" },
      { question: "Do we need a car?", answer: "Not necessarily. You can reach us by ferry and local bus, and we can recommend local transport if needed. Bikes can be rented on the island with delivery. But if you want to explore coves and villages around the island, a car is the most practical option.", category: "getting-there" },
      { question: "How does check-in work?", answer: "Everything is self-service, no reception. Before you arrive, we send you a PIN and instructions for the key safe. Come when it suits you (check-in from 2 PM, check-out by 10 AM) — unlock and you're home. You'll have your peace and privacy, and we're just a phone call away if you need anything.", category: "booking" },
      { question: "Can we bring a pet?", answer: "Yes, with prior notice. Let us know in your inquiry what kind of pet you have, and we'll confirm whether it works for that apartment and the dates.", category: "booking" },
      { question: "Is there AC, Wi-Fi, and parking?", answer: "Yes — the apartments have air conditioning, Wi-Fi, and free parking by the house.", category: "apartment" },
      { question: "Where do we buy groceries and fresh fish?", answer: "The nearest shop in Ždrelac is a few minutes' walk. For fresh fish, head to Kali on Ugljan or the fish market in Zadar. Biograd and Zadar are both easy to reach by ferry for a bigger selection.", category: "getting-there" },
      { question: "What are the beaches like — sand or pebbles?", answer: "Both. Matlovac in Ždrelac is a sandy beach with a gentle slope, great for children. Both sides of the island also have pebble and rocky coves. Tell us what you prefer — we'll recommend the right one for you.", category: "getting-there" },
      { question: "House rules", answer: "We're not a hotel and there's no daily cleaning — we hand you the apartment clean and ready, and we take care of everything personally. All we ask is the basics: leave the apartment tidy and roughly as you found it. When every guest leaves a little care for the next, it's nicer for everyone. Thank you.", category: "house-rules" },
    ],
  };
  faqs = fb[typedLocale];
}

// Schema.org FAQPage — strip HTML from answers for structured data
const faqSchema = {
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: stripHtml(faq.answer) },
  })),
};
---

<Page title={t(typedLocale, "faq.title")} locale={typedLocale} ogImage="https://apartmani.novoselec.ch/api/img/a1f5a8fb-6616-4c17-a60f-e7df4eec89bc">
  <SchemaOrg type="FAQPage" data={faqSchema} />
  <HeroSimple title={t(typedLocale, "faq.title")} image="/api/img/a1f5a8fb-6616-4c17-a60f-e7df4eec89bc" />

  <section class="section">
    <div class="container">
      <div class="faq-list" data-reveal-stagger>
        {faqs.map((faq, i) => (
          <details class="faq-item" id={faq.category === "house-rules" ? "house-rules" : undefined}>
            <summary class="faq-item__question">
              {faq.question}
              <svg class="faq-item__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              </svg>
            </summary>
            <div class="faq-item__answer">
              <p set:html={faq.answer} />
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    if (window.location.hash === "#house-rules") {
      var el = document.getElementById("house-rules");
      if (el) {
        el.open = true;
        el.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    }
  </script>
</Page>

<style>
  .faq-list {
    max-width: 800px;
    margin-inline: auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-stone);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) 0;
    cursor: pointer;
    font-size: var(--font-size-lg);
    font-weight: 500;
    color: var(--color-navy);
    list-style: none;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__icon {
    flex-shrink: 0;
    transition: transform var(--duration-fast);
    color: var(--color-text-light);
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(180deg);
  }

  .faq-item__answer {
    padding-bottom: var(--space-lg);
    color: var(--color-text);
    line-height: 1.7;
  }
</style>
