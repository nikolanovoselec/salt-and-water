---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import SchemaOrg from "~/components/seo/SchemaOrg.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

// Load from CMS
const cmsFaqs = await getLocalizedCollection("faqs", typedLocale);

// Build FAQ list from CMS or fallback
type FaqItem = { question: string; answer: string; category: string };
let faqs: FaqItem[] = [];

if (cmsFaqs.length > 0) {
  faqs = cmsFaqs
    .sort((a, b) => ((a.data.sort_order as number) ?? 0) - ((b.data.sort_order as number) ?? 0))
    .map((f) => ({
      question: f.data.question as string,
      answer: f.data.answer as string,
      category: (f.data.category as string) ?? "general",
    }));
} else {
  // Fallback
  const fb: Record<Locale, FaqItem[]> = {
    hr: [
      { question: "Kako doći na Pašman?", answer: "Trajektom iz Biograda na Moru do Tkona (25 min) ili preko mosta Ždrelac s Ugljana.", category: "getting-there" },
      { question: "Ima li klima uređaj?", answer: "Da, svi apartmani imaju klimu.", category: "apartment" },
      { question: "Ima li parkinga?", answer: "Da, besplatno parkiranje je dostupno uz smještaj.", category: "apartment" },
      { question: "Jesu li kućni ljubimci dozvoljeni?", answer: "Molimo pitajte pri rezervaciji. Primamo kućne ljubimce, ali vrijede određeni uvjeti.", category: "booking" },
      { question: "Kada je prijava/odjava?", answer: "Prijava od 14:00, odjava do 10:00. Fleksibilni termini po dogovoru.", category: "booking" },
      { question: "Ima li Wi-Fi?", answer: "Da, besplatan brzi Wi-Fi je dostupan u svim apartmanima.", category: "apartment" },
      { question: "Gdje mogu kupiti namirnice?", answer: "Najbliža trgovina je u Ždrelacu (5 min pješice). Veći supermarketi su u Tkonu i na Ugljanu.", category: "getting-there" },
    ],
    de: [
      { question: "Wie komme ich nach Pašman?", answer: "Mit der Fähre von Biograd na Moru nach Tkon (25 Min.) oder über die Ždrelac-Brücke von Ugljan.", category: "getting-there" },
      { question: "Gibt es Klimaanlage?", answer: "Ja, alle Ferienwohnungen haben eine Klimaanlage.", category: "apartment" },
      { question: "Gibt es Parkplätze?", answer: "Ja, kostenlose Parkplätze sind direkt bei der Unterkunft vorhanden.", category: "apartment" },
      { question: "Sind Haustiere erlaubt?", answer: "Bitte fragen Sie bei der Buchung nach. Wir sind haustierfreundlich, es gelten jedoch bestimmte Bedingungen.", category: "booking" },
      { question: "Wann ist Check-in/Check-out?", answer: "Check-in ab 14:00 Uhr, Check-out bis 10:00 Uhr. Flexible Zeiten nach Absprache möglich.", category: "booking" },
      { question: "Gibt es WLAN?", answer: "Ja, kostenloses Highspeed-WLAN ist in allen Ferienwohnungen verfügbar.", category: "apartment" },
      { question: "Wo kann ich Lebensmittel kaufen?", answer: "Der nächste Laden ist in Ždrelac (5 Min. zu Fuß). Größere Supermärkte gibt es in Tkon und auf Ugljan.", category: "getting-there" },
    ],
    sl: [
      { question: "Kako pridem na Pašman?", answer: "S trajektom iz Biograda na Moru do Tkona (25 min) ali čez most Ždrelac z Ugljana.", category: "getting-there" },
      { question: "Ali je na voljo klima?", answer: "Da, vsi apartmaji imajo klimatsko napravo.", category: "apartment" },
      { question: "Ali je na voljo parkirišče?", answer: "Da, brezplačno parkirišče je na voljo neposredno ob nastanitvi.", category: "apartment" },
      { question: "Ali so hišni ljubljenčki dovoljeni?", answer: "Prosimo, vprašajte ob rezervaciji. Smo prijazni do živali, vendar veljajo določeni pogoji.", category: "booking" },
      { question: "Kdaj je prijava/odjava?", answer: "Prijava od 14:00, odjava do 10:00. Prilagodljivi časi po dogovoru.", category: "booking" },
      { question: "Ali je na voljo Wi-Fi?", answer: "Da, brezplačen hitri Wi-Fi je na voljo v vseh apartmajih.", category: "apartment" },
      { question: "Kje lahko kupim živila?", answer: "Najbližja trgovina je v Ždrelacu (5 min hoje). Večji supermarketi so v Tkonu in na Ugljanu.", category: "getting-there" },
    ],
    en: [
      { question: "How do I get to Pašman?", answer: "By ferry from Biograd na Moru to Tkon (25 min) or via the Ždrelac bridge from Ugljan.", category: "getting-there" },
      { question: "Is there air conditioning?", answer: "Yes, all apartments have air conditioning.", category: "apartment" },
      { question: "Is parking available?", answer: "Yes, free parking is available right at the property.", category: "apartment" },
      { question: "Are pets allowed?", answer: "Please ask when booking. We are pet-friendly but certain conditions apply.", category: "booking" },
      { question: "What are check-in/check-out times?", answer: "Check-in from 14:00, check-out by 10:00. Flexible times possible by arrangement.", category: "booking" },
      { question: "Is there Wi-Fi?", answer: "Yes, free high-speed Wi-Fi is available in all apartments.", category: "apartment" },
      { question: "Where can I buy groceries?", answer: "The nearest shop is in Ždrelac (5 min walk). Larger supermarkets are in Tkon and on Ugljan.", category: "getting-there" },
    ],
  };
  faqs = fb[typedLocale];
}

// Schema.org FAQPage
const faqSchema = {
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Page title={t(typedLocale, "faq.title")} locale={typedLocale}>
  <SchemaOrg type="FAQPage" data={faqSchema} />
  <HeroSimple title={t(typedLocale, "faq.title")} image="https://images.pexels.com/photos/3580532/pexels-photo-3580532.jpeg?auto=compress&w=1920" />

  <section class="section">
    <div class="container">
      <div class="faq-list" data-reveal-stagger>
        {faqs.map((faq, i) => (
          <details class="faq-item" id={i === faqs.length - 1 ? "house-rules" : undefined}>
            <summary class="faq-item__question">
              {faq.question}
              <svg class="faq-item__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              </svg>
            </summary>
            <div class="faq-item__answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .faq-list {
    max-width: 800px;
    margin-inline: auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-stone);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) 0;
    cursor: pointer;
    font-size: var(--font-size-lg);
    font-weight: 500;
    color: var(--color-navy);
    list-style: none;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__icon {
    flex-shrink: 0;
    transition: transform var(--duration-fast);
    color: var(--color-text-light);
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(180deg);
  }

  .faq-item__answer {
    padding-bottom: var(--space-lg);
    color: var(--color-text);
    line-height: 1.7;
  }
</style>
