---
import Page from "~/layouts/Page.astro";
import HeroSimple from "~/components/ui/HeroSimple.astro";
import { isValidLocale, type Locale } from "~/i18n/config";
import { getLocalizedCollection } from "~/lib/content";

const { locale } = Astro.params;
if (!locale || !isValidLocale(locale)) return Astro.redirect("/hr/", 302);
const typedLocale = locale as Locale;

const pages = await getLocalizedCollection("editorial", typedLocale);
const page = pages.find((p) => p.data.page_key === "impressum");

const fallback: Record<Locale, { title: string; body: string }> = {
  hr: { title: "Impressum", body: "Apartmani Novoselec\nŽdrelac, Pašman\n23262, Hrvatska\n\nKontakt:\nEmail: info@apartmani-zdrelac.hr\nTelefon: +385 XX XXX XXXX\n\nOdgovorna osoba: [Ime vlasnika]" },
  de: { title: "Impressum", body: "Apartmani Novoselec\nŽdrelac, Pašman\n23262, Kroatien\n\nKontakt:\nE-Mail: info@apartmani-zdrelac.hr\nTelefon: +385 XX XXX XXXX\n\nVerantwortliche Person: [Name des Eigentümers]" },
  sl: { title: "Impressum", body: "Apartmani Novoselec\nŽdrelac, Pašman\n23262, Hrvaška\n\nKontakt:\nE-pošta: info@apartmani-zdrelac.hr\nTelefon: +385 XX XXX XXXX\n\nOdgovorna oseba: [Ime lastnika]" },
  en: { title: "Legal Notice", body: "Apartmani Novoselec\nŽdrelac, Pašman\n23262, Croatia\n\nContact:\nEmail: info@apartmani-zdrelac.hr\nPhone: +385 XX XXX XXXX\n\nResponsible person: [Owner name]" },
};

const title = (page?.data.title as string) ?? fallback[typedLocale].title;
const body = (page?.data.body as string) ?? fallback[typedLocale].body;
---

<Page title={title} locale={typedLocale}>
  <HeroSimple title={title} />

  <section class="section">
    <div class="container legal-content">
      {body.split("\n\n").map((paragraph) => (
        <p>{paragraph.split("\n").map((line, i) => (
          <>{i > 0 && <br />}{line}</>
        ))}</p>
      ))}
    </div>
  </section>
</Page>

<style>
  .legal-content {
    max-width: 700px;
    margin-inline: auto;
  }

  .legal-content p {
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }
</style>
