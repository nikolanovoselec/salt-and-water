---
/**
 * GET /admin-login?key=<secret>
 *
 * One-time endpoint to create an admin session without passkey.
 * Visit this URL in your browser to log in.
 *
 * DELETE THIS FILE after setting up passkey auth.
 */

const key = Astro.url.searchParams.get("key");
if (key !== "REDACTED_BYPASS_KEY") {
  return Astro.redirect("/");
}

// Set Emdash session
await Astro.session?.set("user", { id: "01SETUP000000000000000001" });
---

<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="refresh" content="1;url=/_emdash/admin/">
  <title>Logging in...</title>
  <style>
    body { font-family: system-ui; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; background: #0A1F33; color: white; }
    .msg { text-align: center; }
    .msg h1 { font-size: 1.5rem; font-weight: 300; margin-bottom: 1rem; }
    .msg p { opacity: 0.6; font-size: 0.875rem; }
    .msg a { color: #1A6B8F; }
  </style>
</head>
<body>
  <div class="msg">
    <h1>Logging you in...</h1>
    <p>Redirecting to admin panel. If nothing happens, <a href="/_emdash/admin/">click here</a>.</p>
  </div>
</body>
</html>
