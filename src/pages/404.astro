---
import Page from "~/layouts/Page.astro";

const locale = "hr" as const;
---

<Page title="404" locale={locale}>
  <section class="section" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="container text-center">
      <h1 style="font-size: clamp(4rem, 10vw, 8rem); font-weight: 200; color: var(--color-navy); opacity: 0.3;">404</h1>
      <p style="font-size: var(--font-size-xl); margin-top: var(--space-lg);">
        This page could not be found.
      </p>
      <div style="margin-top: var(--space-2xl); display: flex; flex-wrap: wrap; gap: var(--space-md); justify-content: center;">
        <a href="/hr/" class="btn">Početna (HR)</a>
        <a href="/de/" class="btn">Startseite (DE)</a>
        <a href="/en/" class="btn">Home (EN)</a>
        <a href="/sl/" class="btn">Domov (SL)</a>
      </div>
    </div>
  </section>
</Page>
