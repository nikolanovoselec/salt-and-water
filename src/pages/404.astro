---
import Base from "~/layouts/Base.astro";
---

<Base title="404 — Page Not Found">
  <main style="max-width: 600px; margin: 6rem auto; padding: 0 1.5rem; text-align: center;">
    <h1 style="font-size: 4rem; font-weight: 200; color: #0C2D48;">404</h1>
    <p style="font-size: 1.25rem; color: #4A4A4A; margin-top: 1rem;">
      This page could not be found.
    </p>
    <a href="/" style="display: inline-block; margin-top: 2rem; color: #1B6B93; text-decoration: underline;">
      Go to homepage
    </a>
  </main>
</Base>
