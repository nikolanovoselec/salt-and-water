---
import type { Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { formatCurrency, formatDateRange } from "~/i18n/format";
import type { Season } from "~/lib/pricing";

interface Props {
  locale: Locale;
  seasons: readonly Season[];
  cleaningFee: number;
  touristTaxRate: number;
  showTotalPrice?: boolean; // PAngV: true for German locale
}

const { locale, seasons, cleaningFee, touristTaxRate, showTotalPrice = false } = Astro.props;

const sortedSeasons = [...seasons].sort(
  (a, b) => a.startDate.localeCompare(b.startDate),
);
---

<div class="pricing-table" data-reveal>
  <h3>{t(locale, "pricing.title")}</h3>

  {sortedSeasons.length === 0 ? (
    <p class="pricing-table__empty">{t(locale, "pricing.onRequest")}</p>
  ) : (
    <>
      <table>
        <thead>
          <tr>
            <th>{t(locale, "pricing.season")}</th>
            <th>{t(locale, "pricing.dateRange")}</th>
            <th>{t(locale, "pricing.perNight")}</th>
            <th>{t(locale, "pricing.minStay")}</th>
          </tr>
        </thead>
        <tbody>
          {sortedSeasons.map((season) => (
            <tr>
              <td>{season.name}</td>
              <td>{formatDateRange(locale, new Date(season.startDate), new Date(season.endDate))}</td>
              <td>{formatCurrency(locale, season.pricePerNight)}</td>
              <td>{season.minStay} {t(locale, "pricing.nights")}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="pricing-table__fees">
        {cleaningFee > 0 && (
          <p>{t(locale, "pricing.cleaningFee")}: {formatCurrency(locale, cleaningFee)}</p>
        )}
        <p>{t(locale, "pricing.touristTaxNote", { rate: String(touristTaxRate) })}</p>
      </div>

      <p class="pricing-table__disclaimer">{t(locale, "pricing.disclaimer")}</p>
    </>
  )}
</div>

<style>
  .pricing-table h3 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-lg);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }

  th {
    text-align: left;
    font-weight: 600;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-light);
    padding: var(--space-sm) var(--space-md) var(--space-sm) 0;
    border-bottom: 1px solid var(--color-stone);
  }

  td {
    padding: var(--space-md) var(--space-md) var(--space-md) 0;
    border-bottom: 1px solid var(--color-stone);
  }

  td:nth-child(3) {
    font-family: var(--font-serif);
    font-size: var(--font-size-lg);
    color: var(--color-navy);
  }

  .pricing-table__fees {
    margin-top: var(--space-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .pricing-table__fees p {
    margin-bottom: var(--space-xs);
  }

  .pricing-table__disclaimer {
    margin-top: var(--space-md);
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
    font-style: italic;
  }

  .pricing-table__empty {
    font-family: var(--font-serif);
    font-size: var(--font-size-xl);
    color: var(--color-navy);
    margin-top: var(--space-lg);
  }

  @media (max-width: 640px) {
    table {
      font-size: var(--font-size-xs);
    }

    th, td {
      padding: var(--space-sm) var(--space-sm) var(--space-sm) 0;
    }
  }
</style>
