---
import { buildMediaUrl } from "~/lib/media";
import type { Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

interface Photo {
  readonly key: string;
  readonly alt: string;
  readonly blurhash?: string;
}

interface Props {
  locale: Locale;
  photos: readonly Photo[];
}

const { locale, photos } = Astro.props;

const displayPhotos = photos.slice(0, 6);
const totalPhotos = photos.length;
---

{photos.length > 0 && (
  <div class="gallery" data-reveal>
    <div class="gallery__grid">
      {displayPhotos.map((photo, i) => (
        <button
          class="gallery__item image-hover-zoom"
          data-gallery-index={i}
          data-gallery-trigger
          aria-label={photo.alt || `Photo ${i + 1}`}
        >
          <img
            src={buildMediaUrl(photo.key, { width: i === 0 ? 1200 : 800, format: "webp", quality: 80 })}
            alt={photo.alt}
            loading={i === 0 ? "eager" : "lazy"}
            width={i === 0 ? 1200 : 800}
            height={i === 0 ? 800 : 500}
          />
        </button>
      ))}
    </div>

    {totalPhotos > 6 && (
      <button class="gallery__view-all btn" data-gallery-trigger data-gallery-index="0">
        {t(locale, "apartments.viewAll")} ({totalPhotos})
      </button>
    )}

    {/* Lightbox data for client-side island */}
    <script
      type="application/json"
      id="gallery-data"
      set:html={JSON.stringify(
        photos.map((p) => ({
          src: buildMediaUrl(p.key, { width: 1920, format: "webp", quality: 85 }),
          alt: p.alt,
        }))
      )}
    />
  </div>
)}

<style>
  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  @media (min-width: 768px) {
    .gallery__grid {
      grid-template-columns: 2fr 1fr;
      grid-template-rows: auto auto;
    }

    .gallery__item:first-child {
      grid-row: span 2;
    }
  }

  .gallery__item {
    position: relative;
    border: none;
    padding: 0;
    cursor: pointer;
    background: var(--color-stone);
    border-radius: var(--radius-sm);
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 10;
  }

  .gallery__item:first-child img {
    aspect-ratio: 4 / 3;
  }

  .gallery__view-all {
    margin-top: var(--space-lg);
  }

  /* Mobile: horizontal scroll */
  @media (max-width: 767px) {
    .gallery__grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: var(--space-sm);
      padding-bottom: var(--space-sm);
    }

    .gallery__item {
      flex: 0 0 85vw;
      scroll-snap-align: center;
    }

    .gallery__item img {
      aspect-ratio: 4 / 3;
    }
  }
</style>
