---
/**
 * MiniCollage - A compact scrolling photo strip for editorial sections.
 * Fits inside a content row alongside text.
 * Falls back to a single static image when only 1 photo provided.
 */
interface Props {
  images: Array<{ src: string; alt: string }>;
  speed?: number;
  reverse?: boolean;
  showCaptions?: boolean;
}

const { images, speed = 20, reverse = false, showCaptions = false } = Astro.props;
const hasMultiple = images.length > 1;
---

{hasMultiple ? (
  <div class:list={["mini-collage", { "mini-collage--reverse": reverse }]} role="region" aria-roledescription="carousel" aria-label={images[0]?.alt ?? "Photos"}>
    <div class="mini-collage__track" style={`animation-duration: ${speed}s;`}>
      {images.map((img) => (
        <div class="mini-collage__item">
          <img src={img.src} alt={img.alt} width="400" height="300" loading="lazy" />
          {showCaptions && img.alt && <span class="mini-collage__caption">{img.alt}</span>}
        </div>
      ))}
      {images.map((img) => (
        <div class="mini-collage__item" aria-hidden="true">
          <img src={img.src} alt="" width="400" height="300" loading="lazy" />
          {showCaptions && img.alt && <span class="mini-collage__caption">{img.alt}</span>}
        </div>
      ))}
    </div>
  </div>
) : images.length === 1 ? (
  <div class="mini-collage mini-collage--single">
    <img src={images[0].src} alt={images[0].alt} width="800" height="600" loading="lazy" />
  </div>
) : null}

<style>
  @keyframes mini-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .mini-collage {
    overflow: hidden;
    width: 100%;
    padding: var(--space-sm) 0;
  }

  .mini-collage__track {
    display: flex;
    gap: var(--space-md);
    animation-name: mini-scroll;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    width: max-content;
  }

  .mini-collage--reverse .mini-collage__track {
    animation-direction: reverse;
  }

  .mini-collage:hover .mini-collage__track {
    animation-play-state: paused;
  }

  .mini-collage__item {
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .mini-collage__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    font-weight: 400;
    font-style: normal;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.5) 0%, transparent 100%);
    pointer-events: none;
  }

  .mini-collage__item img {
    height: 250px;
    width: auto;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .mini-collage__item img {
      height: 350px;
    }
  }

  /* Single image fallback — no radius, full width like collage strips */
  .mini-collage--single {
    overflow: hidden;
  }

  .mini-collage--single img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .mini-collage__track {
      animation: none;
    }
    .mini-collage {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .mini-collage::-webkit-scrollbar {
      display: none;
    }
  }
</style>
