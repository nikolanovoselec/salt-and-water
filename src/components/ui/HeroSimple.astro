---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="hero-simple">
  <div class="hero-simple__bg"></div>
  <div class="container text-center hero-simple__content">
    <h1>{title}</h1>
    {subtitle && <p class="hero-simple__subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .hero-simple {
    position: relative;
    padding: calc(var(--nav-height) + var(--space-4xl)) 0 var(--space-4xl);
    overflow: hidden;
  }

  .hero-simple__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(26, 107, 143, 0.15) 0%, transparent 60%),
      linear-gradient(175deg, #0A1F33 0%, #122E47 50%, #0F2740 100%);
    z-index: 0;
  }

  .hero-simple__content {
    position: relative;
    z-index: 1;
  }

  .hero-simple h1 {
    color: var(--color-white);
    font-size: clamp(2.25rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .hero-simple__subtitle {
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--font-size-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: var(--space-md);
    max-width: none;
  }
</style>
