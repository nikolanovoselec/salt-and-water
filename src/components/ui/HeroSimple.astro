---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}

const { title, subtitle, image } = Astro.props;
---

<section class="hero-simple">
  {image ? (
    <img class="hero-simple__img" src={image} alt="" width="1920" height="600" />
  ) : (
    <div class="hero-simple__bg"></div>
  )}
  <div class="hero-simple__overlay"></div>
  <div class="container text-center hero-simple__content">
    <h1>{title}</h1>
    {subtitle && <p class="hero-simple__subtitle">{subtitle}</p>}
  </div>
  {/* Wave at bottom of hero */}
  <svg class="hero-simple__wave" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
  </svg>
</section>

<style>
  .hero-simple {
    position: relative;
    min-height: 360px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + var(--space-3xl)) 0 var(--space-2xl);
  }

  .hero-simple__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 0;
    animation: heroSimpleZoom 20s ease-in-out infinite alternate;
  }

  @keyframes heroSimpleZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.06); }
  }

  .hero-simple__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(26, 107, 143, 0.15) 0%, transparent 60%),
      linear-gradient(175deg, #0A1F33 0%, #122E47 50%, #0F2740 100%);
    z-index: 0;
  }

  .hero-simple__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 31, 51, 0.5) 0%, rgba(10, 31, 51, 0.7) 100%);
    z-index: 1;
  }

  .hero-simple__content {
    position: relative;
    z-index: 2;
  }

  .hero-simple h1 {
    color: var(--color-white);
    font-size: clamp(2.25rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .hero-simple__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 3;
    display: block;
    width: 100%;
    height: clamp(40px, 6vw, 80px);
  }

  .hero-simple__subtitle {
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--font-size-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: var(--space-md);
    max-width: none;
  }
</style>
