---
import type { Locale } from "~/i18n/config";
import { t } from "~/i18n/t";
import { locales, localeNames } from "~/i18n/config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const navItems = [
  { key: "nav.apartments", href: `/${locale}/apartmani` },
  { key: "nav.zdrelac", href: `/${locale}/zdrelac` },
  { key: "nav.gallery", href: `/${locale}/galerija` },
  { key: "nav.gettingHere", href: `/${locale}/dolazak` },
  { key: "nav.localGuide", href: `/${locale}/vodic` },
  { key: "nav.about", href: `/${locale}/o-nama` },
];

function getLocalizedPath(targetLocale: string): string {
  const currentPath = Astro.url.pathname;
  const pathWithoutLocale = currentPath.replace(/^\/[a-z]{2}(\/|$)/, "/");
  return `/${targetLocale}${pathWithoutLocale === "/" ? "" : pathWithoutLocale}`;
}
---

<header class="nav" id="site-nav">
  <div class="nav__inner container">
    <a href={`/${locale}`} class="nav__logo" aria-label={t(locale, "nav.home")}>
      <span class="nav__logo-text">Apartmani Novoselec</span>
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      {navItems.map((item) => (
        <a href={item.href} class="nav__link">
          {t(locale, item.key)}
        </a>
      ))}
    </nav>

    <div class="nav__actions">
      <slot name="language-switcher" />
      <a href={`/${locale}/kontakt`} class="btn btn--primary nav__cta">
        {t(locale, "nav.inquire")}
      </a>
    </div>

    <button
      class="nav__hamburger"
      id="hamburger-btn"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

{/* Mobile menu overlay */}
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="mobile-menu__nav" aria-label="Mobile navigation">
    {navItems.map((item) => (
      <a href={item.href} class="mobile-menu__link">
        {t(locale, item.key)}
      </a>
    ))}

    {/* Language picker in mobile menu */}
    <div class="mobile-menu__langs">
      {locales.map((loc) => (
        <a
          href={getLocalizedPath(loc)}
          class:list={["mobile-menu__lang", { "is-active": loc === locale }]}
          lang={loc}
        >
          {localeNames[loc]}
        </a>
      ))}
    </div>

    <a href={`/${locale}/kontakt`} class="btn btn--primary mobile-menu__cta">
      {t(locale, "nav.inquire")}
    </a>
  </nav>
</div>

<style is:global>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    transition: background var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .nav.is-scrolled {
    background: rgba(250, 247, 242, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.05);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
  }

  .nav__logo {
    text-decoration: none;
    color: var(--color-white);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .nav.is-scrolled .nav__logo {
    color: var(--color-navy);
  }

  .nav__logo-text {
    font-family: var(--font-serif);
    font-size: var(--font-size-xl);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .nav__links {
    display: none;
    gap: var(--space-lg);
  }

  .nav__link {
    color: var(--color-white);
    font-size: var(--font-size-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .nav.is-scrolled .nav__link {
    color: var(--color-warm-gray);
  }

  .nav__link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav__actions {
    display: none;
    align-items: center;
    gap: var(--space-md);
  }

  .nav__cta {
    color: var(--color-white);
    border-color: var(--color-white);
    padding: 0.5rem 1.25rem;
    font-size: var(--font-size-xs);
  }

  .nav.is-scrolled .nav__cta {
    color: var(--color-navy);
    border-color: var(--color-navy);
  }

  /* Hamburger — global styles to avoid scoping issues */
  .nav__hamburger {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 12px;
    color: var(--color-white);
    transition: color var(--duration-normal) var(--ease-out);
    z-index: 101;
    position: relative;
  }

  .nav__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .nav__hamburger.is-open span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .nav__hamburger.is-open span:nth-child(2) {
    opacity: 0;
  }

  .nav__hamburger.is-open span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .nav.is-scrolled .nav__hamburger {
    color: var(--color-navy);
  }

  /* Mobile menu — global for JS class toggling */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--color-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  .mobile-menu__link {
    color: var(--color-white);
    font-family: var(--font-serif);
    font-size: var(--font-size-3xl);
    font-weight: 400;
    text-decoration: none;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
  }

  .mobile-menu.is-open .mobile-menu__link {
    opacity: 1;
    transform: translateX(0);
  }

  .mobile-menu.is-open .mobile-menu__link:nth-child(1) { transition-delay: 0.1s; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(2) { transition-delay: 0.15s; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(3) { transition-delay: 0.2s; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(4) { transition-delay: 0.25s; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(5) { transition-delay: 0.3s; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(6) { transition-delay: 0.35s; }

  /* Mobile language picker */
  .mobile-menu__langs {
    display: flex;
    gap: var(--space-md);
    opacity: 0;
    transition: opacity 0.5s var(--ease-out) 0.4s;
  }

  .mobile-menu.is-open .mobile-menu__langs {
    opacity: 1;
  }

  .mobile-menu__lang {
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    transition: color 0.2s;
  }

  .mobile-menu__lang:hover,
  .mobile-menu__lang.is-active {
    color: var(--color-white);
  }

  .mobile-menu__cta {
    margin-top: var(--space-lg);
    color: var(--color-white);
    border-color: var(--color-white);
    opacity: 0;
    transition: opacity 0.5s var(--ease-out) 0.45s;
  }

  .mobile-menu.is-open .mobile-menu__cta {
    opacity: 1;
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .nav__links {
      display: flex;
    }

    .nav__actions {
      display: flex;
    }

    .nav__hamburger {
      display: none;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    // Transparent-to-solid on scroll
    var nav = document.getElementById("site-nav");
    var heroSentinel = document.querySelector(".hero-sentinel");

    if (nav && heroSentinel) {
      var observer = new IntersectionObserver(
        function(entries) {
          nav.classList.toggle("is-scrolled", !entries[0].isIntersecting);
        },
        { threshold: 0 }
      );
      observer.observe(heroSentinel);
    } else if (nav) {
      nav.classList.add("is-scrolled");
    }

    // Mobile menu toggle
    var hamburger = document.getElementById("hamburger-btn");
    var mobileMenu = document.getElementById("mobile-menu");

    if (hamburger && mobileMenu) {
      hamburger.addEventListener("click", function() {
        var isOpen = mobileMenu.classList.toggle("is-open");
        hamburger.classList.toggle("is-open", isOpen);
        hamburger.setAttribute("aria-expanded", String(isOpen));
        mobileMenu.setAttribute("aria-hidden", String(!isOpen));
        document.body.style.overflow = isOpen ? "hidden" : "";
      });

      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape" && mobileMenu.classList.contains("is-open")) {
          mobileMenu.classList.remove("is-open");
          hamburger.classList.remove("is-open");
          hamburger.setAttribute("aria-expanded", "false");
          mobileMenu.setAttribute("aria-hidden", "true");
          document.body.style.overflow = "";
          hamburger.focus();
        }
      });
    }
  });
</script>
