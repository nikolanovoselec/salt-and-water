---
import type { Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const heroImages = [
  "https://images.pexels.com/photos/1285625/pexels-photo-1285625.jpeg?auto=compress&w=1920",
  "https://images.pexels.com/photos/1450353/pexels-photo-1450353.jpeg?auto=compress&w=1920",
  "https://images.pexels.com/photos/2440061/pexels-photo-2440061.jpeg?auto=compress&w=1920",
  "https://images.pexels.com/photos/3601425/pexels-photo-3601425.jpeg?auto=compress&w=1920",
];
---

<section class="hero" id="hero-carousel">
  {/* Carousel background images — stacked, crossfade via JS */}
  {heroImages.map((img, i) => (
    <div class:list={["hero__slide", { "is-active": i === 0 }]} data-slide={i}>
      <img src={img} alt="" width="1920" height="1080" loading={i === 0 ? "eager" : "lazy"} fetchpriority={i === 0 ? "high" : "auto"} />
    </div>
  ))}

  <div class="hero__overlay"></div>

  <div class="hero__content">
    <p class="hero__label text-label">
      {locale === "hr" ? "Otok Pašman, Hrvatska" :
       locale === "de" ? "Insel Pašman, Kroatien" :
       locale === "sl" ? "Otok Pašman, Hrvaška" :
       "Pašman Island, Croatia"}
    </p>
    <h1 class="hero-title">
      <span class="hero-title__line">Apartmani</span>
      <span class="hero-title__line hero-title__line--accent">Novoselec</span>
    </h1>
    <p class="hero-subtitle">{t(locale, "hero.tagline")}</p>
    <div class="hero__cta">
      <a href={`/${locale}/apartmani`} class="btn btn--ghost">
        {t(locale, "nav.apartments")}
      </a>
    </div>
  </div>

  <div class="hero__bottom">
    <div class="hero__scroll scroll-indicator" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M12 5v14M19 12l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    height: 100svh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-white);
    overflow: hidden;
    background: #0A1F33;
  }

  /* Carousel slides — stacked, crossfade */
  .hero__slide {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 1.8s ease-in-out;
  }

  .hero__slide.is-active {
    opacity: 1;
  }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Slow Ken Burns zoom on active slide */
    transform: scale(1);
    transition: transform 8s ease-out;
  }

  .hero__slide.is-active img {
    transform: scale(1.08);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(1200px 800px at 50% 30%, rgba(10, 31, 51, 0.3), rgba(10, 31, 51, 0.65)),
      linear-gradient(180deg, rgba(10, 31, 51, 0.4) 0%, rgba(10, 31, 51, 0.2) 40%, rgba(10, 31, 51, 0.8) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 0 var(--space-lg);
  }

  .hero__label {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-xl);
    letter-spacing: 0.2em;
    font-size: var(--font-size-xs);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 400;
    color: var(--color-white);
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: var(--space-xl);
  }

  .hero-title__line {
    display: block;
  }

  .hero-title__line--accent {
    color: rgba(255, 255, 255, 0.65);
    font-style: italic;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.7;
    max-width: 400px;
    margin-inline: auto;
    margin-bottom: var(--space-2xl);
  }

  .hero__cta {
    margin-top: var(--space-lg);
  }

  .hero__bottom {
    position: absolute;
    bottom: var(--space-2xl);
    z-index: 2;
  }

  .hero__scroll {
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: clamp(2.5rem, 12vw, 4.5rem);
    }
    .hero-subtitle {
      font-size: var(--font-size-xs);
    }
  }
</style>

<script is:inline>
  // Hero carousel — auto-crossfade with Ken Burns, no manual controls
  (function() {
    var slides = document.querySelectorAll('.hero__slide');
    if (slides.length < 2) return;

    var current = 0;
    var total = slides.length;

    function next() {
      slides[current].classList.remove('is-active');
      current = (current + 1) % total;
      slides[current].classList.add('is-active');
    }

    setInterval(next, 6000);
  })();
</script>
