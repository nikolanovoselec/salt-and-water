---
import type { Locale } from "~/i18n/config";
import { t } from "~/i18n/t";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const heroImages = [
  "/api/img/029648ae-b7af-4bd4-831a-4ceba2b9c4d7",
  "/api/img/c047fffd-b9b7-4a05-84f9-7df061389901",
  "/api/img/953b4b07-6c3a-4df1-8358-63a2997e6d24",
  "/api/img/bd440b3f-7f65-4971-bfba-639458c5b9ec",
  "/api/img/c9c4485b-df86-4179-8d49-6cbbfbe0948c",
  "/api/img/ceec62e2-e1a1-42db-914b-64807c4751f7",
];
---

<section class="hero" id="hero-carousel">
  {/* Carousel background images — stacked, crossfade via JS */}
  {heroImages.map((img, i) => (
    <div class:list={["hero__slide", { "is-active": i === 0 }]} data-slide={i}>
      <img src={img} alt="" width="1920" height="1080" loading={i === 0 ? "eager" : "lazy"} fetchpriority={i === 0 ? "high" : "auto"} />
    </div>
  ))}

  <div class="hero__overlay"></div>

  <div class="hero__content">
    <p class="hero__label text-label">
      {locale === "hr" ? "Otok Pašman, Hrvatska" :
       locale === "de" ? "Insel Pašman, Kroatien" :
       locale === "sl" ? "Otok Pašman, Hrvaška" :
       "Pašman Island, Croatia"}
    </p>
    <h1 class="hero-title">
      <span class="hero-title__line">Apartmani</span>
      <span class="hero-title__line hero-title__line--accent">Novoselec</span>
    </h1>
    <p class="hero-subtitle">{t(locale, "hero.tagline")}</p>
    <div class="hero__cta">
      <a href={`/${locale}/apartmani`} class="btn btn--ghost">
        {t(locale, "nav.apartments")}
      </a>
    </div>
  </div>

  <div class="hero__bottom">
    <div class="hero__scroll scroll-indicator" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M12 5v14M19 12l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
  <svg class="hero__wave" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,20 1440,40 L1440,80 L0,80 Z" fill="#F8F5EF" />
  </svg>
</section>

<style>
  .hero__wave {
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: clamp(50px, 8vw, 100px);
    z-index: 3;
    display: block;
  }

  .hero {
    position: relative;
    height: calc(100vh + clamp(50px, 8vw, 100px));
    height: calc(100svh + clamp(50px, 8vw, 100px));
    min-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-white);
    background: #0A1F33;
  }

  /* Carousel slides — stacked, crossfade. overflow:hidden here (not on .hero) to avoid clipping the wave */
  .hero__slide {
    position: absolute;
    overflow: hidden;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 1.8s ease-in-out;
  }

  .hero__slide.is-active {
    opacity: 1;
  }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Continuous slow zoom — never static */
    animation: heroZoom 12s ease-in-out infinite alternate;
    animation-play-state: paused;
  }

  .hero__slide.is-active img {
    animation-play-state: running;
  }

  @keyframes heroZoom {
    0%   { transform: scale(1) translate3d(0, 0, 0); }
    100% { transform: scale(1.1) translate3d(-1%, -1%, 0); }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(1200px 800px at 50% 30%, rgba(10, 31, 51, 0.3), rgba(10, 31, 51, 0.65)),
      linear-gradient(180deg, rgba(10, 31, 51, 0.4) 0%, rgba(10, 31, 51, 0.2) 40%, rgba(10, 31, 51, 0.5) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 0 var(--space-lg);
  }

  .hero__label {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-xl);
    letter-spacing: 0.2em;
    font-size: var(--font-size-xs);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 400;
    color: var(--color-white);
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: var(--space-xl);
  }

  .hero-title__line {
    display: block;
  }

  .hero-title__line--accent {
    color: rgba(255, 255, 255, 0.65);
    font-style: italic;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.7;
    max-width: 400px;
    margin-inline: auto;
    margin-bottom: var(--space-2xl);
  }

  .hero__cta {
    margin-top: var(--space-lg);
  }

  .hero__bottom {
    position: absolute;
    bottom: var(--space-2xl);
    z-index: 2;
  }

  .hero__scroll {
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: clamp(2.5rem, 12vw, 4.5rem);
    }
    .hero-subtitle {
      font-size: var(--font-size-xs);
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    var slides = document.querySelectorAll('.hero__slide');
    if (slides.length < 2) return;

    var current = 0;
    var total = slides.length;

    function next() {
      slides[current].classList.remove('is-active');
      current = (current + 1) % total;
      slides[current].classList.add('is-active');
    }

    setInterval(next, 6000);
  });
</script>
