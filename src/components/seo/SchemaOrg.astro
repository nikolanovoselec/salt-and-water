---
interface Props {
  type: "VacationRental" | "FAQPage" | "BreadcrumbList";
  data: Record<string, unknown>;
}

const { type, data } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": type,
  ...data,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema).replace(/</g, '\\u003c')} />
